---
import NidoLayout from "../../layouts/NidoLayout.astro";
import Logo from "../../components/Logo.astro";
import Nest from "../../components/Nest.astro";
import Icon from "../../components/Icon.astro";
import Toast from "../../components/Toast.astro";
import PasskeySheet from "../../components/PasskeySheet.astro";
---

<NidoLayout title="Nido — Set up your account" shell="focused">
  <div class="col-scroll scroll-hide pad screen-in">
    <!-- header: back-less brand + demo chip + 2-step progress -->
    <div style="padding: 6px 4px 22px;">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
        <Logo size={19} mark markSize={24} />
        <span class="chip" style="font-size:11px;"><span class="dot acc"></span>Testnet</span>
      </div>
      <div class="steps">
        <i id="step-1"></i>
        <i id="step-2"></i>
      </div>
    </div>

    <!-- account id surfaced quietly (preserves the contractId surface) -->
    <div class="addr" id="account-chip" style="margin-bottom:18px;">
      <Icon name="home" size={14} color="var(--mut)" />
      <code id="contract-id"></code>
    </div>

    <div id="error-box" role="alert" class="alert danger" style="display:none; margin-bottom:18px;"></div>

    <!-- ===================== STEP 1 · LOCK IT TO YOU ===================== -->
    <section id="passkey-section">
      <div style="display:grid; place-items:center; margin:10px 0 22px;">
        <span id="passkey-nest"><Nest size={104} /></span>
      </div>
      <h1 class="disp" style="font-weight:800; font-size:28px; line-height:1.06; text-align:center;">
        Lock it to you
      </h1>
      <p id="passkey-intro" class="mut" style="font-size:14.5px; line-height:1.55; margin-top:10px; text-align:center; max-width:330px; margin-inline:auto;">
        Use your passkey so only you can get into your Nido.
        Nothing to memorize, nothing to write down.
      </p>

      <div id="lock-info-list" style="display:flex; flex-direction:column; gap:14px; margin-top:26px;">
        <div class="lock-info-row" style="display:flex; gap:13px; align-items:flex-start;">
          <div style="width:38px; height:38px; border-radius:11px; background:var(--chip); display:grid; place-items:center; flex:0 0 auto;">
            <Icon name="lock" size={19} color="var(--ink-soft)" />
          </div>
          <div>
            <div style="font-weight:700; font-size:14.5px;">Only you get in</div>
            <div class="mut" style="font-size:13px; line-height:1.45;">Your face never leaves this device, and can't be faked.</div>
          </div>
        </div>
        <div class="lock-info-row" style="display:flex; gap:13px; align-items:flex-start;">
          <div style="width:38px; height:38px; border-radius:11px; background:var(--chip); display:grid; place-items:center; flex:0 0 auto;">
            <Icon name="refresh" size={19} color="var(--ink-soft)" />
          </div>
          <div>
            <div style="font-weight:700; font-size:14.5px;">Across your devices</div>
            <div class="mut" style="font-size:13px; line-height:1.45;">Set up once and it follows you to your phone and laptop.</div>
          </div>
        </div>
        <div class="lock-info-row" style="display:flex; gap:13px; align-items:flex-start;">
          <div style="width:38px; height:38px; border-radius:11px; background:var(--chip); display:grid; place-items:center; flex:0 0 auto;">
            <Icon name="shieldcheck" size={19} color="var(--ink-soft)" />
          </div>
          <div>
            <div style="font-weight:700; font-size:14.5px;">Never locked out</div>
            <div class="mut" style="font-size:13px; line-height:1.45;">Add a trusted friend later so you can always get back in.</div>
          </div>
        </div>
      </div>

      <button id="register-btn" class="btn acc" style="margin-top:28px;">
        <Icon name="key" size={20} color="#fff" />
        <span>Create with a passkey</span>
      </button>
    </section>

    <!-- ============= NEVER GET LOCKED OUT · recovery enrollment ============= -->
    <!-- Shown after the passkey is created, before deploy. Three choices, all
         funnelling into an in-memory `enrollSecret`/`enrollMethod` the deploy
         step reads — never persisted (mnemonic + wallet signature are
         derive-then-discard). See the enrollment handlers below. -->
    <section id="recovery-enroll-section" class="hidden">
      <div id="enroll-choices">
        <div style="display:grid; place-items:center; margin:10px 0 22px;">
          <Nest size={104} />
        </div>
        <h1 class="disp" style="font-weight:800; font-size:28px; line-height:1.06; text-align:center;">
          You're almost in
        </h1>
        <p class="mut" style="font-size:14.5px; line-height:1.55; margin-top:10px; text-align:center; max-width:330px; margin-inline:auto;">
          Your wallet is ready. You can add a backup way to get back in now, or anytime later from Security — we'll remind you.
        </p>

        <div style="display:flex; flex-direction:column; gap:12px; margin-top:26px;">
          <button id="enroll-continue" type="button" class="btn acc">
            <span>Continue to my wallet</span>
          </button>
          <button id="enroll-reveal-options" type="button" class="link" style="align-self:center; margin-top:2px; font-size:13.5px; background:none; border:none; cursor:pointer;">
            Set up a recovery backup now (optional)
          </button>

          <!-- Advanced/optional: the actual method choices, revealed only when
               the user opts in. Enrolling here happens at creation, so it stays
               invisible on-chain (uniform genesis leaf); skipping it defers to
               the visible home-page prompt. Kept behind the reveal so the
               default path is a one-tap "continue". -->
          <div id="enroll-options" class="hidden">
            <button id="enroll-seed" type="button" class="card" style="display:flex; gap:13px; align-items:center; width:100%; padding:16px; text-align:left; cursor:pointer; font:inherit; color:inherit;">
              <div style="width:42px; height:42px; border-radius:12px; background:var(--chip); display:grid; place-items:center; flex:0 0 auto;">
                <Icon name="key" size={20} color="var(--ink-soft)" />
              </div>
              <div style="flex:1;">
                <div style="font-weight:700; font-size:14.5px;">Seed phrase</div>
                <div class="mut" style="font-size:12.5px; line-height:1.4;">A 12-word backup, shown once. Write it down and keep it safe.</div>
              </div>
              <Icon name="chevron" size={18} color="var(--mut)" />
            </button>

            <button id="enroll-wallet" type="button" class="card" style="display:flex; gap:13px; align-items:center; width:100%; padding:16px; text-align:left; cursor:pointer; font:inherit; color:inherit;">
              <div style="width:42px; height:42px; border-radius:12px; background:var(--chip); display:grid; place-items:center; flex:0 0 auto;">
                <Icon name="wallet" size={20} color="var(--ink-soft)" />
              </div>
              <div style="flex:1;">
                <div style="font-weight:700; font-size:14.5px;">A wallet you own</div>
                <div class="mut" style="font-size:12.5px; line-height:1.4;">Sign one message with another Stellar wallet — nothing to write down.</div>
              </div>
              <Icon name="chevron" size={18} color="var(--mut)" />
            </button>

            <div id="enroll-status" class="mut" style="display:none; font-size:13px; text-align:center; margin-top:2px;"></div>
          </div>
        </div>
      </div>

      <!-- Seed reveal — the mnemonic exists only in this DOM subtree and in the
           `currentMnemonic` variable, both cleared the moment "continue" derives
           the secret. Never written to localStorage/cookies/logs. -->
      <div id="seed-reveal" class="hidden">
        <div style="display:grid; place-items:center; margin:10px 0 22px;">
          <Nest size={104} />
        </div>
        <h1 class="disp" style="font-weight:800; font-size:26px; line-height:1.06; text-align:center;">
          Your seed phrase
        </h1>
        <p class="mut" style="font-size:13.5px; line-height:1.5; margin-top:8px; text-align:center; max-width:330px; margin-inline:auto;">
          Write these 12 words down and keep them somewhere safe and private. This is the only time they're shown — Nido never stores them.
        </p>

        <div id="seed-words" class="mono" style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px 14px; margin-top:20px; padding:16px; border-radius:var(--r-md); background:var(--paper-2); border:1px solid var(--line); font-size:13.5px;"></div>

        <button id="seed-copy" type="button" class="btn ghost sm" style="margin-top:12px;">Copy to clipboard</button>

        <div class="alert warn" role="note" style="margin-top:16px;">
          Anyone with these words can recover your account. Never share them or type them into a website.
        </div>

        <button id="seed-continue" class="btn acc" style="margin-top:22px;">
          <span>I've written it down — continue</span>
        </button>
        <button id="seed-back" type="button" class="btn ghost" style="margin-top:10px;">
          <span>Back</span>
        </button>
      </div>
    </section>

    <!-- ===================== STEP 2 · SETTING UP ===================== -->
    <section id="deploy-section" class="hidden" style="min-height:440px;">
      <div style="flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center;">
        <div style="display:grid; place-items:center; height:116px;">
          <span id="deploy-nest-spinning"><Nest size={104} spin dur={1.1} /></span>
          <span id="deploy-nest-static" style="display:none;"><Nest size={104} /></span>
        </div>
        <h1 class="disp" style="font-weight:800; font-size:26px; margin-top:28px;">Setting up your Nido</h1>

        <div style="display:flex; flex-direction:column; gap:10px; margin-top:24px; width:100%; max-width:340px;">
          <div class="setup-card" id="check-0">
            <span class="check-mark"></span>
            <span class="check-text">Locked to you</span>
          </div>
          <div class="setup-card" id="check-1">
            <span class="check-mark"></span>
            <span class="check-text">Preparing transaction</span>
          </div>
          <div class="setup-card" id="check-2">
            <span class="check-mark"></span>
            <span class="check-text">Submitting to the network</span>
          </div>
          <div class="setup-card" id="check-3">
            <span class="check-mark"></span>
            <span class="check-text">Confirming on-chain</span>
          </div>
          <div class="setup-card" id="check-4">
            <span class="check-mark"></span>
            <span class="check-text">Finalizing your wallet</span>
          </div>
          <div class="setup-card" id="check-5">
            <span class="check-mark"></span>
            <span class="check-text">Your Nido is ready</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== DONE ===================== -->
    <section id="done-section" class="hidden">
      <div style="display:grid; place-items:center; margin:10px 0 22px;">
        <div style="width:72px; height:72px; border-radius:50%; background:var(--good-soft); display:grid; place-items:center; animation:pop .4s both;">
          <Icon name="check" size={36} color="var(--good)" stroke={2.6} />
        </div>
      </div>
      <h1 class="disp" style="font-weight:800; font-size:28px; line-height:1.06; text-align:center;">Your Nido is ready</h1>
      <p class="mut" style="font-size:14.5px; line-height:1.55; margin-top:10px; text-align:center; max-width:330px; margin-inline:auto;">
        It's live on Stellar and locked to you. Taking you to your wallet…
      </p>
      <!-- F-02: no manual "Go to your Nido" button — the flow auto-advances into /account/. -->
      <div style="display:flex; gap:9px; align-items:center; justify-content:center; color:var(--mut); margin-top:24px;">
        <Nest size={22} spin dur={1.1} />
        <span style="font-size:13.5px; font-weight:600;">Opening your Nido…</span>
      </div>
    </section>

    <!-- ============= RECOVERY CARD · which backup, shown once ============= -->
    <!-- Deliberately separate from #done-section: the C-address is surfaced
         there, the backup-method summary is surfaced here — never together
         (the seed words themselves were already shown once, in #seed-reveal,
         and are never repeated here). -->
    <section id="recovery-card-section" class="hidden">
      <div style="display:grid; place-items:center; margin:10px 0 22px;">
        <div style="width:72px; height:72px; border-radius:50%; background:var(--acc-soft); display:grid; place-items:center;">
          <Icon name="shieldcheck" size={34} color="var(--acc-ink)" />
        </div>
      </div>
      <h1 id="recovery-card-title" class="disp" style="font-weight:800; font-size:26px; line-height:1.06; text-align:center;"></h1>
      <p id="recovery-card-body" class="mut" style="font-size:14px; line-height:1.55; margin-top:10px; text-align:center; max-width:330px; margin-inline:auto;"></p>
    </section>

    <!-- ===================== RESERVING · explainer (page 1) ===================== -->
    <section id="preparing-section" class="hidden" style="min-height:440px;">
      <div style="display:grid; place-items:center; margin:32px 0 26px;">
        <Nest size={104} spin dur={1.1} />
      </div>
      <h1 class="disp" style="font-weight:800; font-size:28px; line-height:1.06; text-align:center;">
        Setting up your Nido
      </h1>
      <p class="mut" style="font-size:14.5px; line-height:1.55; margin-top:12px; text-align:center; max-width:330px; margin-inline:auto;">
        We're reserving your private address and moving you into your own secure space. This only takes a moment.
      </p>
      <div class="mut" style="display:flex; align-items:center; justify-content:center; gap:8px; font-size:13px; margin-top:26px; opacity:.85;">
        <span class="dot acc"></span><span id="preparing-status-text">Reserving your address…</span>
      </div>
      <button id="preparing-continue" class="btn acc" style="margin-top:22px;" disabled>
        <span>Preparing…</span>
      </button>
      <a id="preparing-home-link" href="/" class="link hidden" style="align-self:center; margin-top:18px; font-size:13.5px;">Start again from home</a>
    </section>
  </div>

  <!-- mounted once: real-promise-driven passkey sheet + toast host -->
  <PasskeySheet title="Lock it to you" sub="Confirm with your passkey to finish setting up." />
  <Toast />
</NidoLayout>

<style is:global>
  /* Visibility is owned by the `.hidden` toggle. The deploy step needs a flex
     column layout, but an inline `display:flex` would beat `.hidden` (which is
     not !important) and leave it rendered on top of the passkey step — the
     "two cards" bug. Apply the flex layout only while the section is shown. */
  #deploy-section:not(.hidden) { display: flex; flex-direction: column; }
  #preparing-section:not(.hidden) { display: flex; flex-direction: column; }
  /* On a reservation failure the flow stops here, so halt the spinner. */
  #preparing-section.is-error .nest-ring { animation-play-state: paused; }

  /* Setting-up checklist — full-sized boxed checkbox cards. A card dims while
     pending, lifts (accent border + soft shadow) while active, and shows a teal
     square checkmark when done. renderCheck fills the square .check-mark slot. */
  .setup-card {
    display: flex; align-items: center; gap: 14px;
    padding: 13px 15px;
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    background: var(--paper-2);
    opacity: .5;
    transition: opacity .3s ease, border-color .3s ease, box-shadow .3s ease;
  }
  .setup-card.is-active { opacity: 1; border-color: var(--acc); box-shadow: var(--sh-1); }
  .setup-card.is-done { opacity: 1; }
  .setup-card .check-mark { width: 28px; height: 28px; flex: 0 0 auto; display: grid; place-items: center; }
  .setup-card .check-text { font-size: 16px; font-weight: 600; color: var(--ink); line-height: 1.2; }

  /* Recovery-enrollment choice cards + seed reveal (Task 3). */
  #enroll-choices button.card:disabled,
  #seed-continue:disabled { opacity: .55; cursor: not-allowed; }
  #enroll-choices button.card:not(:disabled):active { transform: scale(.985); }
  /* The optional method choices are flex only while revealed — an inline
     display would beat the `.hidden` toggle (see the spinner-visibility bug). */
  #enroll-options:not(.hidden) { display: flex; flex-direction: column; gap: 12px; }
</style>

<script>
  import { Networks, TransactionBuilder, Operation, Address, Account, Keypair, nativeToScVal, rpc, xdr, hash, Contract } from "@stellar/stellar-sdk";
  import { Buffer } from "buffer";
  import {
    parseRegistration,
    buf2hex,
    buf2base64url,
    hex2buf,
    contractIdFromHostname,
    saveCredential as sdkSaveCredential,
    savePendingAccount,
    loadPendingAccounts,
    activateAccount,
    accountUrl,
    stripSubdomain,
    deriveSecretM1,
    commitmentForCreation,
    dummyCommitment,
    type Fr,
  } from "@nidohq/passkey-sdk";
  // Use the frontend's fetchRegistryAddress (NOT the SDK's) so PUBLIC_ZK_PREVIEW
  // resolves `factory`/`zk-recovery` to the factory-v2 preview pair. The SDK's
  // version has no preview override, which would (in preview mode) send
  // `create_account_v2` to the production v1 factory that lacks it.
  import { fetchRegistryAddress } from "../../lib/policyChainFetch.js";
  import { generateMnemonic } from "@scure/bip39";
  import { wordlist } from "@scure/bip39/wordlists/english.js";
  import { StellarWalletsKit } from "@creit.tech/stellar-wallets-kit";
  import { parseReturnIntent, buildClaimReturnUrl } from "../../lib/claimFlow";
  import { withPasskeySheet } from "../../lib/passkeySheet";
  import { shortAddr } from "../../lib/address";
  import { checkPasskeySupport } from "../../lib/passkeySupport";
  import { NATIVE_SAC_ID, RELAYER_SIM_SOURCE, RELAYER_URL, NETWORK_PASSPHRASE } from "../../lib/network";
  import { extractFuncAndAuth, submitSorobanTransaction, waitForConfirmation } from "../../lib/relayerClient";
  import { syncNidoStorageViaBridge } from "../../lib/nidoSharedStorage";
  import { signAndSubmit } from "../../lib/primaryPasskeySigner";
  import { markBackupSetUp } from "../../lib/recoveryBackupPrompt";
  import { initWalletKit, connect as connectWallet } from "../../lib/walletConnect";
  import { deriveM2SecretSafely } from "../../lib/walletRecoverySign";

  const RPC_URL = "https://soroban-testnet.stellar.org";
  const FRIENDBOT_URL = "https://friendbot.stellar.org";
  const TESTNET_TOPUP_STROOPS = 99_900_000_000n;

  // ZK preview mode (PR-preview builds only, testnet): when set, `deploy()`
  // below calls the preview factory's `create_account_v2(salt, key,
  // commitment)` in a single tx for ALL three enrollment choices (uniform tx
  // shape — on-chain invisibility), instead of the production
  // `create_account` + separate post-create enrollment. `fetchRegistryAddress`
  // (policyChainFetch.ts) resolves `factory`/`zk-recovery` to the hardcoded
  // preview pair while this is set. Production (unset/falsy) is unchanged.
  // See DEPLOYED.md's "Preview (factory-v2)" section.
  const ZK_PREVIEW_ENABLED = Boolean(import.meta.env.PUBLIC_ZK_PREVIEW);

  // --- State ---

  const hostname = window.location.hostname;
  const contractId = contractIdFromHostname(hostname);
  const rpId = hostname;

  const params = new URLSearchParams(window.location.search);
  let saltHex = params.get("salt");
  const isSetupReservation = params.get("setup") === "1";

  if (!saltHex && params.get("key")) {
    saltHex = buf2hex(hash(Buffer.from(params.get("key")!)));
  }

  if (!saltHex && contractId) {
    saltHex =
      paramsFromHash().get("salt") ??
      loadPendingAccounts().find((p) => p.contractId === contractId)?.setupKey ??
      readSetupSaltCookie(contractId);
  }

  let passkeyPublicKey: Uint8Array | null = null;
  let credentialIdBytes: Uint8Array | null = null;
  let testnetFundingPromise: Promise<Keypair> | null = null;
  // Lets a manual tap abort an in-flight auto-attempt of the passkey prompt.
  let autoPasskeyController: AbortController | null = null;

  // --- Recovery-enrollment state ("Never get locked out") ---
  //
  // `enrollSecret` lives ONLY in memory, derived from a mnemonic or a wallet
  // signature that is itself never persisted (see the seed/wallet handlers
  // below) — it is discarded the instant the post-create enrollment calls
  // finish (or fail). `enrollMethod` drives the recovery-card copy only.
  type EnrollMethod = "seed" | "wallet" | "skip";
  let enrollMethod: EnrollMethod | null = null;
  let enrollSecret: Fr | null = null;
  let enrollWalletShortAddr: string | null = null;
  let enrollmentFailed = false;
  // The generated mnemonic, held only between "reveal" and "continue" so it
  // can be wiped from both the variable and the DOM the moment it's used.
  let currentMnemonic: string | null = null;

  // --- UI refs ---

  const $contractIdEl = document.getElementById("contract-id")!;
  const $accountChip = document.getElementById("account-chip")!;
  const $errorBox = document.getElementById("error-box")!;
  const $registerBtn = document.getElementById("register-btn") as HTMLButtonElement;
  const $passkeySection = document.getElementById("passkey-section")!;
  const $passkeyIntro = document.getElementById("passkey-intro")!;
  const $preparingSection = document.getElementById("preparing-section")!;
  const $preparingStatusText = document.getElementById("preparing-status-text")!;
  const $preparingContinue = document.getElementById("preparing-continue") as HTMLButtonElement;
  const $preparingHomeLink = document.getElementById("preparing-home-link")!;
  const $recoveryEnrollSection = document.getElementById("recovery-enroll-section")!;
  const $enrollChoices = document.getElementById("enroll-choices")!;
  const $enrollSeedBtn = document.getElementById("enroll-seed") as HTMLButtonElement;
  const $enrollWalletBtn = document.getElementById("enroll-wallet") as HTMLButtonElement;
  const $enrollContinueBtn = document.getElementById("enroll-continue") as HTMLButtonElement;
  const $enrollRevealBtn = document.getElementById("enroll-reveal-options") as HTMLButtonElement;
  const $enrollOptions = document.getElementById("enroll-options")!;
  const $enrollStatus = document.getElementById("enroll-status")!;
  const $seedReveal = document.getElementById("seed-reveal")!;
  const $seedWords = document.getElementById("seed-words")!;
  const $seedContinueBtn = document.getElementById("seed-continue") as HTMLButtonElement;
  const $seedBackBtn = document.getElementById("seed-back") as HTMLButtonElement;
  const $seedCopy = document.getElementById("seed-copy") as HTMLButtonElement;
  $seedCopy.addEventListener("click", async () => {
    if (!currentMnemonic) return;
    try {
      await navigator.clipboard.writeText(currentMnemonic);
      $seedCopy.textContent = "Copied ✓";
      setTimeout(() => { $seedCopy.textContent = "Copy to clipboard"; }, 1600);
    } catch {
      $seedCopy.textContent = "Copy failed — select the words manually";
    }
  });
  const $deploySection = document.getElementById("deploy-section")!;
  const $deployNestSpinning = document.getElementById("deploy-nest-spinning")!;
  const $deployNestStatic = document.getElementById("deploy-nest-static")!;
  const $doneSection = document.getElementById("done-section")!;
  const $recoveryCardSection = document.getElementById("recovery-card-section")!;
  const $recoveryCardTitle = document.getElementById("recovery-card-title")!;
  const $recoveryCardBody = document.getElementById("recovery-card-body")!;
  const $step1 = document.getElementById("step-1")!;
  const $step2 = document.getElementById("step-2")!;

  // --- UI helpers ---

  function showError(msg: string) {
    $errorBox.textContent = msg;
    $errorBox.style.display = "block";
  }

  function clearError() {
    $errorBox.style.display = "none";
  }

  // Animated "Setting up your Nido" checklist — full-sized boxed checkbox cards.
  // Each step is one of: "pending" (dim box) · "active" (spinner) · "done" (teal
  // checkmark). The friendbot funding that backs "Finalizing your wallet" runs
  // concurrently behind the scenes and is never surfaced as a testnet detail.
  const CHECK_LABELS = ["check-0", "check-1", "check-2", "check-3", "check-4", "check-5"];

  function renderCheck(i: number, state: "pending" | "active" | "done") {
    const item = document.getElementById(CHECK_LABELS[i]);
    if (!item) return;
    const mark = item.querySelector(".check-mark") as HTMLElement;
    item.classList.toggle("is-active", state === "active");
    item.classList.toggle("is-done", state === "done");
    if (state === "done") {
      mark.innerHTML =
        `<span style="width:28px;height:28px;border-radius:8px;background:var(--good);display:grid;place-items:center;">` +
        `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg></span>`;
    } else if (state === "active") {
      mark.innerHTML =
        `<svg class="spin" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--acc)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 13.7-5.6L20 8"/><path d="M20 4v4h-4"/><path d="M20 12a8 8 0 0 1-13.7 5.6L4 16"/><path d="M4 20v-4h4"/></svg>`;
    } else {
      mark.innerHTML = `<span style="width:28px;height:28px;border-radius:8px;border:2px solid var(--line);display:block;"></span>`;
    }
  }

  function setCheckProgress(done: number, activeIdx: number) {
    for (let i = 0; i < CHECK_LABELS.length; i++) {
      if (i < done) renderCheck(i, "done");
      else if (i === activeIdx) renderCheck(i, "active");
      else renderCheck(i, "pending");
    }
  }

  const sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));

  function paramsFromHash(): URLSearchParams {
    return new URLSearchParams(window.location.hash.replace(/^#/, ""));
  }

  function setupCookieName(account: string): string {
    return `nido_setup_${account.toLowerCase()}`;
  }

  function setupCookieDomain(): string {
    const host = window.location.hostname;
    if (host === "localhost" || /^\d{1,3}(\.\d{1,3}){3}$/.test(host)) return "";
    const base = host.split(".").slice(-2).join(".");
    // `*.pages.dev` is on the Public Suffix List, so browsers silently reject a
    // `Domain=.pages.dev` cookie. On a direct Cloudflare Pages preview host
    // (the client-side fallback when the worker proxy isn't in the path) fall
    // back to a host-only cookie so the setup salt is actually written.
    if (!base.includes(".") || base === "pages.dev") return "";
    return `; Domain=.${base}`;
  }

  function saveSetupSaltCookie(account: string, salt: string): void {
    document.cookie = `${setupCookieName(account)}=${salt}; Max-Age=1800; Path=/; SameSite=Lax${setupCookieDomain()}`;
  }

  function readSetupSaltCookie(account: string): string | null {
    const name = `${setupCookieName(account)}=`;
    return document.cookie
      .split(";")
      .map((part) => part.trim())
      .find((part) => part.startsWith(name))
      ?.slice(name.length) ?? null;
  }

  function clearSetupSaltCookie(account: string): void {
    document.cookie = `${setupCookieName(account)}=; Max-Age=0; Path=/; SameSite=Lax${setupCookieDomain()}`;
  }

  async function waitForSourceAccount(server: rpc.Server, publicKey: string): Promise<Account> {
    let lastError: unknown;
    for (let i = 0; i < 20; i++) {
      try {
        const res = await server.getAccount(publicKey);
        return new Account(res.accountId(), res.sequenceNumber());
      } catch (err) {
        lastError = err;
        await sleep(1000);
      }
    }
    throw lastError instanceof Error
      ? new Error(`Funded setup account is not available yet: ${lastError.message}`)
      : new Error("Funded setup account is not available yet.");
  }

  async function startTestnetFunding(): Promise<Keypair> {
    if (testnetFundingPromise) return testnetFundingPromise;
    testnetFundingPromise = (async () => {
      const keypair = Keypair.random();
      const resp = await fetch(`${FRIENDBOT_URL}?addr=${keypair.publicKey()}`);
      if (!resp.ok) {
        const detail = await resp.text().catch(() => resp.statusText);
        throw new Error(`Friendbot funding failed: ${detail || resp.statusText}`);
      }
      await waitForSourceAccount(new rpc.Server(RPC_URL), keypair.publicKey());
      return keypair;
    })().catch((err) => {
      testnetFundingPromise = null;
      throw err;
    });
    return testnetFundingPromise;
  }

  async function drainTestnetFunding(server: rpc.Server, destination: string): Promise<void> {
    const keypair = await startTestnetFunding();
    const sourceAccount = await waitForSourceAccount(server, keypair.publicKey());
    const txn = new TransactionBuilder(sourceAccount, {
      fee: "1000000",
      networkPassphrase: Networks.TESTNET,
    })
      .addOperation(
        Operation.invokeContractFunction({
          contract: NATIVE_SAC_ID,
          function: "transfer",
          args: [
            Address.fromString(keypair.publicKey()).toScVal(),
            Address.fromString(destination).toScVal(),
            nativeToScVal(TESTNET_TOPUP_STROOPS, { type: "i128" }),
          ],
        })
      )
      .setTimeout(60)
      .build();

    const SIM_ATTEMPTS = 6;
    let sim = await server.simulateTransaction(txn);
    for (let simAttempt = 1; simAttempt < SIM_ATTEMPTS; simAttempt++) {
      if (!rpc.Api.isSimulationError(sim) && !rpc.Api.isSimulationRestore(sim)) break;
      await sleep(1500);
      sim = await server.simulateTransaction(txn);
    }
    if (rpc.Api.isSimulationError(sim) || rpc.Api.isSimulationRestore(sim)) {
      throw new Error(`Funding simulation failed: ${"error" in sim ? sim.error : "restore needed"}`);
    }

    const assembled = rpc.assembleTransaction(txn, sim).build();
    assembled.sign(keypair);

    const send = await server.sendTransaction(assembled);
    if (send.status === "ERROR") {
      throw new Error(`Funding transaction failed: ${send.errorResult?.toString() ?? "submission error"}`);
    }

    let got = await server.getTransaction(send.hash);
    let attempts = 0;
    while (got.status === "NOT_FOUND" && attempts < 20) {
      await sleep(1000);
      got = await server.getTransaction(send.hash);
      attempts++;
    }
    if (got.status !== "SUCCESS") {
      throw new Error(`Funding transaction did not complete: ${got.status}`);
    }
  }

  // --- Init: surface the contract id ---

  // Show a shortened address so the 56-char contract ID never overflows the
  // quiet pill chip (full ID stays in the URL / localStorage). The chip carries
  // a title with the full value for hover/inspection.
  $contractIdEl.textContent = isSetupReservation ? "Preparing..." : contractId ? shortAddr(contractId, 6, 6) : "(unknown)";
  if (contractId) $accountChip.title = contractId;
  // First step is in progress.
  $step1.classList.add("on");
  setCheckProgress(0, -1);

  if (!contractId && !isSetupReservation) {
    showError("That link looks off. Please start again from the home page.");
  }

  if (!saltHex) {
    showError("We're missing some setup data. Please start again from the home page.");
  }

  if (isSetupReservation && saltHex) {
    // Show the dedicated explainer while we reserve the address on this host,
    // then hard-navigate to the account's own subdomain. The passkey step
    // (page 2) is where the user actually creates their passkey.
    $passkeySection.classList.add("hidden");
    $accountChip.classList.add("hidden");
    $preparingSection.classList.remove("hidden");
    void runReservationFlow();
  }

  // Page 2 (account subdomain) arriving from the reservation page: auto-attempt
  // the passkey prompt (see attemptAutoPasskey for the user-activation caveat).
  if (params.get("autopass") === "1" && contractId && !isSetupReservation) {
    // One-shot: drop the flag so a refresh doesn't re-trigger the attempt.
    params.delete("autopass");
    const query = params.toString();
    history.replaceState(null, "", `${window.location.pathname}${query ? `?${query}` : ""}${window.location.hash}`);
    void attemptAutoPasskey();
  }

  async function runReservationFlow() {
    clearError();
    const $continueSpan = $preparingContinue.querySelector("span")!;
    try {
      // Reserve the address in the background while the user reads the explainer.
      const cAddress = await reserveNidoAddress();
      // Reserved — hand the redirect to the user (it's theirs to trigger), and
      // tell the destination to auto-attempt the passkey prompt on arrival.
      $preparingStatusText.textContent = "Your Nido is ready.";
      $continueSpan.textContent = "Continue";
      $preparingContinue.disabled = false;
      $preparingContinue.addEventListener(
        "click",
        () => {
          $preparingContinue.disabled = true;
          $continueSpan.textContent = "Taking you there…";
          // Preserve a claim return intent across the apex → <cAddress> subdomain
          // hop so it survives to the final success redirect (which reads `then`
          // from the query string). Absent when this isn't a claim flow → no change.
          const thenParam = params.get("then");
          const thenQuery = thenParam ? `&then=${encodeURIComponent(thenParam)}` : "";
          window.location.replace(
            accountUrl(
              window.location.host,
              cAddress,
              `/new-account/?salt=${encodeURIComponent(saltHex!)}&autopass=1${thenQuery}#salt=${encodeURIComponent(saltHex!)}`,
            ),
          );
        },
        { once: true },
      );
    } catch (err: any) {
      // Dead end — reservation failed, so stop the spinner, hide the button,
      // and offer a way back.
      $preparingSection.classList.add("is-error");
      $preparingStatusText.textContent = "Setup paused";
      $preparingContinue.classList.add("hidden");
      $preparingHomeLink.classList.remove("hidden");
      showError(`Couldn't prepare your Nido: ${err.message}`);
    }
  }

  function saltBytes(): Uint8Array {
    if (!saltHex || !/^[0-9a-fA-F]{64}$/.test(saltHex)) {
      throw new Error("Setup salt is missing or invalid. Please start again from the home page.");
    }
    return hex2buf(saltHex);
  }

  async function reserveNidoAddress(): Promise<string> {
    if (!RELAYER_URL || !RELAYER_SIM_SOURCE) {
      throw new Error("Relayer is not configured for account setup.");
    }
    const server = new rpc.Server(RPC_URL);
    const sourceAccount = await waitForSourceAccount(server, RELAYER_SIM_SOURCE);

    const simTxn = new TransactionBuilder(sourceAccount, {
      fee: "100",
      networkPassphrase: Networks.TESTNET,
    })
      .addOperation(
        Operation.invokeContractFunction({
          contract: await fetchRegistryAddress("factory"),
          function: "get_c_address",
          args: [xdr.ScVal.scvBytes(Buffer.from(saltBytes()))],
        }),
      )
      .setTimeout(0)
      .build();

    const sim = await server.simulateTransaction(simTxn);
    if (rpc.Api.isSimulationError(sim) || rpc.Api.isSimulationRestore(sim)) {
      throw new Error(`Simulation failed: ${"error" in sim ? sim.error : "restore needed"}`);
    }
    if (!sim.result) throw new Error("Address reservation returned no result.");

    const cAddress = Address.fromScVal(sim.result.retval).toString();
    savePendingAccount(cAddress, saltHex!);
    saveSetupSaltCookie(cAddress, saltHex!);
    await syncNidoStorageViaBridge();
    return cAddress;
  }

  // --- Step 1 · Lock it to you (register passkey) ---

  function buildPasskeyCreateOptions(): CredentialCreationOptions {
    const userId = new Uint8Array(16);
    crypto.getRandomValues(userId);
    return {
      publicKey: {
        challenge: crypto.getRandomValues(new Uint8Array(32)),
        rp: { name: `Soroban ${contractId}`, id: rpId },
        user: { id: userId, name: contractId!, displayName: `Account ${contractId}` },
        pubKeyCredParams: [{ alg: -7, type: "public-key" }],
        authenticatorSelection: { residentKey: "required", userVerification: "required" },
        attestation: "none",
        timeout: 60000,
      },
    };
  }

  // Persist the freshly-created passkey, then show the recovery-enrollment
  // choice (deploy only starts once that's resolved — see proceedToDeploy).
  async function completeRegistration(credential: PublicKeyCredential) {
    const reg = parseRegistration(credential as any);
    passkeyPublicKey = reg.publicKey;
    credentialIdBytes = reg.credentialId;

    sdkSaveCredential(contractId!, credentialIdBytes, passkeyPublicKey);
    void startTestnetFunding().catch((err) => console.warn("[nido] testnet funding prep failed", err));

    void buf2base64url(credentialIdBytes);
    void buf2hex(passkeyPublicKey);

    $passkeySection.classList.add("hidden");
    $accountChip.classList.add("hidden");
    $recoveryEnrollSection.classList.remove("hidden");
  }

  // --- "Never get locked out" · recovery enrollment ---
  //
  // Three choices, all resolving `enrollMethod` + (for seed/wallet)
  // `enrollSecret` before handing off to the unchanged deploy step. The
  // account-creation tx itself (`create_account`) never branches on the
  // choice — see deploy()'s comment on why enrollment is a separate,
  // post-create step on this (testnet, factory v1) network.

  function showEnrollStatus(msg: string) {
    $enrollStatus.textContent = msg;
    $enrollStatus.style.display = "block";
  }

  function clearEnrollStatus() {
    $enrollStatus.textContent = "";
    $enrollStatus.style.display = "none";
  }

  function setEnrollButtonsDisabled(disabled: boolean) {
    $enrollSeedBtn.disabled = disabled;
    $enrollWalletBtn.disabled = disabled;
    $enrollContinueBtn.disabled = disabled;
  }

  // Advance out of the enrollment section into "Setting up your Nido" — the
  // one path every choice (seed / wallet / skip) funnels through, identically.
  function proceedToDeploy() {
    $recoveryEnrollSection.classList.add("hidden");
    $step1.classList.remove("on");
    $step1.classList.add("done");
    $step2.classList.add("on");
    $deploySection.classList.remove("hidden");
    void deploy();
  }

  function renderSeedWords(mnemonic: string): void {
    $seedWords.textContent = "";
    mnemonic.split(" ").forEach((word, i) => {
      const el = document.createElement("div");
      el.textContent = `${i + 1}. ${word}`;
      $seedWords.appendChild(el);
    });
  }

  $enrollSeedBtn.addEventListener("click", () => {
    clearError();
    currentMnemonic = generateMnemonic(wordlist);
    renderSeedWords(currentMnemonic);
    $enrollChoices.classList.add("hidden");
    $seedReveal.classList.remove("hidden");
  });

  $seedBackBtn.addEventListener("click", () => {
    // Abandon this reveal entirely rather than leave a shown mnemonic sitting
    // around unused.
    currentMnemonic = null;
    $seedWords.textContent = "";
    $seedReveal.classList.add("hidden");
    $enrollChoices.classList.remove("hidden");
  });

  $seedContinueBtn.addEventListener("click", async () => {
    if (!currentMnemonic || !contractId) return;
    clearError();
    $seedContinueBtn.disabled = true;
    let secret: Fr;
    try {
      secret = await deriveSecretM1(currentMnemonic, "", contractId, NETWORK_PASSPHRASE);
    } catch (err: any) {
      // Only clear the mnemonic/seed-words display on the SUCCESS path below
      // — clearing it here (previously in a `finally`) stranded the user on
      // a blank seed-reveal screen with no way to retry without regenerating
      // a brand-new phrase (T4 review finding).
      showError(`Couldn't prepare your seed-phrase backup: ${err.message}`);
      $seedContinueBtn.disabled = false;
      return;
    }
    // The mnemonic's only job was to derive the secret above — it never
    // leaves this device and is not needed again until a real recovery.
    currentMnemonic = null;
    $seedWords.textContent = "";
    enrollMethod = "seed";
    enrollSecret = secret;
    $seedReveal.classList.add("hidden");
    proceedToDeploy();
  });

  $enrollWalletBtn.addEventListener("click", async () => {
    clearError();
    if (!contractId) return;
    setEnrollButtonsDisabled(true);
    try {
      showEnrollStatus("Connecting your wallet…");
      await initWalletKit({ networkPassphrase: NETWORK_PASSPHRASE });
      const session = await connectWallet();
      // Double-signs, independently SEP-53-verifies, and re-derives from both
      // signatures before trusting this wallet for M2 — a wallet whose
      // signMessage isn't repeatable would otherwise silently make this
      // account's recovery secret unreproducible (see walletRecoverySign.ts).
      enrollSecret = await deriveM2SecretSafely({
        kit: StellarWalletsKit,
        account: contractId,
        walletAddress: session.walletAddress,
        networkPassphrase: NETWORK_PASSPHRASE,
        onStatus: showEnrollStatus,
      });
      enrollMethod = "wallet";
      enrollWalletShortAddr = shortAddr(session.walletAddress, 4, 4);
      clearEnrollStatus();
      proceedToDeploy();
    } catch (err: any) {
      setEnrollButtonsDisabled(false);
      clearEnrollStatus();
      showError(`Couldn't connect a wallet: ${err instanceof Error ? err.message : String(err)}`);
    }
  });

  // Primary path: continue without setting up a backup now (a silent dummy
  // commitment is still inserted at creation, so the account is
  // indistinguishable from an enrolled one). The home page prompts to set up
  // recovery later.
  $enrollContinueBtn.addEventListener("click", () => {
    clearError();
    enrollMethod = "skip";
    enrollSecret = null;
    proceedToDeploy();
  });

  // Optional: reveal the method choices for users who want to enroll now (at
  // creation, so it stays invisible on-chain).
  $enrollRevealBtn.addEventListener("click", () => {
    $enrollOptions.classList.remove("hidden");
    $enrollRevealBtn.classList.add("hidden");
  });

  // Post-create enrollment (seed/wallet only): two account-authed calls
  // against already-deployed contracts, each its own WebAuthn ceremony via
  // `signAndSubmit` (same passkey the account was just locked to). Order
  // between the two doesn't matter for correctness (see
  // `contract.rs::enroll_zk_recovery`'s doc comment).
  //
  // The `insert_for` call is built directly here (mirroring
  // `zkRecoveryActions.ts::buildMigrationEnrollTx`) rather than importing that
  // module: it re-exports `initiateZkRecovery`, which pulls in the zk prover's
  // Web Worker (`lib/zk/prover.ts`) — fine for the recovery-ceremony page
  // (Task 4), but an unnecessary (and, as configured, build-breaking —
  // rollup's worker output rejects code-split "iife" format) dependency for
  // this page, which only ever needs the commitment, never a proof.
  async function enrollRecoveryPostCreate(account: string, secret: Fr): Promise<void> {
    const controllerId = await fetchRegistryAddress("zk-recovery");

    const enrollOp = new Contract(account).call(
      "enroll_zk_recovery",
      Address.fromString(controllerId).toScVal(),
    );
    await signAndSubmit({ account, operation: enrollOp });

    const commitment = commitmentForCreation(secret);
    const insertOp = new Contract(controllerId).call(
      "insert_for",
      Address.fromString(account).toScVal(),
      xdr.ScVal.scvBytes(Buffer.from(commitment)),
    );
    await signAndSubmit({ account, operation: insertOp });
  }

  function renderRecoveryCard(): void {
    if (enrollmentFailed) {
      $recoveryCardTitle.textContent = "Backup didn't finish";
      $recoveryCardBody.textContent =
        "Your Nido is live, but we couldn't finish setting up your backup method. You can add one anytime from Security settings.";
    } else if (enrollMethod === "seed") {
      $recoveryCardTitle.textContent = "Backed up with a seed phrase";
      $recoveryCardBody.textContent =
        "Your 12-word phrase is your backup — keep it somewhere safe and private, separate from this account's address.";
    } else if (enrollMethod === "wallet") {
      $recoveryCardTitle.textContent = "Backed up with a wallet";
      $recoveryCardBody.textContent = enrollWalletShortAddr
        ? `You can get back in later using the wallet you connected (${enrollWalletShortAddr}). Keep access to that wallet safe.`
        : "You can get back in later using the wallet you connected. Keep access to that wallet safe.";
    } else {
      $recoveryCardTitle.textContent = "No backup yet";
      $recoveryCardBody.textContent =
        "You haven't added a backup yet. Set one up anytime from your wallet or Security settings — we'll remind you — so you're never locked out.";
    }
  }

  $registerBtn.addEventListener("click", async () => {
    clearError();
    // A manual tap takes over from any in-flight auto-attempt (see autopass).
    autoPasskeyController?.abort();
    if (!contractId) {
      showError("No account found in this link. Please start again from the home page.");
      return;
    }

    const support = checkPasskeySupport();
    if (!support.ok) {
      showError(support.message!);
      return;
    }

    try {
      $registerBtn.disabled = true;
      // Drive the REAL ceremony through the sheet — no fake timer. The OS
      // passkey dialog is the source of truth; the sheet closes when it settles.
      const credential = (await withPasskeySheet(
        () => navigator.credentials.create(buildPasskeyCreateOptions()),
        { title: "Lock it to you", sub: "Confirm with your passkey to finish setting up." },
      )) as PublicKeyCredential;
      await completeRegistration(credential);
    } catch (err: any) {
      if (err.name === "NotAllowedError") {
        showError("We couldn't reach your passkey. If you're in an in-app browser (Twitter, Instagram, etc.), tap the menu (…) and choose \"Open in Safari\" or \"Open in Browser\".");
      } else {
        showError(`Couldn't set up your passkey: ${err.message}`);
      }
      $registerBtn.disabled = false;
    }
  });

  // Arriving straight from the reservation page (`autopass=1`): try the passkey
  // prompt automatically. WebAuthn needs a transient user gesture that does NOT
  // survive the cross-subdomain redirect, so where it's enforced (notably iOS
  // Safari) this rejects at once — we swallow that silently and leave the ready
  // button for a manual tap. No sheet here, so the fallback doesn't flicker; the
  // OS dialog is the prompt on browsers that allow it.
  async function attemptAutoPasskey() {
    if (!contractId || !checkPasskeySupport().ok) return;
    // Run in the background: do NOT disable the button. The user can tap to take
    // over at any time (the click handler aborts this attempt first), so a hung
    // or pending attempt can never strand the button in a disabled state.
    autoPasskeyController = new AbortController();
    const options = buildPasskeyCreateOptions();
    options.signal = autoPasskeyController.signal;
    try {
      const credential = (await navigator.credentials.create(options)) as PublicKeyCredential;
      await completeRegistration(credential);
    } catch {
      // Rejected (no user activation on iOS Safari), declined, or aborted by a
      // manual tap — the ready button is already there for the user. Silent.
    }
  }

  // --- Step 2 · Setting up your Nido (deploy account) ---

  async function deploy() {
    clearError();
    if (!passkeyPublicKey || !saltHex) {
      showError("Register a passkey first and ensure setup data is present.");
      return;
    }

    try {
      // 0 · "Locked to you" is already done; 1 · "Preparing transaction" begins.
      // Friendbot funding (a testnet-only detail) is already running from
      // completeRegistration, concurrent with this whole deploy — it backs the
      // "Finalizing your wallet" step below and is never surfaced to the user.
      setCheckProgress(1, 1);

      if (!RELAYER_URL || !RELAYER_SIM_SOURCE) {
        throw new Error("Relayer is not configured for account setup.");
      }
      const simulationSource = RELAYER_SIM_SOURCE;
      const server = new rpc.Server(RPC_URL);

      const sourceAccount = await waitForSourceAccount(server, simulationSource);

      // ZK preview mode: fold enrollment into the creation tx itself via
      // `create_account_v2(salt, key, commitment)` — the SAME call shape for
      // all three choices (seed/wallet use the real enrollment commitment,
      // skip uses the deterministic dummy), so the three flows are
      // indistinguishable on-chain (genesis-insert; see DEPLOYED.md). This
      // replaces the separate post-create `enroll_zk_recovery`+`insert_for`
      // step below, which only runs when preview mode is off.
      const previewCommitment: Uint8Array | null = ZK_PREVIEW_ENABLED
        ? enrollMethod && enrollMethod !== "skip" && enrollSecret !== null
          ? commitmentForCreation(enrollSecret)
          : dummyCommitment(saltBytes())
        : null;

      const simTxn = new TransactionBuilder(sourceAccount, {
        fee: "100",
        networkPassphrase: Networks.TESTNET,
      })
        .addOperation(
          Operation.invokeContractFunction({
            contract: await fetchRegistryAddress("factory"),
            function: ZK_PREVIEW_ENABLED ? "create_account_v2" : "create_account",
            args: ZK_PREVIEW_ENABLED
              ? [
                  xdr.ScVal.scvBytes(Buffer.from(saltBytes())),
                  xdr.ScVal.scvBytes(Buffer.from(passkeyPublicKey)),
                  xdr.ScVal.scvBytes(Buffer.from(previewCommitment!)),
                ]
              : [
                  xdr.ScVal.scvBytes(Buffer.from(saltBytes())),
                  xdr.ScVal.scvBytes(Buffer.from(passkeyPublicKey)),
                ],
          })
        )
        .setTimeout(0)
        .build();

      const sim = await server.simulateTransaction(simTxn);
      if (rpc.Api.isSimulationError(sim) || rpc.Api.isSimulationRestore(sim)) {
        throw new Error(`Simulation failed: ${"error" in sim ? sim.error : "restore needed"}`);
      }

      const transaction = rpc.assembleTransaction(simTxn, sim).setTimeout(0).build();
      const { func, auth } = extractFuncAndAuth(transaction);

      // Prepared — 1 done, 2 · "Submitting to the network" begins.
      setCheckProgress(2, 2);
      const submitted = await submitSorobanTransaction({ func, auth });
      if (!submitted.transactionId) {
        throw new Error("Relayer accepted account setup but returned no transaction id");
      }

      // Submitted — 2 done, 3 · "Confirming on-chain" begins (the long wait).
      setCheckProgress(3, 3);
      const confirmed = await waitForConfirmation(submitted.transactionId);
      if (!confirmed.hash) throw new Error("Relayer confirmed account setup without a transaction hash");

      activateAccount(contractId!);
      clearSetupSaltCookie(contractId!);
      await syncNidoStorageViaBridge();

      // Confirmed — 3 done, 4 · "Finalizing your wallet" begins. Behind this card
      // we drain the friendbot-funded keypair into the account; it must follow
      // deploy since the account contract is the transfer destination. The funding
      // itself already ran in parallel with steps 1–3, so this is usually a quick
      // transfer rather than a fresh wait.
      setCheckProgress(4, 4);
      try {
        await drainTestnetFunding(server, contractId!);
      } catch (fundingErr) {
        console.warn("[nido] wallet finalize failed", fundingErr);
        renderCheck(4, "pending");
        renderCheck(5, "pending");
        $deployNestSpinning.style.display = "none";
        $deployNestStatic.style.display = "block";
        showError(
          fundingErr instanceof Error
            ? `Couldn't finish setting up your wallet: ${fundingErr.message}`
            : "Couldn't finish setting up your wallet."
        );
        return;
      }

      // Recovery enrollment (seed/wallet choices only) — deliberately a
      // separate, account-authed step here, AFTER the account exists. The
      // production testnet factory is v1 (no `create_account_v2`), so the
      // `create_account` call above stays byte-identical for all three
      // choices; only seed/wallet then run two more account-authed calls
      // (`enroll_zk_recovery` + the pool's `insert_for`), each its own
      // WebAuthn ceremony. A failure here does NOT unwind the (already
      // successful) account creation — it's surfaced softly on the recovery
      // card instead. Skip performs no enrollment call at all.
      //
      // ZK preview mode skips this entirely: `create_account_v2` above already
      // enrolled the account atomically via genesis-insert (real commitment for
      // seed/wallet, dummy for skip), so a post-create enroll call here would
      // be redundant (and `enroll_zk_recovery` would panic
      // `RecoveryAlreadyEnrolled` since the constructor already installed the
      // recovery rule).
      if (!ZK_PREVIEW_ENABLED && enrollMethod && enrollMethod !== "skip" && enrollSecret !== null) {
        try {
          await enrollRecoveryPostCreate(contractId!, enrollSecret);
        } catch (enrollErr) {
          enrollmentFailed = true;
          console.warn("[nido] recovery enrollment failed; account creation still succeeded", enrollErr);
        }
      }
      // The secret's only remaining purpose was the enrollment call above.
      enrollSecret = null;

      // Record a local "backed up" flag so the home-page recovery banner stays
      // hidden for an account that enrolled at creation. Advisory only (see
      // recoveryBackupPrompt.ts); skip enrollment leaves it unset so the banner
      // prompts later.
      if (enrollMethod && enrollMethod !== "skip" && !enrollmentFailed) {
        markBackupSetUp(contractId!);
      }

      // Finalized — every card lands its checkmark, including "Your Nido is ready".
      setCheckProgress(6, -1);
      $deployNestSpinning.style.display = "none";
      $deployNestStatic.style.display = "block";

      // Wire up the done screen.
      const protocol = window.location.protocol;
      const host = window.location.host;
      const accountUrl = `${protocol}//${host}/account/`;

      // Brief beat so the final check lands before the reveal.
      await new Promise((r) => setTimeout(r, 700));
      $deploySection.classList.add("hidden");
      $doneSection.classList.remove("hidden");
      $step2.classList.remove("on");
      $step2.classList.add("done");

      // After the "ready" beat, swap to the recovery-card screen (which
      // backup method — if any — was enrolled) before the auto hand-off.
      // Deliberately separate from #done-section: the C-address lives there,
      // the backup-method summary lives here, never together.
      setTimeout(() => {
        $doneSection.classList.add("hidden");
        renderRecoveryCard();
        $recoveryCardSection.classList.remove("hidden");
      }, 1500);

      // F-02: auto-advance into the wallet after a brief "ready" beat — arriving
      // in the funded wallet is the payoff, and the deploy copy already promised
      // an automatic hand-off.
      setTimeout(() => {
        const intent = parseReturnIntent(new URLSearchParams(window.location.search).get("then"));
        if (intent) {
          const apexHost = stripSubdomain(window.location.host);
          window.location.href = buildClaimReturnUrl({
            apexHost,
            name: intent.name,
            contractId: contractId!,
            protocol: window.location.protocol,
          });
        } else {
          window.location.href = accountUrl;
        }
      }, 1500 + 2200);
    } catch (err: any) {
      // Fall back to the passkey step so the user can retry the deploy.
      showError(`Couldn't finish setting up: ${err.message}`);
      $deploySection.classList.add("hidden");
      $passkeySection.classList.remove("hidden");
      $accountChip.classList.remove("hidden");
      $step2.classList.remove("on");
      $registerBtn.disabled = false;
    }
  }
</script>
