---
import NidoLayout from "../../layouts/NidoLayout.astro";
import Logo from "../../components/Logo.astro";
import Nest from "../../components/Nest.astro";
import Icon from "../../components/Icon.astro";
import Toast from "../../components/Toast.astro";
import PasskeySheet from "../../components/PasskeySheet.astro";
---

<NidoLayout title="Nido — Set up your account" shell="focused">
  <div class="col-scroll scroll-hide pad screen-in">
    <!-- header: back-less brand + demo chip + 2-step progress -->
    <div style="padding: 6px 4px 22px;">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
        <Logo size={19} mark markSize={24} />
        <span class="chip" style="font-size:11px;"><span class="dot acc"></span>Testnet</span>
      </div>
      <div class="steps">
        <i id="step-1"></i>
        <i id="step-2"></i>
      </div>
    </div>

    <!-- account id surfaced quietly (preserves the contractId surface) -->
    <div class="addr" id="account-chip" style="margin-bottom:18px;">
      <Icon name="home" size={14} color="var(--mut)" />
      <code id="contract-id"></code>
    </div>

    <div id="error-box" role="alert" class="alert danger" style="display:none; margin-bottom:18px;"></div>

    <!-- ===================== STEP 1 · LOCK IT TO YOU ===================== -->
    <section id="passkey-section">
      <div style="display:grid; place-items:center; margin:10px 0 22px;">
        <span id="passkey-nest"><Nest size={104} /></span>
      </div>
      <h1 class="disp" style="font-weight:800; font-size:28px; line-height:1.06; text-align:center;">
        Lock it to you
      </h1>
      <p id="passkey-intro" class="mut" style="font-size:14.5px; line-height:1.55; margin-top:10px; text-align:center; max-width:330px; margin-inline:auto;">
        Use your passkey so only you can get into your Nido.
        Nothing to memorize, nothing to write down.
      </p>

      <div id="lock-info-list" style="display:flex; flex-direction:column; gap:14px; margin-top:26px;">
        <div class="lock-info-row" style="display:flex; gap:13px; align-items:flex-start;">
          <div style="width:38px; height:38px; border-radius:11px; background:var(--chip); display:grid; place-items:center; flex:0 0 auto;">
            <Icon name="lock" size={19} color="var(--ink-soft)" />
          </div>
          <div>
            <div style="font-weight:700; font-size:14.5px;">Only you get in</div>
            <div class="mut" style="font-size:13px; line-height:1.45;">Your face never leaves this device, and can't be faked.</div>
          </div>
        </div>
        <div class="lock-info-row" style="display:flex; gap:13px; align-items:flex-start;">
          <div style="width:38px; height:38px; border-radius:11px; background:var(--chip); display:grid; place-items:center; flex:0 0 auto;">
            <Icon name="refresh" size={19} color="var(--ink-soft)" />
          </div>
          <div>
            <div style="font-weight:700; font-size:14.5px;">Across your devices</div>
            <div class="mut" style="font-size:13px; line-height:1.45;">Set up once and it follows you to your phone and laptop.</div>
          </div>
        </div>
        <div class="lock-info-row" style="display:flex; gap:13px; align-items:flex-start;">
          <div style="width:38px; height:38px; border-radius:11px; background:var(--chip); display:grid; place-items:center; flex:0 0 auto;">
            <Icon name="shieldcheck" size={19} color="var(--ink-soft)" />
          </div>
          <div>
            <div style="font-weight:700; font-size:14.5px;">Never locked out</div>
            <div class="mut" style="font-size:13px; line-height:1.45;">Add a trusted friend later so you can always get back in.</div>
          </div>
        </div>
      </div>

      <button id="register-btn" class="btn acc" style="margin-top:28px;">
        <Icon name="key" size={20} color="#fff" />
        <span>Create with a passkey</span>
      </button>
    </section>

    <!-- ===================== STEP 2 · SETTING UP ===================== -->
    <section id="deploy-section" class="hidden" style="min-height:440px;">
      <div style="flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center;">
        <div style="display:grid; place-items:center; height:116px;">
          <span id="deploy-nest-spinning"><Nest size={104} spin dur={1.1} /></span>
          <span id="deploy-nest-static" style="display:none;"><Nest size={104} /></span>
        </div>
        <h1 class="disp" style="font-weight:800; font-size:26px; margin-top:28px;">Setting up your Nido</h1>

        <div style="display:flex; flex-direction:column; gap:13px; margin-top:24px; width:100%; max-width:320px;">
          <div class="checkitem" id="check-0" style="display:flex; align-items:flex-start; gap:12px; opacity:.4; transition:opacity .3s;">
            <span class="check-mark" style="width:24px; height:24px; flex:0 0 auto; display:grid; place-items:center; margin-top:1px;"></span>
            <span style="display:flex; flex-direction:column; gap:2px; min-width:0;">
              <span class="check-text" style="font-size:18px; font-weight:600; white-space:nowrap;">Locked to you</span>
              <span class="check-sub" id="sub-0" style="display:none; font-size:14px; line-height:1.35; color:var(--mut); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></span>
            </span>
          </div>
          <div class="checkitem" id="check-1" style="display:flex; align-items:flex-start; gap:12px; opacity:.4; transition:opacity .3s;">
            <span class="check-mark" style="width:24px; height:24px; flex:0 0 auto; display:grid; place-items:center; margin-top:1px;"></span>
            <span style="display:flex; flex-direction:column; gap:2px; min-width:0;">
              <span class="check-text" style="font-size:18px; font-weight:600; white-space:nowrap;">Publishing to Stellar</span>
              <span class="check-sub" id="sub-1" style="display:none; font-size:14px; line-height:1.35; color:var(--mut); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></span>
            </span>
          </div>
          <div class="checkitem" id="check-2" style="display:flex; align-items:flex-start; gap:12px; opacity:.4; transition:opacity .3s;">
            <span class="check-mark" style="width:24px; height:24px; flex:0 0 auto; display:grid; place-items:center; margin-top:1px;"></span>
            <span style="display:flex; flex-direction:column; gap:2px; min-width:0;">
              <span class="check-text" style="font-size:18px; font-weight:600; white-space:nowrap;">Adding testnet funds</span>
              <span class="check-sub" id="sub-2" style="display:none; font-size:14px; line-height:1.35; color:var(--mut); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></span>
            </span>
          </div>
          <div class="checkitem" id="check-3" style="display:flex; align-items:flex-start; gap:12px; opacity:.4; transition:opacity .3s;">
            <span class="check-mark" style="width:24px; height:24px; flex:0 0 auto; display:grid; place-items:center; margin-top:1px;"></span>
            <span style="display:flex; flex-direction:column; gap:2px; min-width:0;">
              <span class="check-text" style="font-size:18px; font-weight:600; white-space:nowrap;">Your Nido is ready</span>
              <span class="check-sub" id="sub-3" style="display:none; font-size:14px; line-height:1.35; color:var(--mut); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></span>
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== DONE ===================== -->
    <section id="done-section" class="hidden">
      <div style="display:grid; place-items:center; margin:10px 0 22px;">
        <div style="width:72px; height:72px; border-radius:50%; background:var(--good-soft); display:grid; place-items:center; animation:pop .4s both;">
          <Icon name="check" size={36} color="var(--good)" stroke={2.6} />
        </div>
      </div>
      <h1 class="disp" style="font-weight:800; font-size:28px; line-height:1.06; text-align:center;">Your Nido is ready</h1>
      <p class="mut" style="font-size:14.5px; line-height:1.55; margin-top:10px; text-align:center; max-width:330px; margin-inline:auto;">
        It's live on Stellar and locked to you. Taking you to your wallet…
      </p>
      <!-- F-02: no manual "Go to your Nido" button — the flow auto-advances into /account/. -->
      <div style="display:flex; gap:9px; align-items:center; justify-content:center; color:var(--mut); margin-top:24px;">
        <Nest size={22} spin dur={1.1} />
        <span style="font-size:13.5px; font-weight:600;">Opening your Nido…</span>
      </div>
      <a id="explorer-link" class="link" target="_blank" rel="noopener" style="display:block; text-align:center; margin-top:18px; font-size:13.5px;">
        View on Stellar Expert
      </a>
    </section>

    <!-- ===================== RESERVING · explainer (page 1) ===================== -->
    <section id="preparing-section" class="hidden" style="min-height:440px;">
      <div style="display:grid; place-items:center; margin:32px 0 26px;">
        <Nest size={104} spin dur={1.1} />
      </div>
      <h1 class="disp" style="font-weight:800; font-size:28px; line-height:1.06; text-align:center;">
        Setting up your Nido
      </h1>
      <p class="mut" style="font-size:14.5px; line-height:1.55; margin-top:12px; text-align:center; max-width:330px; margin-inline:auto;">
        We're reserving your private address and moving you into your own secure space. This only takes a moment.
      </p>
      <div class="mut" style="display:flex; align-items:center; justify-content:center; gap:8px; font-size:13px; margin-top:26px; opacity:.85;">
        <span class="dot acc"></span><span id="preparing-status-text">Reserving your address…</span>
      </div>
      <button id="preparing-continue" class="btn acc" style="margin-top:22px;" disabled>
        <span>Preparing…</span>
      </button>
      <a id="preparing-home-link" href="/" class="link hidden" style="align-self:center; margin-top:18px; font-size:13.5px;">Start again from home</a>
    </section>
  </div>

  <!-- mounted once: real-promise-driven passkey sheet + toast host -->
  <PasskeySheet title="Lock it to you" sub="Confirm with your passkey to finish setting up." />
  <Toast />
</NidoLayout>

<style is:global>
  /* Visibility is owned by the `.hidden` toggle. The deploy step needs a flex
     column layout, but an inline `display:flex` would beat `.hidden` (which is
     not !important) and leave it rendered on top of the passkey step — the
     "two cards" bug. Apply the flex layout only while the section is shown. */
  #deploy-section:not(.hidden) { display: flex; flex-direction: column; }
  #preparing-section:not(.hidden) { display: flex; flex-direction: column; }
  /* On a reservation failure the flow stops here, so halt the spinner. */
  #preparing-section.is-error .nest-ring { animation-play-state: paused; }
</style>

<script>
  import { Networks, TransactionBuilder, Operation, Address, Account, Keypair, nativeToScVal, rpc, xdr, hash } from "@stellar/stellar-sdk";
  import { Buffer } from "buffer";
  import {
    parseRegistration,
    buf2hex,
    buf2base64url,
    hex2buf,
    contractIdFromHostname,
    saveCredential as sdkSaveCredential,
    savePendingAccount,
    loadPendingAccounts,
    activateAccount,
    fetchRegistryAddress,
    accountUrl,
    stripSubdomain,
  } from "@nidohq/passkey-sdk";
  import { parseReturnIntent, buildClaimReturnUrl } from "../../lib/claimFlow";
  import { withPasskeySheet } from "../../lib/passkeySheet";
  import { shortAddr } from "../../lib/address";
  import { checkPasskeySupport } from "../../lib/passkeySupport";
  import { NATIVE_SAC_ID, RELAYER_SIM_SOURCE, RELAYER_URL } from "../../lib/network";
  import { extractFuncAndAuth, submitSorobanTransaction, waitForConfirmation, type RelayerStatus } from "../../lib/relayerClient";
  import { syncNidoStorageViaBridge } from "../../lib/nidoSharedStorage";

  const RPC_URL = "https://soroban-testnet.stellar.org";
  const FRIENDBOT_URL = "https://friendbot.stellar.org";
  const TESTNET_TOPUP_STROOPS = 99_900_000_000n;

  // --- State ---

  const hostname = window.location.hostname;
  const contractId = contractIdFromHostname(hostname);
  const rpId = hostname;

  const params = new URLSearchParams(window.location.search);
  let saltHex = params.get("salt");
  const isSetupReservation = params.get("setup") === "1";

  if (!saltHex && params.get("key")) {
    saltHex = buf2hex(hash(Buffer.from(params.get("key")!)));
  }

  if (!saltHex && contractId) {
    saltHex =
      paramsFromHash().get("salt") ??
      loadPendingAccounts().find((p) => p.contractId === contractId)?.setupKey ??
      readSetupSaltCookie(contractId);
  }

  let passkeyPublicKey: Uint8Array | null = null;
  let credentialIdBytes: Uint8Array | null = null;
  let testnetFundingPromise: Promise<Keypair> | null = null;
  // Lets a manual tap abort an in-flight auto-attempt of the passkey prompt.
  let autoPasskeyController: AbortController | null = null;

  // --- UI refs ---

  const $contractIdEl = document.getElementById("contract-id")!;
  const $accountChip = document.getElementById("account-chip")!;
  const $errorBox = document.getElementById("error-box")!;
  const $registerBtn = document.getElementById("register-btn") as HTMLButtonElement;
  const $passkeySection = document.getElementById("passkey-section")!;
  const $passkeyIntro = document.getElementById("passkey-intro")!;
  const $preparingSection = document.getElementById("preparing-section")!;
  const $preparingStatusText = document.getElementById("preparing-status-text")!;
  const $preparingContinue = document.getElementById("preparing-continue") as HTMLButtonElement;
  const $preparingHomeLink = document.getElementById("preparing-home-link")!;
  const $deploySection = document.getElementById("deploy-section")!;
  const $deployNestSpinning = document.getElementById("deploy-nest-spinning")!;
  const $deployNestStatic = document.getElementById("deploy-nest-static")!;
  const $doneSection = document.getElementById("done-section")!;
  const $explorerLink = document.getElementById("explorer-link") as HTMLAnchorElement;
  const $step1 = document.getElementById("step-1")!;
  const $step2 = document.getElementById("step-2")!;

  // --- UI helpers ---

  function showError(msg: string) {
    $errorBox.textContent = msg;
    $errorBox.style.display = "block";
  }

  function clearError() {
    $errorBox.style.display = "none";
  }

  // Animated "Setting up your Nido" checklist. Each step is one of:
  //   "pending" (dim ring) · "active" (spinner) · "done" (teal check).
  const CHECK_LABELS = ["check-0", "check-1", "check-2", "check-3"];

  // Live sub-step ticker under a main step. Only the active step shows one;
  // it's cleared automatically when the step is marked done or pending.
  function setTicker(i: number, text: string) {
    const sub = document.getElementById(`sub-${i}`);
    if (!sub) return;
    sub.textContent = text;
    sub.style.display = text ? "block" : "none";
  }

  function renderCheck(i: number, state: "pending" | "active" | "done") {
    const item = document.getElementById(CHECK_LABELS[i]);
    if (!item) return;
    const mark = item.querySelector(".check-mark") as HTMLElement;
    item.style.opacity = state === "pending" ? ".4" : "1";
    // A step only carries a ticker while it's the active one.
    if (state !== "active") setTicker(i, "");
    if (state === "done") {
      mark.innerHTML =
        `<span style="width:24px;height:24px;border-radius:50%;background:var(--good);display:grid;place-items:center;">` +
        `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg></span>`;
    } else if (state === "active") {
      mark.innerHTML =
        `<svg class="spin" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--acc)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 13.7-5.6L20 8"/><path d="M20 4v4h-4"/><path d="M20 12a8 8 0 0 1-13.7 5.6L4 16"/><path d="M4 20v-4h4"/></svg>`;
    } else {
      mark.innerHTML = `<span style="width:24px;height:24px;border-radius:50%;border:2px solid var(--line);display:block;"></span>`;
    }
  }

  function setCheckProgress(done: number, activeIdx: number) {
    for (let i = 0; i < CHECK_LABELS.length; i++) {
      if (i < done) renderCheck(i, "done");
      else if (i === activeIdx) renderCheck(i, "active");
      else renderCheck(i, "pending");
    }
  }

  const sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));

  function paramsFromHash(): URLSearchParams {
    return new URLSearchParams(window.location.hash.replace(/^#/, ""));
  }

  function setupCookieName(account: string): string {
    return `nido_setup_${account.toLowerCase()}`;
  }

  function setupCookieDomain(): string {
    const host = window.location.hostname;
    if (host === "localhost" || /^\d{1,3}(\.\d{1,3}){3}$/.test(host)) return "";
    const base = host.split(".").slice(-2).join(".");
    // `*.pages.dev` is on the Public Suffix List, so browsers silently reject a
    // `Domain=.pages.dev` cookie. On a direct Cloudflare Pages preview host
    // (the client-side fallback when the worker proxy isn't in the path) fall
    // back to a host-only cookie so the setup salt is actually written.
    if (!base.includes(".") || base === "pages.dev") return "";
    return `; Domain=.${base}`;
  }

  function saveSetupSaltCookie(account: string, salt: string): void {
    document.cookie = `${setupCookieName(account)}=${salt}; Max-Age=1800; Path=/; SameSite=Lax${setupCookieDomain()}`;
  }

  function readSetupSaltCookie(account: string): string | null {
    const name = `${setupCookieName(account)}=`;
    return document.cookie
      .split(";")
      .map((part) => part.trim())
      .find((part) => part.startsWith(name))
      ?.slice(name.length) ?? null;
  }

  function clearSetupSaltCookie(account: string): void {
    document.cookie = `${setupCookieName(account)}=; Max-Age=0; Path=/; SameSite=Lax${setupCookieDomain()}`;
  }

  async function waitForSourceAccount(server: rpc.Server, publicKey: string): Promise<Account> {
    let lastError: unknown;
    for (let i = 0; i < 20; i++) {
      try {
        const res = await server.getAccount(publicKey);
        return new Account(res.accountId(), res.sequenceNumber());
      } catch (err) {
        lastError = err;
        await sleep(1000);
      }
    }
    throw lastError instanceof Error
      ? new Error(`Funded setup account is not available yet: ${lastError.message}`)
      : new Error("Funded setup account is not available yet.");
  }

  async function startTestnetFunding(): Promise<Keypair> {
    if (testnetFundingPromise) return testnetFundingPromise;
    testnetFundingPromise = (async () => {
      const keypair = Keypair.random();
      const resp = await fetch(`${FRIENDBOT_URL}?addr=${keypair.publicKey()}`);
      if (!resp.ok) {
        const detail = await resp.text().catch(() => resp.statusText);
        throw new Error(`Friendbot funding failed: ${detail || resp.statusText}`);
      }
      await waitForSourceAccount(new rpc.Server(RPC_URL), keypair.publicKey());
      return keypair;
    })().catch((err) => {
      testnetFundingPromise = null;
      throw err;
    });
    return testnetFundingPromise;
  }

  async function drainTestnetFunding(server: rpc.Server, destination: string): Promise<void> {
    const keypair = await startTestnetFunding();
    const sourceAccount = await waitForSourceAccount(server, keypair.publicKey());
    const txn = new TransactionBuilder(sourceAccount, {
      fee: "1000000",
      networkPassphrase: Networks.TESTNET,
    })
      .addOperation(
        Operation.invokeContractFunction({
          contract: NATIVE_SAC_ID,
          function: "transfer",
          args: [
            Address.fromString(keypair.publicKey()).toScVal(),
            Address.fromString(destination).toScVal(),
            nativeToScVal(TESTNET_TOPUP_STROOPS, { type: "i128" }),
          ],
        })
      )
      .setTimeout(60)
      .build();

    const sim = await server.simulateTransaction(txn);
    if (rpc.Api.isSimulationError(sim) || rpc.Api.isSimulationRestore(sim)) {
      throw new Error(`Funding simulation failed: ${"error" in sim ? sim.error : "restore needed"}`);
    }

    const assembled = rpc.assembleTransaction(txn, sim).build();
    assembled.sign(keypair);

    const send = await server.sendTransaction(assembled);
    if (send.status === "ERROR") {
      throw new Error(`Funding transaction failed: ${send.errorResult?.toString() ?? "submission error"}`);
    }

    let got = await server.getTransaction(send.hash);
    let attempts = 0;
    while (got.status === "NOT_FOUND" && attempts < 20) {
      await sleep(1000);
      got = await server.getTransaction(send.hash);
      attempts++;
    }
    if (got.status !== "SUCCESS") {
      throw new Error(`Funding transaction did not complete: ${got.status}`);
    }
  }

  // --- Init: surface the contract id ---

  // Show a shortened address so the 56-char contract ID never overflows the
  // quiet pill chip (full ID stays in the URL / localStorage). The chip carries
  // a title with the full value for hover/inspection.
  $contractIdEl.textContent = isSetupReservation ? "Preparing..." : contractId ? shortAddr(contractId, 6, 6) : "(unknown)";
  if (contractId) $accountChip.title = contractId;
  // First step is in progress.
  $step1.classList.add("on");
  renderCheck(0, "pending");
  renderCheck(1, "pending");
  renderCheck(2, "pending");
  renderCheck(3, "pending");

  if (!contractId && !isSetupReservation) {
    showError("That link looks off. Please start again from the home page.");
  }

  if (!saltHex) {
    showError("We're missing some setup data. Please start again from the home page.");
  }

  if (isSetupReservation && saltHex) {
    // Show the dedicated explainer while we reserve the address on this host,
    // then hard-navigate to the account's own subdomain. The passkey step
    // (page 2) is where the user actually creates their passkey.
    $passkeySection.classList.add("hidden");
    $accountChip.classList.add("hidden");
    $preparingSection.classList.remove("hidden");
    void runReservationFlow();
  }

  // Page 2 (account subdomain) arriving from the reservation page: auto-attempt
  // the passkey prompt (see attemptAutoPasskey for the user-activation caveat).
  if (params.get("autopass") === "1" && contractId && !isSetupReservation) {
    // One-shot: drop the flag so a refresh doesn't re-trigger the attempt.
    params.delete("autopass");
    const query = params.toString();
    history.replaceState(null, "", `${window.location.pathname}${query ? `?${query}` : ""}${window.location.hash}`);
    void attemptAutoPasskey();
  }

  async function runReservationFlow() {
    clearError();
    const $continueSpan = $preparingContinue.querySelector("span")!;
    try {
      // Reserve the address in the background while the user reads the explainer.
      const cAddress = await reserveNidoAddress();
      // Reserved — hand the redirect to the user (it's theirs to trigger), and
      // tell the destination to auto-attempt the passkey prompt on arrival.
      $preparingStatusText.textContent = "Your Nido is ready.";
      $continueSpan.textContent = "Continue";
      $preparingContinue.disabled = false;
      $preparingContinue.addEventListener(
        "click",
        () => {
          $preparingContinue.disabled = true;
          $continueSpan.textContent = "Taking you there…";
          // Preserve a claim return intent across the apex → <cAddress> subdomain
          // hop so it survives to the final success redirect (which reads `then`
          // from the query string). Absent when this isn't a claim flow → no change.
          const thenParam = params.get("then");
          const thenQuery = thenParam ? `&then=${encodeURIComponent(thenParam)}` : "";
          window.location.replace(
            accountUrl(
              window.location.host,
              cAddress,
              `/new-account/?salt=${encodeURIComponent(saltHex!)}&autopass=1${thenQuery}#salt=${encodeURIComponent(saltHex!)}`,
            ),
          );
        },
        { once: true },
      );
    } catch (err: any) {
      // Dead end — reservation failed, so stop the spinner, hide the button,
      // and offer a way back.
      $preparingSection.classList.add("is-error");
      $preparingStatusText.textContent = "Setup paused";
      $preparingContinue.classList.add("hidden");
      $preparingHomeLink.classList.remove("hidden");
      showError(`Couldn't prepare your Nido: ${err.message}`);
    }
  }

  function saltBytes(): Uint8Array {
    if (!saltHex || !/^[0-9a-fA-F]{64}$/.test(saltHex)) {
      throw new Error("Setup salt is missing or invalid. Please start again from the home page.");
    }
    return hex2buf(saltHex);
  }

  async function reserveNidoAddress(): Promise<string> {
    if (!RELAYER_URL || !RELAYER_SIM_SOURCE) {
      throw new Error("Relayer is not configured for account setup.");
    }
    const server = new rpc.Server(RPC_URL);
    const sourceAccount = await waitForSourceAccount(server, RELAYER_SIM_SOURCE);

    const simTxn = new TransactionBuilder(sourceAccount, {
      fee: "100",
      networkPassphrase: Networks.TESTNET,
    })
      .addOperation(
        Operation.invokeContractFunction({
          contract: await fetchRegistryAddress("factory"),
          function: "get_c_address",
          args: [xdr.ScVal.scvBytes(Buffer.from(saltBytes()))],
        }),
      )
      .setTimeout(0)
      .build();

    const sim = await server.simulateTransaction(simTxn);
    if (rpc.Api.isSimulationError(sim) || rpc.Api.isSimulationRestore(sim)) {
      throw new Error(`Simulation failed: ${"error" in sim ? sim.error : "restore needed"}`);
    }
    if (!sim.result) throw new Error("Address reservation returned no result.");

    const cAddress = Address.fromScVal(sim.result.retval).toString();
    savePendingAccount(cAddress, saltHex!);
    saveSetupSaltCookie(cAddress, saltHex!);
    await syncNidoStorageViaBridge();
    return cAddress;
  }

  // --- Step 1 · Lock it to you (register passkey) ---

  function buildPasskeyCreateOptions(): CredentialCreationOptions {
    const userId = new Uint8Array(16);
    crypto.getRandomValues(userId);
    return {
      publicKey: {
        challenge: crypto.getRandomValues(new Uint8Array(32)),
        rp: { name: `Soroban ${contractId}`, id: rpId },
        user: { id: userId, name: contractId!, displayName: `Account ${contractId}` },
        pubKeyCredParams: [{ alg: -7, type: "public-key" }],
        authenticatorSelection: { residentKey: "required", userVerification: "required" },
        attestation: "none",
        timeout: 60000,
      },
    };
  }

  // Persist the freshly-created passkey, then advance to the deploy step.
  async function completeRegistration(credential: PublicKeyCredential) {
    const reg = parseRegistration(credential as any);
    passkeyPublicKey = reg.publicKey;
    credentialIdBytes = reg.credentialId;

    sdkSaveCredential(contractId!, credentialIdBytes, passkeyPublicKey);
    void startTestnetFunding().catch((err) => console.warn("[nido] testnet funding prep failed", err));

    void buf2base64url(credentialIdBytes);
    void buf2hex(passkeyPublicKey);

    // Advance to "Setting up your Nido" and kick off the deploy automatically.
    $step1.classList.remove("on");
    $step1.classList.add("done");
    $step2.classList.add("on");
    $passkeySection.classList.add("hidden");
    $accountChip.classList.add("hidden");
    $deploySection.classList.remove("hidden");

    void deploy();
  }

  $registerBtn.addEventListener("click", async () => {
    clearError();
    // A manual tap takes over from any in-flight auto-attempt (see autopass).
    autoPasskeyController?.abort();
    if (!contractId) {
      showError("No account found in this link. Please start again from the home page.");
      return;
    }

    const support = checkPasskeySupport();
    if (!support.ok) {
      showError(support.message!);
      return;
    }

    try {
      $registerBtn.disabled = true;
      // Drive the REAL ceremony through the sheet — no fake timer. The OS
      // passkey dialog is the source of truth; the sheet closes when it settles.
      const credential = (await withPasskeySheet(
        () => navigator.credentials.create(buildPasskeyCreateOptions()),
        { title: "Lock it to you", sub: "Confirm with your passkey to finish setting up." },
      )) as PublicKeyCredential;
      await completeRegistration(credential);
    } catch (err: any) {
      if (err.name === "NotAllowedError") {
        showError("We couldn't reach your passkey. If you're in an in-app browser (Twitter, Instagram, etc.), tap the menu (…) and choose \"Open in Safari\" or \"Open in Browser\".");
      } else {
        showError(`Couldn't set up your passkey: ${err.message}`);
      }
      $registerBtn.disabled = false;
    }
  });

  // Arriving straight from the reservation page (`autopass=1`): try the passkey
  // prompt automatically. WebAuthn needs a transient user gesture that does NOT
  // survive the cross-subdomain redirect, so where it's enforced (notably iOS
  // Safari) this rejects at once — we swallow that silently and leave the ready
  // button for a manual tap. No sheet here, so the fallback doesn't flicker; the
  // OS dialog is the prompt on browsers that allow it.
  async function attemptAutoPasskey() {
    if (!contractId || !checkPasskeySupport().ok) return;
    // Run in the background: do NOT disable the button. The user can tap to take
    // over at any time (the click handler aborts this attempt first), so a hung
    // or pending attempt can never strand the button in a disabled state.
    autoPasskeyController = new AbortController();
    const options = buildPasskeyCreateOptions();
    options.signal = autoPasskeyController.signal;
    try {
      const credential = (await navigator.credentials.create(options)) as PublicKeyCredential;
      await completeRegistration(credential);
    } catch {
      // Rejected (no user activation on iOS Safari), declined, or aborted by a
      // manual tap — the ready button is already there for the user. Silent.
    }
  }

  // --- Step 2 · Setting up your Nido (deploy account) ---

  async function deploy() {
    clearError();
    if (!passkeyPublicKey || !saltHex) {
      showError("Register a passkey first and ensure setup data is present.");
      return;
    }

    try {
      // 0 · "Locked to you" is already done; main step 1 · "Publishing to Stellar"
      // begins. Its ticker narrates the sub-steps: prepare → submit → confirm.
      setCheckProgress(1, 1);
      setTicker(1, "preparing transaction…");

      if (!RELAYER_URL || !RELAYER_SIM_SOURCE) {
        throw new Error("Relayer is not configured for account setup.");
      }
      const simulationSource = RELAYER_SIM_SOURCE;
      const server = new rpc.Server(RPC_URL);

      const sourceAccount = await waitForSourceAccount(server, simulationSource);

      const simTxn = new TransactionBuilder(sourceAccount, {
        fee: "100",
        networkPassphrase: Networks.TESTNET,
      })
        .addOperation(
          Operation.invokeContractFunction({
            contract: await fetchRegistryAddress("factory"),
            function: "create_account",
            args: [
              xdr.ScVal.scvBytes(Buffer.from(saltBytes())),
              xdr.ScVal.scvBytes(Buffer.from(passkeyPublicKey)),
            ],
          })
        )
        .setTimeout(0)
        .build();

      const sim = await server.simulateTransaction(simTxn);
      if (rpc.Api.isSimulationError(sim) || rpc.Api.isSimulationRestore(sim)) {
        throw new Error(`Simulation failed: ${"error" in sim ? sim.error : "restore needed"}`);
      }

      const transaction = rpc.assembleTransaction(simTxn, sim).setTimeout(0).build();
      const { func, auth } = extractFuncAndAuth(transaction);

      // Prepared — hand the signed call off to the relayer.
      setTicker(1, "submitting to the network…");
      const submitted = await submitSorobanTransaction({ func, auth });
      if (!submitted.transactionId) {
        throw new Error("Relayer accepted account setup but returned no transaction id");
      }

      // Submitted — now the long wait. Surface the relayer's own status plus a
      // ledger heartbeat so the step reads as live rather than stalled.
      const confirmLabel = (status: RelayerStatus | null) =>
        status === "sent" ? "sent to the network"
        : status === "submitted" ? "submitted — waiting to confirm"
        : status === "confirmed" ? "confirmed on-chain"
        : "waiting for the network";
      let tickStatus = "waiting for the network";
      let tickLedger: number | null = null;
      // Guards the async ledger read: it may resolve after the wait is over and
      // the step is already done — without this it would re-show a stale ticker.
      let confirming = true;
      const renderConfirmTicker = () => {
        if (!confirming) return;
        setTicker(1, tickLedger ? `${tickStatus} · ledger ${tickLedger}…` : `${tickStatus}…`);
      };
      renderConfirmTicker();
      const confirmed = await waitForConfirmation(submitted.transactionId, undefined, {
        onPoll: ({ status }) => {
          tickStatus = confirmLabel(status);
          renderConfirmTicker();
          // Best-effort ledger heartbeat; a failed read just keeps the last value.
          server
            .getLatestLedger()
            .then((l) => {
              tickLedger = l.sequence;
              renderConfirmTicker();
            })
            .catch(() => {});
        },
      });
      confirming = false;
      if (!confirmed.hash) throw new Error("Relayer confirmed account setup without a transaction hash");

      activateAccount(contractId!);
      clearSetupSaltCookie(contractId!);
      await syncNidoStorageViaBridge();

      // Confirmed — main step 1 done; 2 · "Adding testnet funds" begins.
      setCheckProgress(2, 2);
      setTicker(2, "requesting testnet funds…");
      let fundingComplete = true;
      try {
        await drainTestnetFunding(server, contractId!);
        // Funded — 3 · "Your Nido is ready" begins.
        setCheckProgress(3, 3);
      } catch (fundingErr) {
        fundingComplete = false;
        console.warn("[nido] testnet funding failed", fundingErr);
        renderCheck(2, "pending");
        renderCheck(3, "pending");
        $deployNestSpinning.style.display = "none";
        $deployNestStatic.style.display = "block";
        showError(
          fundingErr instanceof Error
            ? `Testnet funding failed after setup: ${fundingErr.message}`
            : "Testnet funding failed after setup."
        );
        return;
      }
      if (fundingComplete) setCheckProgress(4, -1);
      $deployNestSpinning.style.display = "none";
      $deployNestStatic.style.display = "block";

      // Wire up the done screen.
      const protocol = window.location.protocol;
      const host = window.location.host;
      const accountUrl = `${protocol}//${host}/account/`;
      $explorerLink.href = `https://stellar.expert/explorer/testnet/contract/${contractId}`;

      // Brief beat so the final check lands before the reveal.
      await new Promise((r) => setTimeout(r, 700));
      $deploySection.classList.add("hidden");
      $doneSection.classList.remove("hidden");
      $step2.classList.remove("on");
      $step2.classList.add("done");

      // F-02: auto-advance into the wallet after a brief "ready" beat — arriving
      // in the funded wallet is the payoff, and the deploy copy already promised
      // an automatic hand-off. "View on Stellar Expert" remains the only opt-in link.
      setTimeout(() => {
        const intent = parseReturnIntent(new URLSearchParams(window.location.search).get("then"));
        if (intent) {
          const apexHost = stripSubdomain(window.location.host);
          window.location.href = buildClaimReturnUrl({
            apexHost,
            name: intent.name,
            contractId: contractId!,
            protocol: window.location.protocol,
          });
        } else {
          window.location.href = accountUrl;
        }
      }, 1700);
    } catch (err: any) {
      // Fall back to the passkey step so the user can retry the deploy.
      showError(`Couldn't finish setting up: ${err.message}`);
      $deploySection.classList.add("hidden");
      $passkeySection.classList.remove("hidden");
      $accountChip.classList.remove("hidden");
      $step2.classList.remove("on");
      $registerBtn.disabled = false;
    }
  }
</script>
