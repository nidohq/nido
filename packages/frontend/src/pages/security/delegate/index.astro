---
// Nido reskin of the session-key delegation approval page. The ENTIRE <script>
// is preserved verbatim from the BaseLayout version — including the origin /
// return-URL validation (anti-redirect-abuse) which is copied VERBATIM — and all
// element IDs and query-param names (origin, target, pubkey, duration, return)
// are unchanged. Only the shell, markup and copy are reskinned to Nido voice
// ("an app wants to act on your behalf").
import NidoLayout from '../../../layouts/NidoLayout.astro';
import Toast from '../../../components/Toast.astro';
import PasskeySheet from '../../../components/PasskeySheet.astro';
import Icon from '../../../components/Icon.astro';
---
<NidoLayout title="Let an app in">
  <div class="col-scroll scroll-hide screen-in">
    <!-- K-02: standard sub-flow top bar (back + centered title) so reaching and
         leaving nested flows is predictable — matches the recover sub-flow. -->
    <div class="topbar">
      <a href="/security/" class="btn ghost sm" style="width:40px;height:40px;padding:0;border-radius:12px;" aria-label="Back">
        <Icon name="back" size={18} />
      </a>
      <h1 class="disp" style="font-weight:800;font-size:19px;">Let an app in?</h1>
      <span style="width:40px;"></span>
    </div>

    <div class="pad" style="padding-top:8px;">
      <div class="card" style="padding:18px;">
        <div style="display:flex;align-items:center;gap:11px;margin-bottom:14px;">
          <div style="width:42px;height:42px;border-radius:13px;background:var(--acc-soft);display:grid;place-items:center;">
            <Icon name="link" size={20} color="var(--acc)" />
          </div>
          <div style="min-width:0;">
            <div style="font-weight:700;font-size:14.5px;">App wants to act for you</div>
            <div class="mut mono" id="origin-text" style="font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
          </div>
        </div>
        <p class="mut" style="font-size:13px;line-height:1.55;margin:0;">
          This app made its own key and wants permission to use it with the contract
          below — just for a while. You stay in control: approve with your passkey,
          and you can cut it off any time.
        </p>
      </div>

      <span class="section-label" style="display:block;margin:22px 0 10px;">What you're allowing</span>
      <div class="card" style="overflow:hidden;padding:0;">
        <div class="navrow" style="cursor:default;">
          <div style="flex:1;">
            <div style="font-weight:700;font-size:13.5px;">Allowed to use</div>
            <div class="mut mono" style="font-size:12px;"><code id="target-text" style="word-break:break-all; display:block;"></code></div>
          </div>
        </div>
        <div class="navrow" style="cursor:default;">
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:13.5px;">App's key</div>
            <div class="mut mono" style="font-size:11.5px;word-break:break-all;"><code id="pubkey-text" class="wrap"></code></div>
          </div>
        </div>
        <div class="navrow" style="cursor:default;">
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:13.5px;">Expires</div>
            <select id="duration-sel" class="input"
                    style="height:40px;font-size:13.5px;width:auto;padding:0 10px;margin-top:8px;">
              <option value="24h">In 24 hours</option>
              <option value="7d">In 7 days</option>
              <option value="30d">In 30 days</option>
              <option value="none">Never (until revoked)</option>
            </select>
            <div class="mut" id="expiry-text" style="font-size:12.5px;margin-top:8px;line-height:1.5;"></div>
          </div>
        </div>
        <div class="navrow" style="cursor:default;border-bottom:none;">
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:13.5px;">Spending limit</div>
            <div class="mut" id="limit-summary" style="font-size:12.5px;margin-top:8px;line-height:1.5;"></div>
          </div>
        </div>
      </div>

      <p class="mut" style="font-size:12.5px;line-height:1.55;margin:14px 0 0;">
        Next you'll review and confirm with your passkey. You can adjust the
        spending limit on the review screen. To cut it off later, visit
        <a href="/security/" class="link">your safety settings</a>.
      </p>

      <div class="actions" style="display:flex;gap:10px;margin-top:18px;">
        <button id="approve" class="btn acc" type="button" style="flex:1;">Review &amp; continue</button>
        <button id="deny" class="btn ghost" type="button" style="flex:0 0 auto;width:auto;">Cancel</button>
      </div>
      <p id="status" role="status" aria-live="polite" class="mut" style="font-size:12.5px;margin-top:12px;"></p>
    </div>
  </div>

  <Toast />
  <PasskeySheet />
</NidoLayout>

<script>
  import { contractIdFromHostname } from '@nidohq/passkey-sdk';
  import { fetchVerifierAddress } from '../../../lib/policyChainFetch.js';
  import { stroopsToXlm } from '../../../lib/money.js';
  import {
    PERIOD_LEDGERS,
    PERIOD_LABEL,
    stroopsFromXlm,
    type LimitPeriod,
  } from '../../../lib/spendingLimitParams.js';
  import { stashSignRequest, type SignRequest } from '../../../lib/signing/signRequest';

  const RPC_URL = 'https://soroban-testnet.stellar.org';
  const DURATIONS: Record<string, number | null> = {
    '24h': 17280,
    '7d': 17280 * 7,
    '30d': 17280 * 30,
    'none': null,
  };
  // Human-readable expiry labels matching the <select> option text, used to carry
  // the display label through to /sign/ so it never has to interpret validUntil.
  const DURATION_LABEL: Record<string, string> = {
    '24h': '24 hours',
    '7d': '7 days',
    '30d': '30 days',
    'none': 'Until revoked',
  };

  const params = new URLSearchParams(window.location.search);
  const dappOrigin = params.get('origin') ?? '';
  const target = params.get('target') ?? '';
  const pubkeyHex = params.get('pubkey') ?? '';
  const duration = params.get('duration') ?? '30d';
  // Optional spending limit: `limit` (decimal XLM string) + `limit_period`
  // (day|week|30d, default day). Absent or EMPTY `limit` = no cap (today's
  // behavior). The dApp's request seeds the editable control on /sign/; it
  // must NOT pre-block here with a parse error.
  const limitParam = params.get('limit') || null;
  const limitPeriodParam = params.get('limit_period') ?? 'day';
  const limitPeriodInitial: LimitPeriod =
    limitPeriodParam in PERIOD_LEDGERS ? (limitPeriodParam as LimitPeriod) : 'day';
  const returnUrl = params.get('return') ?? '';
  const account = contractIdFromHostname(window.location.hostname);

  // Surface the request to the user.
  document.getElementById('origin-text')!.textContent = dappOrigin || '(missing)';
  document.getElementById('target-text')!.textContent = target || '(missing)';
  document.getElementById('pubkey-text')!.textContent = pubkeyHex || '(missing)';

  const expirySpan = document.getElementById('expiry-text')!;
  const durationSel = document.getElementById('duration-sel') as HTMLSelectElement;
  // Pre-select the dApp's requested duration when it's one we offer; otherwise
  // fall back to the 30-day default. The user can change it before continuing —
  // the selected value (not the URL param) is what gets installed.
  durationSel.value = duration in DURATIONS ? duration : '30d';

  // The select only holds keys we defined, so the lookup is always valid; a
  // `none` value is a real `null` (no expiry), not a missing key.
  const selectedExpiryOffset = (): number | null => DURATIONS[durationSel.value];

  function syncExpiry() {
    const off = selectedExpiryOffset();
    expirySpan.textContent =
      off == null
        ? 'Never — stays valid until you revoke it.'
        : `≈ ${off.toLocaleString()} ledgers from now.`;
  }
  durationSel.addEventListener('change', syncExpiry);
  syncExpiry();

  const denyBtn = document.getElementById('deny')!;
  const approveBtn = document.getElementById('approve') as HTMLButtonElement;
  const status = document.getElementById('status')!;

  // Read-only spending-limit summary — the EDITABLE control now lives on the
  // /sign/ review screen. We compute the limit the dApp seeded (if any) so the
  // user sees it before continuing; the actual editing happens on /sign/.
  const limitSummary = document.getElementById('limit-summary')!;
  let initialStroops: string | null = null;
  if (limitParam != null) {
    try {
      initialStroops = stroopsFromXlm(limitParam).toString();
      limitSummary.textContent =
        `Requested cap: ${stroopsToXlm(initialStroops)} XLM ${PERIOD_LABEL[limitPeriodInitial]} ` +
        `(rolling window). You can change this on the next screen.`;
    } catch {
      // A malformed dApp-supplied limit is ignored (treated as no cap); the
      // user can set one on /sign/. Never block the flow on a bad ?limit=.
      initialStroops = null;
      limitSummary.textContent =
        'No cap requested — you can set a spending limit on the next screen.';
    }
  } else {
    limitSummary.textContent =
      'No cap requested — you can set a spending limit on the next screen.';
  }

  // Return-URL must be the dApp origin (anti-redirect-abuse). Returns the
  // validated, query-rewritten URL string, or null if it fails validation.
  function backToDapp(qs: string): string | null {
    if (!returnUrl) return null;
    try {
      const url = new URL(returnUrl);
      if (url.origin !== dappOrigin) {
        status.textContent = `Refusing to redirect: return URL origin (${url.origin}) does not match request origin (${dappOrigin}).`;
        return null;
      }
      url.search = qs;
      return url.toString();
    } catch {
      status.textContent = 'Invalid return URL; not redirecting.';
      return null;
    }
  }

  denyBtn.addEventListener('click', () => {
    const back = backToDapp('?delegation=cancelled');
    if (back) window.location.href = back;
  });

  // Sanity-check request parameters before allowing the handoff.
  function validate(): string | null {
    if (!account) return 'This page must be opened on an account subdomain.';
    if (!dappOrigin) return 'Missing origin parameter.';
    if (!target || !/^C[A-Z0-9]{55}$/.test(target)) return 'Invalid target contract address.';
    if (!pubkeyHex || !/^04[0-9a-fA-F]{128}$/.test(pubkeyHex)) {
      return 'Invalid session public key (expected 65-byte SEC1 uncompressed P-256, hex-encoded with 0x04 prefix).';
    }
    if (!returnUrl) return 'Missing return URL.';
    try { new URL(returnUrl); } catch { return 'Malformed return URL.'; }
    return null;
  }

  const err = validate();
  if (err) {
    status.textContent = err;
    approveBtn.disabled = true;
  }

  approveBtn.addEventListener('click', async () => {
    approveBtn.disabled = true;
    try {
      // Validate the dApp return URL BEFORE we do any work — keeps the
      // anti-redirect-abuse guard at the front of the flow.
      const successReturn = backToDapp('?delegation=ok');
      if (!successReturn) {
        // backToDapp already wrote the reason to `status`.
        approveBtn.disabled = false;
        return;
      }

      // Resolve the verifier THIS account trusts (read from rule 0) so the
      // installed External signer cites the right verifier. Done in the caller
      // to keep /sign/ generic — the descriptor carries the resolved address.
      status.textContent = 'Resolving verifier address…';
      const verifierAddress = await fetchVerifierAddress(account!);

      // Compute the absolute expiry ledger from the chosen duration. A `none`
      // selection installs no expiry (validUntil = null → valid until revoked).
      status.textContent = 'Computing expiry…';
      const { rpc } = await import('@stellar/stellar-sdk');
      const server = new rpc.Server(RPC_URL);
      const latest = await server.getLatestLedger();
      const off = selectedExpiryOffset();
      const validUntil = off == null ? null : latest.sequence + off;

      const limit =
        initialStroops != null
          ? { stroops: initialStroops, periodLedgers: PERIOD_LEDGERS[limitPeriodInitial] }
          : null;

      // Build the canonical SignRequest and hand off to /sign/. The grant runs
      // on this account's contract-id subdomain, so sessionStorage is
      // same-origin and `?req=<id>` resolves on the next page.
      const req: SignRequest = {
        v: 1,
        kind: 'session-grant',
        account: account!,
        operation: {
          type: 'add-context-rule',
          target,
          signerPublicKeyHex: pubkeyHex,
          verifierAddress,
          validUntil,
          limit,
          label: 'session-key',
          expiryLabel: DURATION_LABEL[durationSel.value] ?? (validUntil == null ? 'Until revoked' : `${durationSel.value}`),
        },
        title: 'Grant a session key',
        subtitle: `${dappOrigin} wants to act on your behalf.`,
        submitMode: 'relayer',
        editable: [
          { field: 'spending-limit', initialStroops, initialPeriod: limitPeriodInitial },
        ],
        // dApp return: /sign/ posts `?delegation=ok` on success (and
        // `?delegation=cancelled` on cancel) — the delegationHandover contract.
        returnTarget: {
          type: 'dapp',
          origin: dappOrigin,
          returnUrl,
          successQuery: '?delegation=ok',
        },
      };

      const id = stashSignRequest(req);
      window.location.href = `/sign/?req=${id}`;
    } catch (e) {
      const msg = e instanceof Error ? e.message : String(e);
      status.textContent = `Failed: ${msg}`;
      approveBtn.disabled = false;
    }
  });
</script>

<style>
  .pad code { font-family: var(--mono); }
  code.wrap { word-break: break-all; }
</style>
