---
// Nido reskin of the account-recovery ceremony page. BOTH modes are preserved:
//  - friend mode (?handoff=…): a friend approves & signs a Refractor-backed rotation
//  - originator mode: stage an M-of-N rotation, collect friend signatures, submit
// The entire <script> (recoveryActions wiring, M-of-N logic, handoff, staging
// resume, key persistence) is preserved verbatim from the BaseLayout version.
// Element IDs are unchanged so the script keeps working; only shell, markup and
// copy are reskinned to Nido voice ("friends can let you back in").
import NidoLayout from '../../../layouts/NidoLayout.astro';
import Toast from '../../../components/Toast.astro';
import PasskeySheet from '../../../components/PasskeySheet.astro';
import Icon from '../../../components/Icon.astro';
---
<NidoLayout title="Get back in">
  <div class="col-scroll scroll-hide screen-in">
    <div class="topbar">
      <a href="/security/" class="btn ghost sm" style="width:40px;height:40px;padding:0;border-radius:12px;" aria-label="Back">
        <Icon name="back" size={18} />
      </a>
      <h1 class="disp" style="font-weight:800;font-size:19px;">Get back in</h1>
      <span style="width:40px;"></span>
    </div>

    <div class="pad" style="padding-top:8px;">
      <!-- Friend mode: shown when ?handoff=… is present -->
      <section id="friend-mode" hidden>
        <div class="card" style="padding:18px;">
          <div style="display:flex;align-items:center;gap:11px;margin-bottom:12px;">
            <div style="width:40px;height:40px;border-radius:12px;background:var(--acc-soft);display:grid;place-items:center;">
              <Icon name="shieldcheck" size={20} color="var(--acc)" />
            </div>
            <div class="disp" style="font-weight:800;font-size:17px;">A friend needs your help</div>
          </div>
          <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 12px;">
            Your friend <code id="fm-account" class="mono" style="word-break:break-all; display:block;"></code> lost their phone and is
            getting back in. Take a look, then approve with your own passkey — your
            okay only counts toward this one request.
          </p>
          <p style="margin:0 0 14px;"><strong id="fm-desc" style="font-size:14px;"></strong></p>
          <div class="actions" style="display:flex;gap:10px;">
            <button id="fm-sign" class="btn acc" type="button">Approve &amp; sign</button>
          </div>
          <div id="fm-done" hidden style="margin-top:16px;">
            <div style="display:flex;align-items:center;gap:9px;color:var(--good-ink);">
              <Icon name="shieldcheck" size={18} color="var(--good-ink)" />
              <strong style="font-size:14px;">Signed ✓ — you can close this</strong>
            </div>
            <p class="mut" style="font-size:13px;line-height:1.55;margin:8px 0 0;">
              Your approval was sent to your friend automatically. Nothing else to do.
            </p>
          </div>
          <p id="fm-status" class="mut" style="font-size:12.5px;margin-top:12px;"></p>
        </div>
      </section>

      <!-- Picker mode: shown when the handoff is for THIS account's own
           subdomain — pick a friend, then redirect to that friend's Nido. -->
      <section id="picker-mode" hidden>
        <div class="card" style="padding:18px;">
          <div style="display:flex;align-items:center;gap:11px;margin-bottom:12px;">
            <div style="width:40px;height:40px;border-radius:12px;background:var(--acc-soft);display:grid;place-items:center;">
              <Icon name="shieldcheck" size={20} color="var(--acc)" />
            </div>
            <div class="disp" style="font-weight:800;font-size:17px;">Ask a friend to approve</div>
          </div>
          <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 14px;">
            Pick a friend below. We'll take you to their Nido so they can approve
            with their own passkey. Friends who've already signed are greyed out.
          </p>
          <ul id="picker-list" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;"></ul>
          <p id="picker-progress" class="mut" style="font-size:12.5px;margin-top:14px;"></p>
        </div>
      </section>

      <!-- Originator mode -->
      <section id="originator-mode" hidden>
        <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 6px;">
          Your trusted friends, together, can put a new passkey on this account.
          Make a new passkey, share the link with each friend, gather their okays,
          then finish.
        </p>
        <p class="mut" style="font-size:12.5px;margin:0 0 14px;">
          Prefer a seed phrase or a wallet instead of friends?
          <a href="?zk=1" class="link">Recover with a seed phrase or wallet</a>.
        </p>

        <div id="om-no-rule" hidden>
          <div class="card" style="padding:18px;margin-top:14px;">
            <p style="margin:0;font-size:14px;line-height:1.55;">
              No trusted friends are set up on this account. Friends have to be added
              <em>before</em> a phone is lost. <a href="/security/" class="link">Back to safety</a>.
            </p>
          </div>
        </div>

        <p id="om-multi-rule" class="mut" style="font-size:12.5px;margin-top:12px;" hidden></p>

        <!-- Repair mode (issue #87): rule 0 is multi-signer with no policy,
             so EVERY passkey must co-sign every action — single-passkey
             signing is bricked. Friends can authorize installing a 1-of-N
             approval policy without touching any keys. -->
        <div id="om-repair" hidden>
          <div class="card" style="padding:18px;margin-top:14px;border:1px solid var(--warn-ink, #b45309);">
            <div class="disp" style="font-weight:800;font-size:15px;margin-bottom:8px;">This account is locked</div>
            <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 12px;" id="om-repair-text">
              All of this account's passkeys currently have to approve together,
              so signing with one passkey always fails. Your friends can fix
              this — no keys change.
            </p>
            <button id="om-repair-btn" class="btn acc" type="button">Repair with my friends</button>
            <p id="om-repair-status" class="mut" style="font-size:12.5px;margin-top:10px;"></p>
          </div>
        </div>

        <div id="om-stage">
          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 1 · New passkey</span>
          <div class="card" style="padding:18px;">
            <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 12px;">
              Create a fresh passkey on this device. It becomes the way you get in
              from now on.
            </p>
            <button id="om-new-key" class="btn acc" type="button">
              <Icon name="key" size={18} /> Create new passkey
            </button>
            <p id="om-key-status" class="mut" style="font-size:12.5px;margin-top:10px;"></p>
          </div>

          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 2 · Optional</span>
          <div class="card" style="padding:18px;">
            <label id="om-remove-label" style="display:flex;align-items:flex-start;gap:9px;cursor:pointer;">
              <input id="om-remove-old" type="checkbox" disabled
                     style="margin-top:3px;accent-color:var(--acc);" />
              <span>
                <span style="display:block;font-size:14px;">Remove the lost device's key</span>
                <span id="om-remove-hint" class="mut" style="display:block;font-size:12.5px;margin-top:3px;line-height:1.5;">Checking the account…</span>
              </span>
            </label>
          </div>

          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 3 · Share with friends</span>
          <div class="card" style="padding:18px;">
            <button id="om-prepare" class="btn acc" type="button" disabled>Share with my friends</button>
            <p id="om-prepare-status" class="mut" style="font-size:12.5px;margin-top:10px;"></p>
          </div>
        </div>

        <div id="om-collect" hidden>
          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 4 · Gather okays</span>
          <div class="card" style="padding:18px;">
            <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 8px;">Send this link to each friend:</p>
            <textarea id="om-link" class="input mono" rows="3" readonly></textarea>
            <button id="om-copy-link" class="btn soft sm" type="button" style="margin:8px 0 16px;">
              <Icon name="copy" size={16} /> Copy link
            </button>
            <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 8px;">
              As each friend approves, their okay shows up here automatically.
            </p>
            <button id="om-refresh" class="btn soft sm" type="button">Refresh</button>
            <p id="om-progress" class="mut" style="font-size:12.5px;margin-top:12px;"></p>
            <ul id="om-collected"></ul>
          </div>

          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 5 · Finish</span>
          <div class="card" style="padding:18px;">
            <div class="actions" style="display:flex;gap:10px;">
              <button id="om-submit" class="btn acc" type="button" disabled style="flex:1;">Get back in</button>
              <button id="om-cancel" class="btn ghost" type="button" style="flex:0 0 auto;width:auto;">Cancel</button>
            </div>
            <p id="om-submit-status" class="mut" style="font-size:12.5px;margin-top:10px;"></p>
          </div>
        </div>
      </section>

      <!-- ZK mode: recover with a seed phrase or an external wallet, no
           friends required. Triggered by ?zk=1 (or the link from originator
           mode above). Fixed ids below match the M4 plan's step machine —
           Playwright hooks land in Task 5. -->
      <section id="zk-mode" hidden>
        <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 6px;">
          Get back in using a seed phrase or the wallet you enrolled with —
          no friends required.
        </p>
        <div class="alert warn" role="note" style="margin-top:14px;">
          Once you start a recovery, don't clear this browser's site data
          until it finishes — the new passkey's public key is only
          remembered here (your secret itself is never stored anywhere).
        </div>

        <p id="zk-status" class="mut" style="font-size:12.5px;"></p>

        <div id="zk-new-key" hidden>
          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 1 · New passkey</span>
          <div class="card" style="padding:18px;">
            <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 12px;">
              Create a fresh passkey on this device. It becomes the way you
              get in once this recovery completes.
            </p>
            <button id="zk-new-key-btn" class="btn acc" type="button">
              <Icon name="key" size={18} /> Create new passkey
            </button>
            <p id="zk-new-key-status" class="mut" style="font-size:12.5px;margin-top:10px;"></p>
          </div>
        </div>

        <div id="zk-secret" hidden>
          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 2 · Prove it's you</span>
          <div class="card" style="padding:18px;">
            <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 12px;">
              Enter the 12 or 24-word recovery phrase you saved, or sign with
              the wallet you enrolled with.
            </p>
            <textarea id="zk-mnemonic-input" class="input mono" rows="3"
                      placeholder="word1 word2 word3 …" style="width:100%;"></textarea>
            <div class="actions" style="display:flex;gap:10px;margin-top:10px;flex-wrap:wrap;">
              <button id="zk-mnemonic-btn" class="btn acc" type="button">Use this phrase</button>
              <button id="zk-wallet-btn" class="btn soft" type="button">Sign with a wallet instead</button>
            </div>
            <p id="zk-secret-status" class="mut" style="font-size:12.5px;margin-top:10px;"></p>
          </div>
        </div>

        <div id="zk-sync" hidden>
          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 3 · Checking the recovery pool</span>
          <div class="card" style="padding:18px;">
            <p id="zk-sync-status" class="mut" style="font-size:13px;line-height:1.55;margin:0;"></p>
          </div>
        </div>

        <div id="zk-initiate" hidden>
          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 4 · Start recovery</span>
          <div class="card" style="padding:18px;">
            <p class="mut" style="font-size:13px;line-height:1.55;margin:0 0 12px;">
              This proves you know the recovery secret without revealing it
              on-chain. Proving happens on this device and can take from a
              few seconds to a couple of minutes.
            </p>
            <button id="zk-initiate-btn" class="btn acc" type="button">Start recovery</button>
            <div id="zk-prove" hidden style="margin-top:12px;align-items:center;gap:9px;">
              <svg class="spin" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--acc)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 13.7-5.6L20 8"/><path d="M20 4v4h-4"/><path d="M20 12a8 8 0 0 1-13.7 5.6L4 16"/><path d="M4 20v-4h4"/></svg>
              <span id="zk-prove-status" class="mut" style="font-size:12.5px;"></span>
            </div>
            <p id="zk-initiate-status" class="mut" style="font-size:12.5px;margin-top:10px;"></p>
          </div>
        </div>

        <div id="zk-countdown" hidden>
          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 5 · Timelock</span>
          <div class="card" style="padding:18px;">
            <p id="zk-countdown-text" class="mut" style="font-size:14px;font-weight:700;margin:0;"></p>
            <p class="mut" style="font-size:12.5px;margin-top:10px;line-height:1.5;">
              This waiting period protects you — it gives you time to notice
              and cancel from Security settings if you didn't start this.
            </p>
          </div>
        </div>

        <div id="zk-complete" hidden>
          <span class="section-label" style="display:block;margin:22px 0 10px;">Step 6 · Finish</span>
          <div class="card" style="padding:18px;">
            <button id="zk-complete-btn" class="btn acc" type="button">Complete recovery</button>
            <p id="zk-complete-status" class="mut" style="font-size:12.5px;margin-top:10px;"></p>
          </div>
        </div>
      </section>
    </div>
  </div>

  <Toast />
  <PasskeySheet />
</NidoLayout>

<script>
  import {
    rpc,
    Contract,
    scValToNative,
    StrKey,
  } from '@stellar/stellar-sdk';
  import {
    accountUrl,
    contractIdFromHostname,
    createSessionPasskey,
    decodeRotationHandoff,
    lookupName,
    buf2hex,
    hex2buf,
    deriveSecretM1,
    wrapLeafInner,
    wrapLeafStored,
    fieldToBytes32,
    type RotationHandoff,
    type Fr,
  } from '@nidohq/passkey-sdk';
  import {
    fetchVerifierAddress,
    findRemovableOldSigner,
    simulateView,
    type RemovableSigner,
  } from '../../../lib/policyChainFetch.js';
  import {
    findRecoveryRules,
    prepareRotation,
    submitRotation,
    signRotationAsFriend,
    submitFriendSignatureToRelay,
    collectFromRelay,
    checkDefaultRuleRepair,
    getStaging,
    clearStaging,
    collectedCount,
    recoveryHandoffLinkFromStaging,
    RELAY_BASE_URL,
  } from '../../../lib/recoveryActions.js';
  import {
    syncPoolAndLocate,
    initiateZkRecovery,
    completeZkRecovery,
    getZkPending,
    readStaged,
    clearStaged,
  } from '../../../lib/zkRecoveryActions.js';
  import { buildPickerRows } from '../../../lib/friendPicker.js';
  import { listFriendSignatures } from '../../../lib/relayClient.js';
  import { nameRegistryId, NAME_NETWORK } from '../../../lib/nidoSwitcher.js';
  import { RPC_URL, NETWORK_PASSPHRASE } from '../../../lib/network.js';
  import { initWalletKit, connect as connectWallet } from '../../../lib/walletConnect.js';
  import { deriveM2SecretSafely } from '../../../lib/walletRecoverySign.js';
  import { StellarWalletsKit } from '@creit.tech/stellar-wallets-kit';
  import { validateMnemonic } from '@scure/bip39';
  import { wordlist } from '@scure/bip39/wordlists/english.js';

  const account = contractIdFromHostname(window.location.hostname);
  const params = new URLSearchParams(window.location.search);
  const handoff = params.get('handoff');

  const friendMode = document.getElementById('friend-mode')!;
  const pickerMode = document.getElementById('picker-mode')!;
  const originatorMode = document.getElementById('originator-mode')!;
  const zkMode = document.getElementById('zk-mode')!;

  if (params.get('zk') === '1') {
    void runZkMode();
  } else if (handoff) {
    let parsed: RotationHandoff | null = null;
    try {
      parsed = decodeRotationHandoff(handoff);
    } catch {
      parsed = null; // surface the decode-error path through friend mode
    }
    if (parsed && account === parsed.account) {
      runPickerMode(handoff, parsed);
    } else {
      runFriendMode(handoff);
    }
  } else {
    runOriginatorMode();
  }

  // ---- Friend mode --------------------------------------------------------
  async function runFriendMode(encoded: string) {
    friendMode.hidden = false;
    const status = document.getElementById('fm-status')!;
    if (!account) {
      status.textContent = 'Open this link on your own account subdomain so your passkey can sign.';
      return;
    }
    try {
      document.getElementById('fm-account')!.textContent =
        decodeRotationHandoff(encoded).account;
    } catch {
      document.getElementById('fm-account')!.textContent = 'this account';
    }

    // Persists across retry clicks so a relay-PUT failure never forces a re-sign.
    let signedBlob: string | null = null;
    document.getElementById('fm-sign')!.addEventListener('click', async () => {
      const btn = document.getElementById('fm-sign') as HTMLButtonElement;
      btn.disabled = true;
      // Sign only once: if a previous attempt already produced a blob (e.g. the
      // relay PUT failed and the user is retrying), reuse it instead of
      // re-running the passkey ceremony with a fresh nonce.
      if (!signedBlob) {
        status.textContent = 'Signing…';
        try {
          const signed = await signRotationAsFriend(
            account!,
            encoded,
            (m) => { status.textContent = m; },
          );
          signedBlob = signed.blob;
          document.getElementById('fm-desc')!.textContent = signed.description;
        } catch (e) {
          status.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
          btn.disabled = false;
          return;
        }
      }
      // Decode the handoff to learn where the friend's signature should go, then
      // push the blob to the relay. The recovering account polls it; no paste-back.
      try {
        const h = decodeRotationHandoff(encoded);
        status.textContent = 'Sending your approval…';
        await submitFriendSignatureToRelay(
          h.relayBaseUrl,
          h.relayKey,
          account!,
          signedBlob,
        );
        document.getElementById('fm-sign')!.hidden = true;
        document.getElementById('fm-done')!.hidden = false;
        status.textContent = '';
      } catch (e) {
        // Do NOT lose the signature: keep the blob in scope (so the retry above
        // reuses it) and offer a manual fallback to hand it back out of band.
        const err = e instanceof Error ? e.message : String(e);
        status.innerHTML =
          `Couldn't send automatically (${err}). Copy this and send it to ` +
          `your friend, or tap Approve again to retry:`;
        let ta = document.getElementById('fm-fallback') as HTMLTextAreaElement | null;
        if (!ta) {
          ta = document.createElement('textarea');
          ta.id = 'fm-fallback';
          ta.className = 'input mono';
          ta.rows = 5;
          ta.readOnly = true;
          ta.style.marginTop = '8px';
          status.after(ta);
        }
        ta.value = signedBlob;
        btn.disabled = false;
      }
    });
  }

  // ---- Picker mode --------------------------------------------------------
  // Shown when the handoff link is opened on the RECOVERING account's own
  // subdomain. Lists the rule's friends, greys out those who already signed,
  // and redirects to a chosen friend's Nido so they can approve there.
  async function runPickerMode(encoded: string, h: RotationHandoff) {
    pickerMode.hidden = false;
    const list = document.getElementById('picker-list')!;
    const progress = document.getElementById('picker-progress')!;

    // Resolve the rule the handoff targets (fall back to the first rule).
    let friends: string[] = [];
    let threshold = 0;
    try {
      const rules = await findRecoveryRules(h.account);
      const rule = rules.find((r) => r.ruleId === h.recoveryRuleId) ?? rules[0];
      if (!rule) {
        progress.textContent = 'No recovery friends are set up on this account.';
        return;
      }
      friends = rule.friends;
      threshold = rule.threshold ?? Math.max(1, Math.ceil(friends.length / 2));
    } catch (e) {
      progress.textContent =
        'Could not read this account’s recovery rule: ' +
        (e instanceof Error ? e.message : String(e));
      return;
    }

    // Best-effort name resolution per friend; failures fall back to the address.
    const names = new Map<string, string>();
    let registryId: string | null = null;
    try {
      registryId = await nameRegistryId();
    } catch {
      registryId = null;
    }
    if (registryId) {
      await Promise.all(
        friends.map(async (addr) => {
          try {
            const name = await lookupName(RPC_URL, registryId!, addr, NAME_NETWORK);
            if (name) names.set(addr, name);
          } catch {
            /* leave unresolved; address fallback is fine */
          }
        }),
      );
    }

    // Best-effort signed set: a relay error means show everyone ungreyed.
    let signed = new Set<string>();
    try {
      const sigs = await listFriendSignatures(h.relayBaseUrl, h.relayKey);
      signed = new Set(sigs.map((s) => s.friend));
    } catch {
      signed = new Set();
    }

    const rows = buildPickerRows(friends, names, signed);
    list.innerHTML = '';
    for (const row of rows) {
      const li = document.createElement('li');
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'btn soft';
      btn.style.width = '100%';
      btn.style.justifyContent = 'flex-start';
      if (row.signed) {
        btn.textContent = `${row.label} ✓`;
        btn.disabled = true;
      } else {
        btn.textContent = row.label;
        btn.addEventListener('click', () => {
          window.location.assign(
            accountUrl(
              window.location.host,
              row.address,
              `/security/recover/?handoff=${encoded}`,
            ),
          );
        });
      }
      li.appendChild(btn);
      list.appendChild(li);
    }

    progress.textContent = `${signed.size} of ${threshold} friends have signed.`;
  }

  // ---- Originator mode ----------------------------------------------------
  async function runOriginatorMode() {
    originatorMode.hidden = false;
    if (!account) {
      document.getElementById('om-stage')!.innerHTML =
        '<p class="muted">Open this page on the account subdomain you want to recover.</p>';
      return;
    }

    let newPublicKey: Uint8Array | null = null;
    let newCredentialId: string | null = null;
    let recoveryRuleId: number | null = null;
    let friends: string[] = [];
    let threshold = 1;
    let removable: RemovableSigner | null = null;

    const keyStatus = document.getElementById('om-key-status')!;
    const prepareBtn = document.getElementById('om-prepare') as HTMLButtonElement;

    // Discover recovery rule.
    try {
      const rules = await findRecoveryRules(account);
      if (rules.length === 0) {
        document.getElementById('om-no-rule')!.hidden = false;
        document.getElementById('om-stage')!.hidden = true;
        return;
      }
      // First cut: use the first recovery rule, but warn if there is more
      // than one so the user knows we are not letting them pick yet.
      if (rules.length > 1) {
        const warn = document.getElementById('om-multi-rule')!;
        warn.hidden = false;
        warn.textContent =
          `This account has ${rules.length} recovery rules. Using rule #${rules[0].ruleId} ` +
          `(the first). Picking among multiple recovery rules is not supported yet.`;
      }
      recoveryRuleId = rules[0].ruleId;
      friends = rules[0].friends;
      // Use the REAL on-chain threshold from the rule's multisig policy; only
      // fall back to a heuristic if the policy could not be read.
      threshold =
        rules[0].threshold ?? Math.max(1, Math.ceil(friends.length / 2));
    } catch (e) {
      document.getElementById('om-stage')!.innerHTML =
        '<p class="muted">Failed to read recovery rule: ' +
        (e instanceof Error ? e.message : String(e)) + '</p>';
      return;
    }

    // Figure out which signer the "remove the lost device's key" checkbox would
    // remove. Enable it only when exactly one External (passkey) signer is on
    // rule 0 — during recovery that's the lost device's key (the new passkey
    // isn't on-chain yet). With 0 or >1 (or an unreadable rule) leave it
    // disabled and explain why, rather than guess.
    const removeCheckbox = document.getElementById('om-remove-old') as HTMLInputElement;
    const removeHint = document.getElementById('om-remove-hint')!;
    void (async () => {
      removable = await findRemovableOldSigner(account!);
      if (removable.ok) {
        removeCheckbox.disabled = false;
        removeHint.textContent =
          `Removes the old passkey …${buf2hex(removable.publicKey).slice(-8)} ` +
          `(signer #${removable.signerId}) in the same recovery.`;
      } else {
        removeCheckbox.checked = false;
        removeCheckbox.disabled = true;
        removeHint.textContent =
          removable.reason === 'none'
            ? 'No old device key found to remove.'
            : removable.reason === 'multiple'
              ? `This account has ${removable.count} device keys — can't pick one ` +
                `automatically, so leave this unchecked.`
              : "Couldn't read this account's keys just now — leave unchecked or retry.";
      }
    })();

    // Resume an in-progress rotation if one is staged.
    const existing = getStaging(account);
    if (existing) {
      threshold = existing.threshold;
      showCollect(existing.threshold);
      refreshProgress();
    }

    // Issue #87: offer the repair path when rule 0 is multi-signer with no
    // policy (single-passkey signing bricked). The repair is a recovery-
    // authorized rotation that ONLY installs the 1-of-N approval policy.
    void (async () => {
      try {
        const repair = await checkDefaultRuleRepair(account!);
        if (!repair.needsRepair) return;
        document.getElementById('om-repair')!.hidden = false;
        document.getElementById('om-repair-text')!.textContent =
          `All ${repair.signerCount} of this account's passkeys currently have to ` +
          `approve together, so signing with one passkey always fails. Your ` +
          `friends can fix this by installing a 1-of-${repair.signerCount} ` +
          `approval policy — no keys change.`;
      } catch { /* detection is best-effort; the normal flow still works */ }
    })();

    document.getElementById('om-repair-btn')!.addEventListener('click', async () => {
      const btn = document.getElementById('om-repair-btn') as HTMLButtonElement;
      const status = document.getElementById('om-repair-status')!;
      btn.disabled = true;
      status.textContent = 'Staging repair…';
      try {
        // Bare request: no key added or removed. planRotation sees the
        // bricked rule state and plans the lone add_policy call.
        const { handoffLink } = await prepareRotation({
          account: account!,
          recoveryRuleId: recoveryRuleId!,
          friends,
          threshold,
          request: { defaultRuleId: 0 },
        });
        (document.getElementById('om-link') as HTMLTextAreaElement).value = handoffLink;
        showCollect(threshold);
        refreshProgress();
        status.textContent = 'Staged. Share the link with your friends (Step 4 below).';
      } catch (e) {
        status.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
        btn.disabled = false;
      }
    });

    document.getElementById('om-new-key')!.addEventListener('click', async () => {
      keyStatus.textContent = 'Creating passkey…';
      try {
        const k = await createSessionPasskey({
          rpId: window.location.hostname,
          rpName: window.location.host,
          userName: `recovered-key:${account}`,
        });
        newPublicKey = k.publicKey;
        newCredentialId = k.credentialId;
        keyStatus.textContent = 'New passkey created (' + buf2hex(k.publicKey).slice(0, 12) + '…).';
        prepareBtn.disabled = false;
      } catch (e) {
        keyStatus.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
      }
    });

    prepareBtn.addEventListener('click', async () => {
      prepareBtn.disabled = true;
      const status = document.getElementById('om-prepare-status')!;
      status.textContent = 'Staging…';
      try {
        const verifierAddress = await fetchVerifierAddress(account!);
        // Remove the lost device's key when the box is checked AND we resolved
        // exactly one removable signer. planRotation supports add + remove in a
        // single rotation (separate txs, one friend handoff), so the new key and
        // the removal land together — no second ceremony needed.
        const r = removable;
        const removeSignerId =
          removeCheckbox.checked && r?.ok ? r.signerId : undefined;
        const request: {
          defaultRuleId: number;
          addPasskey?: { verifierAddress: string; publicKey: Uint8Array };
          removeSignerId?: number;
        } = { defaultRuleId: 0 };
        if (newPublicKey) request.addPasskey = { verifierAddress, publicKey: newPublicKey };
        if (removeSignerId !== undefined) request.removeSignerId = removeSignerId;
        if (!request.addPasskey && request.removeSignerId === undefined) {
          throw new Error('Create a new passkey, or check "Remove the lost device\'s key", before sharing.');
        }
        const { handoffLink } = await prepareRotation({
          account: account!,
          recoveryRuleId: recoveryRuleId!,
          friends,
          threshold,
          request,
        });
        // Persist the new passkey so the user can use it after recovery.
        if (newCredentialId && newPublicKey) {
          saveRecoveredKey(account!, newCredentialId, newPublicKey);
        }
        (document.getElementById('om-link') as HTMLTextAreaElement).value = handoffLink;
        showCollect(threshold);
        refreshProgress();
        status.textContent = 'Staged. Share the link below.';
      } catch (e) {
        status.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
        prepareBtn.disabled = false;
      }
    });

    document.getElementById('om-copy-link')!.addEventListener('click', () => {
      navigator.clipboard.writeText((document.getElementById('om-link') as HTMLTextAreaElement).value);
    });

    // Pull any newly-arrived friend approvals from the relay, then re-render
    // progress. Friends submit their blobs to the relay instead of pasting back.
    let collecting = false;
    async function collectFromRelayNow() {
      const staging = getStaging(account!);
      if (!staging || collecting) return;
      collecting = true;
      try {
        const known = new Set(Object.keys(staging.collected));
        await collectFromRelay(account!, RELAY_BASE_URL, staging.relayKey, known);
        refreshProgress();
      } catch (e) {
        console.warn('relay poll failed:', e);
      } finally {
        collecting = false;
      }
    }

    document.getElementById('om-refresh')!.addEventListener('click', () => {
      void collectFromRelayNow();
    });

    // Poll while the collect step is visible (cheap GET; errors are swallowed).
    setInterval(() => {
      if (!document.getElementById('om-collect')!.hidden) void collectFromRelayNow();
    }, 10000);

    document.getElementById('om-submit')!.addEventListener('click', async () => {
      const btn = document.getElementById('om-submit') as HTMLButtonElement;
      btn.disabled = true;
      const status = document.getElementById('om-submit-status')!;
      status.textContent = 'Submitting…';
      try {
        const hash = await submitRotation(account!);
        status.textContent =
          'Done — your new passkey is active (tx ' + hash.slice(0, 8) + '…). Taking you to your account…';
        // Recovery complete: drop the user on their account home instead of
        // stranding them on the recovery page. We're already on the account
        // subdomain, so a same-origin /account/ redirect is correct.
        setTimeout(() => { window.location.href = '/account/'; }, 1200);
      } catch (e) {
        status.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
        btn.disabled = false;
      }
    });

    document.getElementById('om-cancel')!.addEventListener('click', () => {
      if (!confirm('Discard this staged rotation? Collected signatures will be lost.')) return;
      clearStaging(account!);
      location.reload();
    });

    function showCollect(_threshold: number) {
      document.getElementById('om-collect')!.hidden = false;
    }

    function refreshProgress() {
      const staging = getStaging(account!);
      if (!staging) return;
      const have = collectedCount(staging);
      const linkBox = document.getElementById('om-link') as HTMLTextAreaElement;
      if (!linkBox.value) {
        linkBox.value = recoveryHandoffLinkFromStaging(window.location.origin, staging);
      }
      document.getElementById('om-progress')!.textContent =
        `${have} of ${staging.threshold} required signatures collected.`;
      const ul = document.getElementById('om-collected')!;
      ul.innerHTML = Object.keys(staging.collected)
        .map((f) => `<li><code>${f.slice(0, 8)}…${f.slice(-4)}</code> ✓</li>`)
        .join('');
      (document.getElementById('om-submit') as HTMLButtonElement).disabled =
        have < staging.threshold;
    }
  }

  function saveRecoveredKey(acc: string, credentialId: string, publicKey: Uint8Array) {
    // Mirror saveCredential's storage shape so the wallet picks up the new key.
    const prefix = `passkey:${acc}:`;
    // base64url credentialId is already in the createSessionPasskey return.
    localStorage.setItem(prefix + 'credentialId', credentialId);
    localStorage.setItem(prefix + 'publicKey', buf2hex(publicKey));
  }

  // ---- ZK mode (?zk=1) ----------------------------------------------------
  // Recover using a BIP-39 seed phrase or an external wallet signature,
  // independent of trusted friends. Step machine (fixed ids, per the M4 plan):
  //   #zk-new-key -> #zk-secret -> #zk-sync -> #zk-initiate (#zk-prove nested)
  //   -> #zk-countdown -> #zk-complete, with #zk-status for top-level guard
  //   errors. The mnemonic / wallet signature is only ever held in a local
  //   variable long enough to derive the secret, then discarded — never
  //   localStorage, never logged.
  function formatDuration(totalSeconds: number): string {
    const s = Math.max(0, totalSeconds);
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = Math.floor(s % 60);
    return [h, m, sec].map((n) => String(n).padStart(2, '0')).join(':');
  }

  async function runZkMode() {
    zkMode.hidden = false;
    const status = document.getElementById('zk-status')!;
    if (!account) {
      status.textContent = 'Open this page on the account subdomain you want to recover.';
      return;
    }
    const acct = account; // narrowed, non-null for the rest of this closure

    const newKeySection = document.getElementById('zk-new-key') as HTMLElement;
    const newKeyBtn = document.getElementById('zk-new-key-btn') as HTMLButtonElement;
    const newKeyStatus = document.getElementById('zk-new-key-status')!;
    const secretSection = document.getElementById('zk-secret') as HTMLElement;
    const secretStatus = document.getElementById('zk-secret-status')!;
    const mnemonicInput = document.getElementById('zk-mnemonic-input') as HTMLTextAreaElement;
    const mnemonicBtn = document.getElementById('zk-mnemonic-btn') as HTMLButtonElement;
    const walletBtn = document.getElementById('zk-wallet-btn') as HTMLButtonElement;
    const syncSection = document.getElementById('zk-sync') as HTMLElement;
    const syncStatus = document.getElementById('zk-sync-status')!;
    const initiateSection = document.getElementById('zk-initiate') as HTMLElement;
    const initiateBtn = document.getElementById('zk-initiate-btn') as HTMLButtonElement;
    const initiateStatus = document.getElementById('zk-initiate-status')!;
    const proveProgress = document.getElementById('zk-prove') as HTMLElement;
    const proveStatus = document.getElementById('zk-prove-status')!;
    const countdownSection = document.getElementById('zk-countdown') as HTMLElement;
    const countdownText = document.getElementById('zk-countdown-text')!;
    const completeSection = document.getElementById('zk-complete') as HTMLElement;
    const completeBtn = document.getElementById('zk-complete-btn') as HTMLButtonElement;
    const completeStatus = document.getElementById('zk-complete-status')!;

    let zkNewPubkey: Uint8Array | null = null;
    let zkNewCredentialId: string | null = null;
    let zkSecret: Fr | null = null;
    let countdownTimer: number | undefined;
    // Seconds past `executable_after` (client clock) before completion is
    // offered / auto-retried — covers ledger-close lag vs wall-clock so the
    // on-chain timelock check has definitely passed. See showCountdown.
    const COMPLETE_BUFFER_SECS = 12;
    // The current pending's timelock bounds, shared with the complete handler
    // so it can distinguish a boundary-lag failure (retry) from an expired or
    // otherwise-permanent one (surface at once). 0 = unknown/not-applicable.
    let currentExecutableAfter = 0;
    let currentExpiresAt = 0;

    function showCountdown(executableAfter: number, expiresAt = 0) {
      currentExecutableAfter = executableAfter;
      currentExpiresAt = expiresAt;
      countdownSection.hidden = false;
      const tick = () => {
        const now = Math.floor(Date.now() / 1000);
        // The completion window (expires_at) closes recovery on-chain
        // (RecoveryError::RecoveryExpired). Past it, completion can only fail —
        // stop offering it and tell the user to restart, rather than letting
        // them click into an opaque auth error.
        if (currentExpiresAt && now >= currentExpiresAt) {
          countdownText.textContent =
            'This recovery request expired (its completion window closed). Start again from Step 1.';
          completeSection.hidden = true;
          if (countdownTimer !== undefined) clearInterval(countdownTimer);
          return;
        }
        const remaining = executableAfter - now;
        // Only reveal "complete" once the client clock is COMPLETE_BUFFER_SECS
        // PAST executable_after. The on-chain enforce checks the ledger's
        // close-time, which lags wall-clock (ledgers close every ~5-6s) — so a
        // completion submitted the instant our countdown hits zero can still
        // trip `TimelockNotElapsed`. The buffer keeps that boundary miss off
        // the happy path; the completion handler still retries as a backstop.
        if (remaining <= -COMPLETE_BUFFER_SECS) {
          countdownText.textContent = 'Your recovery is ready to complete.';
          completeSection.hidden = false;
          if (countdownTimer !== undefined) clearInterval(countdownTimer);
          return;
        }
        if (remaining <= 0) {
          countdownText.textContent = 'Finalizing on the network — ready in a few seconds…';
          return;
        }
        countdownText.textContent = `Executable in ${formatDuration(remaining)}.`;
      };
      tick();
      countdownTimer = window.setInterval(tick, 1000);
    }

    // Retries `completeZkRecovery` when it fails on the timelock boundary
    // (see the completion handler + showCountdown for why the ledger clock
    // lags). Non-timelock failures (wrong key, expired, etc.) rethrow at once.
    async function completeWithTimelockRetry(
      args: Parameters<typeof completeZkRecovery>[0],
    ): Promise<string> {
      const MAX_ATTEMPTS = 4;
      const RETRY_DELAY_MS = 8000;
      // How far past executable_after a failure can still plausibly be
      // ledger-close lag rather than a real problem. Every enforce panic
      // (RecoveryExpired, ContextMismatch from a wrong new_pubkey, NoPending
      // from an already-completed recovery) collapses to the same opaque
      // "(Auth, InvalidAction)" as a timelock miss, so the error string ALONE
      // can't classify it — gate on actually being in the boundary window and
      // not past expiry, else these permanent failures would retry 4× behind a
      // misleading "Almost there…" message instead of surfacing at once.
      const RETRY_MAX_SKEW_SECS = 90;
      for (let attempt = 1; ; attempt++) {
        try {
          return await completeZkRecovery(args);
        } catch (e) {
          const msg = e instanceof Error ? e.message : String(e);
          const now = Math.floor(Date.now() / 1000);
          const withinBoundary =
            currentExecutableAfter > 0 &&
            now >= currentExecutableAfter &&
            now < currentExecutableAfter + RETRY_MAX_SKEW_SECS &&
            (!currentExpiresAt || now < currentExpiresAt);
          const looksLikeTimelock = /InvalidAction|TimelockNotElapsed|enforce simulation|#15/i.test(msg);
          if (looksLikeTimelock && withinBoundary && attempt < MAX_ATTEMPTS) {
            completeStatus.textContent =
              'Almost there — the network needs a few more seconds to finalize the timelock. Retrying…';
            await new Promise((r) => setTimeout(r, RETRY_DELAY_MS));
            continue;
          }
          throw e;
        }
      }
    }

    // Resume: a chain-authoritative pending recovery (getZkPending) plus the
    // advisory local staging record (readStaged) drive an in-progress resume
    // on reload. If the chain says nothing is pending, drop any stale local
    // staging and start the ceremony from step 1.
    async function tryResume(): Promise<boolean> {
      const staged = readStaged(acct);
      let pending: Awaited<ReturnType<typeof getZkPending>> = null;
      try {
        pending = await getZkPending(acct);
      } catch {
        pending = null;
      }
      if (!pending) {
        if (staged) clearStaged(acct);
        return false;
      }
      newKeySection.hidden = true;
      // Prefer the on-chain pending record's own `new_pubkey` (T4 review
      // finding) over the local (advisory-only) staging record — it's
      // authoritative and survives cleared site data / a different device
      // than the one that started the recovery. Fall back to staging only
      // if the chain read somehow came back without it.
      if (pending.newPubkey65.length === 65) {
        zkNewPubkey = pending.newPubkey65;
      } else if (staged) {
        zkNewPubkey = hex2buf(staged.newPubkey65Hex);
      }
      showCountdown(pending.executableAfter, pending.expiresAt);
      if (!zkNewPubkey) {
        countdownText.textContent +=
          " This browser has no local record of the new key — if you cleared " +
          "site data, you'll need the device that started this recovery to finish it.";
      }
      return true;
    }

    if (await tryResume()) return;

    newKeySection.hidden = false;

    newKeyBtn.addEventListener('click', async () => {
      newKeyBtn.disabled = true;
      newKeyStatus.textContent = 'Creating passkey…';
      try {
        const k = await createSessionPasskey({
          rpId: window.location.hostname,
          rpName: window.location.host,
          userName: `zk-recovery-key:${acct}`,
        });
        zkNewPubkey = k.publicKey;
        zkNewCredentialId = k.credentialId;
        newKeyStatus.textContent =
          'New passkey created (' + buf2hex(k.publicKey).slice(0, 12) + '…).';
        secretSection.hidden = false;
      } catch (e) {
        newKeyStatus.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
        newKeyBtn.disabled = false;
      }
    });

    async function afterSecret() {
      secretSection.hidden = true;
      syncSection.hidden = false;
      syncStatus.textContent = 'Checking the recovery pool…';
      try {
        const accountId32 = StrKey.decodeContract(acct);
        const storedLeaf = wrapLeafStored(accountId32, wrapLeafInner(zkSecret!));
        const located = await syncPoolAndLocate(acct, fieldToBytes32(storedLeaf));
        if (!located) {
          syncStatus.textContent =
            "We couldn't find this account's recovery enrollment in the pool. " +
            "If this account never enrolled ZK recovery, this method can't be used here " +
            '— try Trusted friends instead.';
          return;
        }
        syncStatus.textContent = 'Found your enrollment. Ready to start recovery.';
        initiateSection.hidden = false;
      } catch (e) {
        syncStatus.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
      }
    }

    mnemonicBtn.addEventListener('click', async () => {
      const words = mnemonicInput.value.trim().split(/\s+/).filter(Boolean);
      if (words.length !== 12 && words.length !== 24) {
        secretStatus.textContent = 'Enter your 12 or 24-word recovery phrase.';
        return;
      }
      const mnemonic = words.join(' ');
      if (!validateMnemonic(mnemonic, wordlist)) {
        secretStatus.textContent = "That phrase doesn't look right — check the words and try again.";
        return;
      }
      mnemonicBtn.disabled = true;
      walletBtn.disabled = true;
      secretStatus.textContent = 'Deriving your recovery secret…';
      try {
        zkSecret = await deriveSecretM1(mnemonic, '', acct, NETWORK_PASSPHRASE);
        mnemonicInput.value = ''; // the phrase's only job was this derivation
        secretStatus.textContent = '';
        await afterSecret();
      } catch (e) {
        secretStatus.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
        mnemonicBtn.disabled = false;
        walletBtn.disabled = false;
      }
    });

    walletBtn.addEventListener('click', async () => {
      mnemonicBtn.disabled = true;
      walletBtn.disabled = true;
      secretStatus.textContent = 'Connecting your wallet…';
      try {
        await initWalletKit({ networkPassphrase: NETWORK_PASSPHRASE });
        const session = await connectWallet();
        zkSecret = await deriveM2SecretSafely({
          kit: StellarWalletsKit,
          account: acct,
          walletAddress: session.walletAddress,
          networkPassphrase: NETWORK_PASSPHRASE,
          onStatus: (s) => { secretStatus.textContent = s; },
        });
        secretStatus.textContent = '';
        await afterSecret();
      } catch (e) {
        secretStatus.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
        mnemonicBtn.disabled = false;
        walletBtn.disabled = false;
      }
    });

    initiateBtn.addEventListener('click', async () => {
      if (!zkSecret || !zkNewPubkey) return;
      initiateBtn.disabled = true;
      initiateStatus.textContent = '';
      proveProgress.hidden = false;
      proveStatus.textContent = 'Generating your recovery proof — this can take up to a minute…';
      try {
        const result = await initiateZkRecovery({
          account: acct,
          secret: zkSecret,
          newPubkey65: zkNewPubkey,
        });
        proveProgress.hidden = true;
        initiateStatus.textContent = 'Recovery started (tx ' + result.txHash.slice(0, 8) + '…).';
        initiateSection.hidden = true;
        showCountdown(result.executableAfter);
      } catch (e) {
        proveProgress.hidden = true;
        initiateStatus.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
        initiateBtn.disabled = false;
      }
    });

    completeBtn.addEventListener('click', async () => {
      completeBtn.disabled = true;
      completeStatus.textContent = 'Finishing recovery…';
      // Belt-and-suspenders vs the countdown's own expiry check: if the window
      // closed between render and click, don't submit a doomed completion.
      if (currentExpiresAt && Math.floor(Date.now() / 1000) >= currentExpiresAt) {
        completeStatus.textContent =
          'This recovery request expired (its completion window closed). Start again from Step 1.';
        return;
      }
      try {
        // Prefer the on-chain pending record's own `new_pubkey` (T4 review
        // finding) over this device's local (advisory-only) staging record —
        // it's authoritative and works even after cleared site data, or from
        // a different device than the one that started the recovery. Fall
        // back to staging, then to this session's in-memory `zkNewPubkey`.
        let newPubkey65: Uint8Array | null = null;
        try {
          const pending = await getZkPending(acct);
          if (pending && pending.newPubkey65.length === 65) {
            newPubkey65 = pending.newPubkey65;
          }
        } catch {
          // best-effort -- fall through to the local staging/in-memory record
        }
        if (!newPubkey65) {
          const staged = readStaged(acct);
          newPubkey65 = staged ? hex2buf(staged.newPubkey65Hex) : zkNewPubkey;
        }
        if (!newPubkey65) {
          throw new Error(
            "Missing this device's staged recovery record. If you cleared site data since " +
              "starting this recovery, it can't be completed automatically here.",
          );
        }
        const server = new rpc.Server(RPC_URL);
        const ruleRv = await simulateView(server, new Contract(acct), 'recovery_rule_id');
        const ruleId = scValToNative(ruleRv) as number | null;
        if (ruleId == null) throw new Error('This account has no ZK recovery rule installed.');
        const webauthnVerifierId = await fetchVerifierAddress(acct);

        // The completion is gated on-chain by the ledger clock, which lags
        // wall-clock — a submission a hair early trips `TimelockNotElapsed`
        // (#15), which the relayer surfaces as a generic "(Auth,
        // InvalidAction)". The precise #15 is buried in diagnostic events we
        // don't see here, so near the boundary treat an auth-validation
        // failure as "not ready yet" and retry a few times before giving up.
        const hash = await completeWithTimelockRetry({
          account: acct,
          recoveryRuleId: ruleId,
          newPubkey65,
          webauthnVerifierId,
        });
        completeStatus.textContent = 'Done — your new passkey is active (tx ' + hash.slice(0, 8) + '…).';
        if (zkNewCredentialId && zkNewPubkey) {
          saveRecoveredKey(acct, zkNewCredentialId, zkNewPubkey);
        }
        completeSection.hidden = true;
        countdownSection.hidden = true;
        setTimeout(() => { window.location.href = '/account/'; }, 1200);
      } catch (e) {
        completeStatus.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
        completeBtn.disabled = false;
      }
    });
  }
</script>

<style>
  section { margin: 0; }
  .pad code, .pad .mono { font-family: var(--mono); }
  textarea.input { font-family: var(--mono); font-size: 12px; }
  #om-collected { list-style: none; padding: 0; margin: 12px 0 0; }
  #om-collected :global(li) {
    font-family: var(--mono); font-size: 12px; color: var(--good-ink);
    padding: 4px 0;
  }
  #om-collected :global(code) {
    background: var(--good-soft); color: var(--good-ink);
    padding: 1px 6px; border-radius: var(--r-sm);
  }
  /* status / error markup the script may inject into om-stage uses .muted */
  :global(.muted) { color: var(--mut); font-size: 13px; }
