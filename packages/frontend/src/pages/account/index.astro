---
// Nido reskin of the ACCOUNT / home page. Real logic is preserved verbatim
// from the original (BaseLayout) version — only the markup, copy and presentation
// are reskinned to the Nido "Warm Nest" design system.
//
// Layouts: NidoLayout (NOT BaseLayout). Toast + PasskeySheet are mounted once
// here so toast() and withPasskeySheet() work.
//
// Preserved logic (rewired, not rewritten):
//   - initAccountCard / fetchXlmBalance — REAL XLM balance (no fabricated USD).
//   - copy-address — now uses toast() for "Copied!" feedback.
//   - name section — saveAccountName/loadAccountName + claim/sign-redirect-return flow.
//   - passkey-info section, register section, sign-a-hash section.
//   - signing mode — reskinned with PasskeySheet + withPasskeySheet(realCeremony);
//     loadCredential / signHash / registerPasskey plumbing intact (Task 15 removes).
//
// Send & Activity from the prototype are intentionally OMITTED (no backend).
// "Settings" links out to the existing /security/ page (no settings built here).
import NidoLayout from "../../layouts/NidoLayout.astro";
import Toast from "../../components/Toast.astro";
import PasskeySheet from "../../components/PasskeySheet.astro";
import Avatar from "../../components/Avatar.astro";
import Icon from "../../components/Icon.astro";
import Qr from "../../components/Qr.astro";
import Logo from "../../components/Logo.astro";
import Nest from "../../components/Nest.astro";
import RecentActivityCard from "../../components/RecentActivityCard.astro";
import AssetsCard from "../../components/AssetsCard.astro";
import MyNidoMenu from "../../components/MyNidoMenu.astro";
---

<NidoLayout title="Your Nido">
  <div class="col-scroll scroll-hide">
    <!-- top bar -->
    <div class="topbar">
      <a id="home-link" href="/" class="topbar-mark" data-home-apex aria-label="Nido home"><Nest size={30} /></a>
      <MyNidoMenu>
        <button slot="trigger" type="button" class="topbar-account" data-mynido-trigger aria-haspopup="true" aria-expanded="false">
          <span id="account-nickname" style="font-weight:800; font-size:14.5px; white-space:nowrap;">Your Nido</span>
          <span class="mn-sr"> — switch account</span>
          <Avatar seed="nido" size={32} class="js-avatar" />
          <span class="mynido-caret" aria-hidden="true">▾</span>
        </button>
      </MyNidoMenu>
    </div>

    <div id="error-box" role="alert" class="alert danger" style="display:none; margin:8px 22px;"></div>

    <!-- ============================================================= -->
    <!-- SIGNING MODE — reskinned signature request                    -->
    <!-- ============================================================= -->
    <div id="signing-mode" class="hidden screen-in pad" style="padding-top:18px;">
      <div style="text-align:center; margin-bottom:18px;">
        <div style="width:72px; height:72px; border-radius:20px; background:var(--acc-soft); display:grid; place-items:center; margin:0 auto 14px;">
          <span id="sign-icon-generic"><Icon name="shieldcheck" size={36} color="var(--acc)" /></span>
          <span id="sign-icon-claim" class="hidden"><Icon name="sparkle" size={36} color="var(--acc)" /></span>
        </div>
        <div id="sign-title" class="disp" style="font-weight:800; font-size:26px;">Approve this request</div>
        <p id="sign-sub" class="mut" style="font-size:14px; line-height:1.5; max-width:320px; margin:8px auto 0;">
          An app is asking you to sign. Review it, then confirm with your passkey.
        </p>
      </div>

      <div class="card" style="padding:4px 16px;">
        <!-- Name row — shown only when this request is a recognized name claim
             (the incoming hash matches the one the claim flow stashed). Default
             hidden via inline display (NOT the .hidden class) because the row
             also carries an inline display, and an inline style would otherwise
             override the class and leak an empty row into the generic path. -->
        <div id="sign-name-row" style="display:none; justify-content:space-between; align-items:center; gap:14px; padding:14px 0;">
          <span class="mut" style="font-size:13.5px; font-weight:600; white-space:nowrap;">Name</span>
          <code id="sign-name" class="mono" style="font-size:15px; font-weight:700; margin-left:auto; text-align:right; word-break:break-all; color:var(--acc-ink);"></code>
        </div>
        <div id="sign-from-row" style="display:flex; justify-content:space-between; align-items:center; gap:14px; padding:14px 0;">
          <span class="mut" style="font-size:13.5px; font-weight:600; white-space:nowrap;">From</span>
          <span id="sign-origin" class="mono" style="font-size:13px; margin-left:auto; text-align:right; word-break:break-all;"></span>
        </div>
        <div id="sign-hash-row" style="display:flex; justify-content:space-between; gap:14px; padding:14px 0; border-top:1px solid var(--line-soft);">
          <span class="mut" style="font-size:13.5px; font-weight:600; white-space:nowrap;">Hash</span>
          <code id="sign-hash" class="mono" style="font-size:11.5px; margin-left:auto; text-align:right; word-break:break-all;"></code>
        </div>
      </div>
      <!-- For a recognized name claim the verifiable details (the decoded
           transaction + the raw hash) are collapsed behind this toggle (mirrors
           the /sign/ page's "Show raw transaction"). Populated by JS. -->
      <button id="sign-toggle-tech" type="button" class="hidden" style="background:none; border:none; color:var(--acc-ink); font-weight:700; cursor:pointer; font-size:12.5px; padding:0; margin:10px 0 0;">Show technical details</button>
      <div id="sign-tech" class="hidden" style="margin-top:12px;"></div>

      <div id="sign-needs-register" style="margin-top:18px;">
        <p class="mut" style="font-size:13.5px; line-height:1.5; text-align:center; margin:0 0 14px;">
          You don't have a passkey on this Nido yet. Set one up first, then you can approve.
        </p>
        <button id="sign-register-btn" class="btn acc">
          <Icon name="key" size={20} color="#fff" /> Set up your passkey
        </button>
      </div>

      <div id="sign-ready" class="hidden" style="margin-top:18px;">
        <button id="approve-btn" class="btn acc">
          <Icon name="faceid" size={20} color="#fff" /> <span class="js-confirm-label">Confirm it's you</span>
        </button>
        <button id="deny-btn" class="btn ghost" style="margin-top:10px;">Not now</button>
      </div>

      <pre id="sign-mode-result" class="mono" style="display:none; margin-top:16px; font-size:12.5px; color:var(--good); text-align:center;"></pre>
    </div>

    <!-- ============================================================= -->
    <!-- CLAIM ENTRY — unclaimed name subdomain, non-signing            -->
    <!-- ============================================================= -->
    <!-- A standalone top-level view (sibling of #signing-mode / #home-mode),
         NOT nested in #home-mode: an unclaimed name has no account context, so
         #home-mode (and its empty balance/address hero) is never revealed.
         showClaimEntry un-hides this section directly. Visited when an UNCLAIMED
         name subdomain is opened outside signing mode — we identify a claiming
         account here and hand off to that account's own subdomain (where its
         passkey rpId matches) to do the claim. -->
    <div id="claim-entry" class="hidden screen-in pad" style="padding-top:18px;">
      <span class="section-label" style="display:block; margin-bottom:12px;">Claim this name</span>
      <div class="card" style="padding:16px;">
        <p style="font-size:15px; font-weight:600; margin:0 0 6px;">
          <span id="claim-entry-name"></span> is available
        </p>
        <p class="mut" style="font-size:13.5px; line-height:1.5; margin:0 0 14px;">
          Claim it for <strong id="claim-entry-account"></strong>. We'll open your account's
          domain to confirm with your passkey, then bring you back here.
        </p>
        <button id="claim-entry-btn" class="btn acc">
          <Icon name="sparkle" size={18} color="#fff" /> Claim <span id="claim-entry-name2"></span>
        </button>
        <button id="claim-entry-switch" class="btn ghost sm" type="button" style="margin-top:8px; display:none;">
          Use a different account
        </button>
        <div id="claim-entry-picker" class="hidden" style="margin-top:10px;"></div>
      </div>
    </div>

    <!-- ============================================================= -->
    <!-- HOME MODE                                                     -->
    <!-- ============================================================= -->
    <div id="home-mode" class="hidden screen-in home-mode">
      <div class="card-grid">
      <!-- desktop greeting (≥1024 only): the account topbar is hidden at desktop
           width, so this welcome line + network chip anchors the dashboard. -->
      <div class="home-greeting">
        <div>
          <div class="mut home-greeting-eyebrow">Welcome back</div>
          <h1 class="disp home-hello js-account-name">Your Nido</h1>
        </div>
        <span class="chip acc"><span class="dot"></span> Testnet</span>
      </div>

      <!-- balance — primary hero. Mobile/tablet: centered balance + the circular
           quick actions below. Desktop (≥1024): a horizontal card with balance +
           address on the left and Send / Receive on the right. -->
      <div class="span-all home-hero" style="padding:14px 22px 0; text-align:center;">
        <div class="home-hero-bal">
          <div class="mut" style="font-size:13px; font-weight:700;">Balance</div>
          <div class="disp" id="xlm-balance" style="font-weight:800; font-size:48px; letter-spacing:-.01em; line-height:1.04; margin-top:4px;">…</div>
          <div class="mut" style="font-size:14px; font-weight:600; margin-top:2px;">In your Nido</div>
          <!-- Claim a name — coral CTA sitting directly above the contract
               address (the contract name), matching the Send button's accent.
               Revealed by JS only for accounts that have not claimed a name. -->
          <div class="home-claim-row" style="margin-top:14px;">
            <button id="claim-name-top-btn" class="btn acc sm hidden" style="font-size:13px;" type="button">
              <Icon name="sparkle" size={16} color="#fff" /> Claim a name
            </button>
          </div>
          <div class="home-addr-row" style="display:flex; justify-content:center; margin-top:14px;">
            <button id="copy-btn" class="addr addr-full" title="Copy your address">
              <code id="contract-id" style="background:none; padding:0;"></code>
              <span class="copy-ico" aria-hidden="true"><Icon name="copy" size={15} color="var(--ink-soft)" /></span>
              <span class="copy-check" aria-hidden="true"><Icon name="check" size={15} color="var(--good)" /></span>
            </button>
          </div>
          <div style="margin-top:10px;">
            <a id="explorer-link" class="link" target="_blank" rel="noopener" style="display:none; font-size:13px;">View on Stellar Expert</a>
          </div>
        </div>
        <!-- desktop-only hero actions; bound to the same panel toggles as the
             mobile circular actions via the .js-send / .js-receive classes. -->
        <div class="home-hero-actions-d">
          <button type="button" class="btn acc js-send" style="width:auto; padding:0 24px;">
            <Icon name="send" size={17} color="#fff" /> Send
          </button>
          <button type="button" class="btn soft js-receive" style="width:auto; padding:0 24px;" aria-expanded="false" aria-controls="receive-section">
            <Icon name="receive" size={17} /> Receive
          </button>
        </div>
      </div>

      <!-- quick actions — Receive (the everyday action) gets the coral emphasis
           (H-02); "Prove" is demoted to neutral + renamed the concrete job it
           does, "Approve" (→ the focused /sign/ surface); "Settings" → "Security"
           with the shield glyph so the entry points agree on one label (K-03). -->

      <div class="span-all home-actions-mobile" style="display:flex; gap:6px; padding:26px 30px 6px;">
        <button id="send-action" class="qa js-send" type="button">
          <div class="circ"><Icon name="send" size={24} color="#fff" /></div>
          <span>Send</span>
        </button>
        <button id="receive-action" class="qa js-receive" type="button" aria-expanded="false" aria-controls="receive-section">
          <div class="circ soft"><Icon name="receive" size={23} /></div>
          <span>Receive</span>
        </button>
        <a class="qa" href="/security/">
          <div class="circ soft"><Icon name="shield" size={23} /></div>
          <span>Security</span>
        </a>
      </div>

      <!-- Inline name-claim form — opened by the coral "Claim a name" button in
           the hero. Hidden until JS reveals it (unclaimed accounts only). -->
      <div class="span-all hidden" id="claim-name-inline" style="padding:0 22px 6px;">
        <p class="mut" style="font-size:13px; line-height:1.45; margin:0 0 8px;">
          Use 1-15 lowercase letters and digits, starting with a letter. After it is claimed, we'll open the new domain address and register its passkey because browsers lock passkeys to the domain shown.
        </p>
        <div style="display:flex; gap:6px; align-items:center;">
          <input id="name-input" class="input" placeholder="e.g. alice" maxlength="15" pattern="[a-z][a-z0-9]*" style="font-size:13px; min-width:0; flex:1;" />
          <button id="claim-name-btn" class="btn acc sm" type="button" style="font-size:13px;">Claim + passkey</button>
        </div>
        <div id="name-result" role="status" aria-live="polite" class="mut mono" style="display:none; font-size:12.5px; margin-top:8px; line-height:1.5;"></div>
      </div>

      <!-- The XLM-only inline Send panel was retired here: "Send" now opens the
           dedicated multi-asset transfer view at /transfer/ (the .js-send
           buttons navigate there in initHomeMode). -->

      <!-- ============ ASSETS ============ -->
      <div class="grid-cell">
        <AssetsCard />
      </div>

      <!-- ============ RECENT ACTIVITY ============ -->
      <div class="grid-cell home-col-activity">
        <RecentActivityCard />
      </div>

      <!-- ============ RECEIVE PANEL (display-only) ============ -->
      <div class="grid-cell home-panel">
      <section id="receive-section" class="hidden pad" style="text-align:center; padding-top:18px;">
        <span class="section-label" style="display:block; text-align:left; margin-bottom:12px;">Receive</span>
        <p class="mut" style="font-size:14px; line-height:1.5; max-width:320px; margin:0 auto 18px;">
          Share your address or code so anyone can send to your Nido.
        </p>
        <div style="background:var(--paper-2); border:1px solid var(--line); border-radius:22px; padding:18px; display:inline-block; box-shadow:var(--sh-1);">
          <Qr data="nido" size={188} />
        </div>
        <div class="card" style="padding:16px; margin-top:22px; text-align:left; display:flex; align-items:center; gap:12px;">
          <Avatar seed="nido" size={34} class="js-avatar" />
          <div style="flex:1; min-width:0;">
            <div style="font-weight:700; font-size:13.5px;">Your Nido</div>
            <code id="receive-address" class="mut mono" style="font-size:12px; display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"></code>
          </div>
        </div>
        <button id="receive-copy-btn" class="btn soft" style="margin-top:14px;">
          <Icon name="copy" size={18} /> Copy address
        </button>
      </section>
      </div>

      <!-- ============ NAME SECTION ============ -->
      <div class="grid-cell home-panel">
      <section id="name-section" class="hidden pad" style="padding-top:18px;">
        <span class="section-label" style="display:block; margin-bottom:12px;">Your name</span>

        <div id="name-display" class="hidden">
          <div class="card" style="padding:4px 16px;">
            <div style="display:flex; justify-content:space-between; align-items:center; gap:14px; padding:14px 0;">
              <span class="mut" style="font-size:13.5px; font-weight:600;">Name</span>
              <code id="account-name" class="mono" style="font-size:14px; margin-left:auto;"></code>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; gap:14px; padding:14px 0; border-top:1px solid var(--line-soft);">
              <span class="mut" style="font-size:13.5px; font-weight:600;">Share link</span>
              <a id="name-url" class="link mono" style="font-size:12.5px; margin-left:auto; text-align:right; word-break:break-all;"></a>
            </div>
          </div>
        </div>

      </section>
      </div>

      <!-- ============ REGISTER (when no passkey) ============ -->
      <div class="grid-cell home-panel">
      <section id="register-section" class="hidden pad" style="padding-top:18px;">
        <span class="section-label" style="display:block; margin-bottom:12px;">Set up your passkey</span>
        <div class="card" style="padding:16px;">
          <p id="register-copy" class="mut" style="font-size:13.5px; line-height:1.5; margin:0 0 14px;">
            Create a passkey bound to this Nido. It's how you'll prove it's you — no seed phrase, no password.
          </p>
          <button id="register-btn" class="btn acc">
            <Icon name="key" size={20} color="#fff" /> <span id="register-label">Set up your passkey</span>
          </button>
        </div>
      </section>
      </div>

      <!-- H-03: the "Developer" disclosure (status-message demo + sign-a-hash tool)
           has been removed from the consumer wallet — it belongs behind a dev flag,
           not on the primary account screen, so consumers never meet raw hashes.
           The status-message entry point will return as a link to a properly
           external dApp (tracked separately). -->

      <div class="span-all home-foot" style="display:flex; justify-content:center; margin:8px 0 28px;">
        <Logo size={18} mark markSize={24} />
      </div>
      </div>
    </div>
  </div>

  <Toast />
  <PasskeySheet />
</NidoLayout>

<script>
  import {
    Networks,
  } from "@stellar/stellar-sdk";
  import {
    parseRegistration,
    derToCompact,
    buf2hex,
    hex2buf,
    contractIdFromHostname,
    isContractId,
    nameFromHostname,
    resolveNameCached,
    stripSubdomain,
    accountUrl,
    saveAccount,
    saveCredential as sdkSaveCredential,
    loadCredential as sdkLoadCredential,
    saveAccountName,
    loadAccountName,
    fetchRegistryAddress,
  } from "@nidohq/passkey-sdk";
  import { accountShareUrl, accountShareLabel } from "../../lib/accountLinks";
  import {
    classifyNameState,
    selectClaimer,
    formatClaimerLabel,
    buildClaimHandoffUrl,
  } from "../../lib/claimFlow";
  import { localNidoSnapshot, syncNidoStorageViaBridge } from "../../lib/nidoSharedStorage";
  import { createNido } from "../../lib/createNido";
  import { markUsed, readLastUsed } from "../../lib/lastUsed";
  import { toast } from "../../lib/toast";
  import { describeSignRequest } from "../../lib/signRequestSummary";
  import { stashSignRequest, type SignRequest } from "../../lib/signing/signRequest";
  import { describeTransaction } from "../../lib/transfer/txSummary";
  import { renderNameRegister } from "../../lib/transfer/review";
  import { esc } from "../../lib/html";
  import { withPasskeySheet } from "../../lib/passkeySheet";
  import { detectPasskeyLabel } from "../../lib/passkeyLabel";
  import { shortAddr } from "../../lib/address";
  import { formatXlm } from "../../lib/money";
  import { fetchXlmBalance } from "../../lib/balance";
  import { checkPasskeySupport } from "../../lib/passkeySupport";

  const RPC_URL = "https://soroban-testnet.stellar.org";

  // The on-page "Your name" / "Claim a name" card. Was parked while the claim
  // round-trip was broken (bug #3); re-enabled now that the finalize flow signs
  // and submits correctly. (Name-subdomain *resolution* below is independent of
  // this flag and stays active.)
  const SHOW_NAME_SECTION = true;

  // Friendly platform label for confirm copy ("Confirm with Face ID", etc.).
  const passkey = detectPasskeyLabel();
  const confirmLabel = `Confirm with ${passkey.label}`;
  document.querySelectorAll<HTMLElement>(".js-confirm-label").forEach((el) => {
    el.textContent = confirmLabel;
  });

  // --- URL params (needed early for signing mode detection) ---

  const params = new URLSearchParams(window.location.search);
  const signHashParam = params.get("sign");
  const callbackUrl = params.get("callback");
  const isSigningMode = signHashParam && callbackUrl;
  const shouldRegisterNamePasskey = params.get("namepasskey") === "1";

  // --- State ---

  const hostname = window.location.hostname;
  let contractId = contractIdFromHostname(hostname);
  const rpId = hostname;

  // Point every home link (tagged data-home-apex — here the topbar mark; the
  // sidebar brand is handled by the Sidebar module) at the apex as early as
  // possible, before any code that could throw. The static fallback is href="/",
  // but on a contract subdomain the root page redirects straight back here — so
  // if a later runtime error skipped this, the home button would loop. Doing it
  // here (independent of contractId resolution) keeps it safe.
  {
    const apexHome = `//${stripSubdomain(window.location.host)}/`;
    document
      .querySelectorAll<HTMLAnchorElement>("[data-home-apex]")
      .forEach((a) => (a.href = apexHome));
  }

  // --- Name resolution ---
  // If the subdomain is a human-readable name (not a 56-char contract ID),
  // resolve it to a contract ID. Stay on the name subdomain for shareability.
  // Only redirect to contract-ID subdomain when signing (passkey RP ID binding).

  const detectedName = nameFromHostname(hostname);
  if (detectedName && !isContractId(detectedName)) {
    try {
      const resolved = await resolveNameCached(
        RPC_URL,
        await fetchRegistryAddress("name-registry"),
        detectedName,
        "Test SDF Network ; September 2015"
      );
      if (resolved) {
        if (isSigningMode) {
          // Redirect to contract-ID subdomain for passkey auth
          const rootHost = stripSubdomain(window.location.host);
          const target = accountUrl(rootHost, resolved, window.location.pathname + window.location.search);
          window.location.replace(window.location.protocol + target);
          throw new Error("redirecting");
        }
        // Stay on name subdomain — use resolved ID for all operations
        contractId = resolved;
      } else if (!isSigningMode) {
        // Syntactically-valid but unclaimed name + not signing → offer to claim
        // it. The entry view OWNS the page (it picks a claiming account and
        // hands off to that account's own subdomain), so halt the rest of
        // module init: there's no account context to initialize for an
        // unclaimed name. A bare `return` is illegal at module top level here
        // (this whole block runs in the script's ES-module body), so mirror the
        // signing-mode redirect above and throw a sentinel the catch re-throws.
        await showClaimEntry(detectedName);
        throw new Error("claim-entry");
      } else {
        // Signing mode: nothing to sign against an unresolved name.
        showError(`Name "${detectedName}" not found in the registry.`);
      }
    } catch (err: any) {
      if (err.message === "redirecting" || err.message === "claim-entry") throw err;
      showError(`Couldn't resolve that name: ${err.message}`);
    }
  }

  function saveCredential(credentialId: Uint8Array, publicKey: Uint8Array) {
    sdkSaveCredential(contractId!, credentialId, publicKey);
  }

  function loadCredential() {
    return contractId ? sdkLoadCredential(contractId) : null;
  }

  function bytesToArrayBuffer(bytes: Uint8Array): ArrayBuffer {
    const buffer = new ArrayBuffer(bytes.byteLength);
    new Uint8Array(buffer).set(bytes);
    return buffer;
  }

  // --- Shared: register passkey ---

  async function registerPasskey() {
    if (!contractId) throw new Error("Navigate to <contractId>.<domain> to use");

    const userId = new Uint8Array(16);
    crypto.getRandomValues(userId);

    const credential = (await navigator.credentials.create({
      publicKey: {
        challenge: crypto.getRandomValues(new Uint8Array(32)),
        rp: { name: `Soroban ${contractId}`, id: rpId },
        user: {
          id: userId,
          name: contractId,
          displayName: `Account ${contractId}`,
        },
        pubKeyCredParams: [{ alg: -7, type: "public-key" }],
        authenticatorSelection: {
          residentKey: "required",
          userVerification: "required",
        },
        attestation: "none",
        timeout: 60000,
      },
    })) as PublicKeyCredential;

    const reg = parseRegistration(credential as any);
    saveCredential(reg.credentialId, reg.publicKey);
    return reg;
  }

  // --- Shared: sign hash ---

  async function signHash(hashHex: string) {
    const cred = loadCredential();
    if (!cred) throw new Error("No passkey registered");

    const challenge = bytesToArrayBuffer(hex2buf(hashHex));

    const assertion = (await navigator.credentials.get({
      publicKey: {
        challenge: challenge,
        rpId: rpId,
        allowCredentials: [
          {
            id: bytesToArrayBuffer(cred.credentialId),
            type: "public-key",
          },
        ],
        userVerification: "required",
        timeout: 60000,
      },
    })) as PublicKeyCredential;

    const response = assertion.response as AuthenticatorAssertionResponse;
    const authenticatorData = new Uint8Array(response.authenticatorData);
    const clientDataJSON = new Uint8Array(response.clientDataJSON);
    const signatureDer = new Uint8Array(response.signature);
    const signatureCompact = derToCompact(signatureDer);

    return {
      authenticatorData: buf2hex(authenticatorData),
      clientDataJSON: buf2hex(clientDataJSON),
      signature: buf2hex(signatureCompact),
      publicKey: cred.publicKey,
    };
  }

  // --- UI helpers ---

  function showError(msg: string) {
    const $errorBox = document.getElementById("error-box")!;
    $errorBox.textContent = msg;
    $errorBox.style.display = "block";
  }

  function clearError() {
    document.getElementById("error-box")!.style.display = "none";
  }

  function passkeyBlockedHint(action: "registration" | "signing"): string {
    return `Passkey ${action} was blocked. If you're using an in-app browser (Twitter, Instagram, etc.), tap the menu (…) and choose "Open in Safari" or "Open in Browser".`;
  }

  // =====================
  // CLAIM ENTRY (unclaimed name subdomain, non-signing)
  // =====================

  // Show the "claim this name" entry view for an UNCLAIMED, syntactically-valid
  // name. Picks a claiming account (param → recent → single → none) and hands
  // off to that account's own subdomain (where its passkey rpId matches).
  async function showClaimEntry(name: string) {
    const state = classifyNameState(name, null); // resolved was null in this branch
    if (state === "invalid") {
      showError(`"${name}" isn't a valid name.`);
      return;
    }

    const paramAccount = params.get("account");
    // Pull accounts from local storage, then refresh from the apex bridge if empty.
    let snapshot = localNidoSnapshot();
    if (snapshot.accounts.length === 0) {
      await syncNidoStorageViaBridge();
      snapshot = localNidoSnapshot();
    }

    const apexHost = stripSubdomain(window.location.host);

    // No account anywhere → send to new-account (on the apex) with a return intent.
    const choice = selectClaimer(paramAccount, snapshot.accounts, readLastUsed());
    if (choice.contractId === null) {
      // No account yet → start a fresh new-account reservation, carrying the claim
      // intent so we return here to claim the name once it's deployed.
      const setupUrl = createNido(window.location.host); // //<setupHost>/new-account/?salt=<hex>&setup=1
      const sep = setupUrl.includes("?") ? "&" : "?";
      window.location.href = `${window.location.protocol}${setupUrl}${sep}then=claim:${encodeURIComponent(name)}`;
      return;
    }

    const claimer = choice.contractId;
    const claimerName = snapshot.names[claimer] ?? null;

    const $entry = document.getElementById("claim-entry")!;
    document.getElementById("claim-entry-name")!.textContent = name;
    document.getElementById("claim-entry-name2")!.textContent = name;
    document.getElementById("claim-entry-account")!.textContent = formatClaimerLabel(claimer, claimerName);
    $entry.classList.remove("hidden");

    const handoff = () =>
      buildClaimHandoffUrl({
        apexHost,
        fromHost: window.location.host,
        claimName: name,
        claimerContractId: claimer,
        claimerName,
        protocol: window.location.protocol,
      });

    document.getElementById("claim-entry-btn")!.addEventListener("click", () => {
      window.location.href = handoff();
    });

    // Offer account switching only when there is more than one account.
    if (snapshot.accounts.length > 1) {
      const $switch = document.getElementById("claim-entry-switch") as HTMLButtonElement;
      $switch.style.display = "block";
      $switch.addEventListener("click", () => {
        const $picker = document.getElementById("claim-entry-picker")!;
        $picker.classList.toggle("hidden");
        if (!$picker.dataset.mounted) {
          renderClaimPicker($picker, name, apexHost, snapshot);
          $picker.dataset.mounted = "1";
        }
      });
    }
  }

  function renderClaimPicker(
    host: HTMLElement,
    name: string,
    apexHost: string,
    snapshot: { accounts: string[]; names: Record<string, string> },
  ) {
    host.innerHTML = "";
    for (const id of snapshot.accounts) {
      const row = document.createElement("button");
      row.type = "button";
      row.className = "btn ghost sm";
      row.style.cssText = "display:block; width:100%; text-align:left; margin-bottom:6px;";
      row.textContent = formatClaimerLabel(id, snapshot.names[id] ?? null);
      row.addEventListener("click", () => {
        window.location.href = buildClaimHandoffUrl({
          apexHost,
          fromHost: window.location.host,
          claimName: name,
          claimerContractId: id,
          claimerName: snapshot.names[id] ?? null,
          protocol: window.location.protocol,
        });
      });
      host.append(row);
    }
  }

  function clearNamePasskeyParam() {
    const url = new URL(window.location.href);
    url.searchParams.delete("namepasskey");
    window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
  }

  function initAccountCard() {
    // Show the FULL contract address (not a truncated 6…6 form) so the
    // account's on-chain identity — the contract name — is never hidden behind
    // an ellipsis.
    document.getElementById("contract-id")!.textContent = contractId ?? "(unknown)";

    const $explorerLink = document.getElementById("explorer-link") as HTMLAnchorElement;
    if (contractId) {
      $explorerLink.href = `https://stellar.expert/explorer/testnet/contract/${contractId}`;
      $explorerLink.style.display = "inline";
    }

    // Copy button — fires the Nido toast AND flips the button into an inline
    // "copied" check state, so a tap gives unmissable local feedback even if
    // the toast is missed.
    const $copyBtn = document.getElementById("copy-btn") as HTMLButtonElement;
    $copyBtn.addEventListener("click", async () => {
      if (!contractId) return;
      try {
        await navigator.clipboard.writeText(contractId);
        toast({ msg: "Copied your address", icon: "check" });
        flashCopied($copyBtn);
      } catch {
        toast("Couldn't copy — try selecting it manually");
      }
    });
  }

  // Briefly flip a copy button into its "copied" check state (the CSS toggles
  // the copy glyph for a check), then restore it. Re-entrant taps reset the
  // timer instead of stacking.
  let copiedTimer: ReturnType<typeof setTimeout> | undefined;
  function flashCopied(btn: HTMLElement) {
    btn.classList.add("copied");
    if (copiedTimer) clearTimeout(copiedTimer);
    copiedTimer = setTimeout(() => btn.classList.remove("copied"), 1300);
  }

  // =====================
  // SIGNING MODE
  // =====================

  // The raw auth digest, as a labelled card — the irreducible "what you're
  // signing" detail, shown inside the collapsible technical section.
  function renderSignHashCard(hash: string): string {
    return `<div class="card" style="padding:13px 16px;margin-top:10px;">
      <div class="mut" style="font-size:12px;font-weight:600;margin-bottom:6px;">Signature hash</div>
      <code class="mono" style="font-size:11.5px;word-break:break-all;line-height:1.5;">${esc(hash)}</code>
    </div>`;
  }

  function renderStoredNameClaimDetails(name: string, signHash: string): string {
    const account = contractId;
    const registry = localStorage.getItem("nido:name-registry-id");
    const row = (label: string, valueHtml: string, first = false) => {
      const border = first ? "" : "border-top:1px solid var(--line-soft);";
      return `<div style="display:flex;align-items:center;justify-content:space-between;gap:14px;padding:13px 0;${border}">
        <span class="mut" style="font-size:13px;font-weight:600;white-space:nowrap;">${label}</span>
        <span style="font-size:13.5px;font-weight:600;text-align:right;min-width:0;word-break:break-word;">${valueHtml}</span>
      </div>`;
    };
    const accountRow = account
      ? row("For account", `<span class="mono">${esc(shortAddr(account))}</span>`)
      : "";
    const registryRow = registry
      ? row("Registry", `<span class="mono">${esc(shortAddr(registry))}</span>`)
      : "";
    return `<div class="card" style="padding:2px 16px;">
      ${row("Action", "Register a name", true)}
      ${row("Name", `<code class="mono">${esc(name)}</code>`)}
      ${accountRow}
      ${registryRow}
    </div>${renderSignHashCard(signHash)}`;
  }

  // Decode the transaction the claim flow stashed (same origin) and render it as
  // human-readable detail, so "technical details" shows the actual register
  // operation, not just the digest. Best-effort: any failure leaves the
  // already-rendered hash card in place.
  async function renderClaimTxDetails($tech: HTMLElement, signHash: string) {
    const txXdr = localStorage.getItem("nido:name-txXdr");
    if (!txXdr) return;
    try {
      // stellar-sdk's XDR parsing needs the Buffer global (same lazy polyfill
      // the claim/finalize paths use before any SDK call).
      const { Buffer: B } = await import("buffer");
      if (typeof globalThis.Buffer === "undefined") (globalThis as any).Buffer = B;

      const summary = describeTransaction(txXdr, Networks.TESTNET);
      const reg = summary.ops.find((o) => o.kind === "name-register");
      if (!reg || reg.kind !== "name-register") return;

      let fee: bigint | undefined;
      try {
        fee = BigInt(summary.fee);
      } catch {
        fee = undefined;
      }
      $tech.innerHTML = renderNameRegister(reg, fee) + renderSignHashCard(signHash);
    } catch {
      /* keep the hash-only card already shown */
    }
  }

  function initSigningMode() {
    document.getElementById("signing-mode")!.classList.remove("hidden");

    // K-04: an "approve a request" moment is a single focused decision — strip
    // the wallet sidebar + topbar so this surface matches the dedicated /sign/
    // treatment, regardless of which route the request arrived on. Inline
    // display:none beats the ≥1024 sidebar media query.
    const $sidebar = document.querySelector<HTMLElement>(".nido-sidebar");
    if ($sidebar) $sidebar.style.display = "none";
    const $topbar = document.querySelector<HTMLElement>(".col-app .topbar");
    if ($topbar) $topbar.style.display = "none";

    // Show request details
    let originDisplay: string;
    try {
      originDisplay = new URL(callbackUrl!).origin;
    } catch {
      originDisplay = callbackUrl!;
    }
    document.getElementById("sign-origin")!.textContent = originDisplay;
    document.getElementById("sign-hash")!.textContent = signHashParam;

    // If this request is the name claim the user just started, surface what
    // they're actually approving — the name — instead of only the raw hash.
    // describeSignRequest binds that friendly copy to the exact hash (the claim
    // flow stashed both), so a mismatched/forged request can't borrow it.
    const summary = describeSignRequest({
      signHash: signHashParam!,
      claimHash: localStorage.getItem("nido:name-claim-hash"),
      claimName: localStorage.getItem("nido:name-pending"),
    });
    const signingNameClaim = summary.kind === "name-claim" ? summary.name : null;
    if (summary.kind === "name-claim") {
      document.getElementById("sign-icon-generic")!.classList.add("hidden");
      document.getElementById("sign-icon-claim")!.classList.remove("hidden");
      document.getElementById("sign-title")!.textContent = "Claim your name";
      document.getElementById("sign-sub")!.textContent =
        `You're claiming the name "${summary.name}" for your Nido. Confirm with your passkey to lock it in.`;

      document.getElementById("sign-name")!.textContent = summary.name;
      document.getElementById("sign-name-row")!.style.display = "flex";
      // The "From" origin and the in-card raw-hash row are noise for a
      // self-initiated claim — hide both. The verifiable details (the decoded
      // transaction + the hash) move into the collapsible block below.
      document.getElementById("sign-from-row")!.style.display = "none";
      document.getElementById("sign-hash-row")!.style.display = "none";

      const $tech = document.getElementById("sign-tech")!;
      // Show hash-bound name-claim details immediately so the toggle is useful
      // even if async XDR decoding fails; enrich with the decoded transaction
      // when ready.
      $tech.innerHTML = renderStoredNameClaimDetails(summary.name, signHashParam!);
      void renderClaimTxDetails($tech, signHashParam!);

      const $toggle = document.getElementById("sign-toggle-tech")!;
      $toggle.classList.remove("hidden");
      $toggle.addEventListener("click", () => {
        const shown = $tech.classList.toggle("hidden") === false;
        $toggle.textContent = shown ? "Hide technical details" : "Show technical details";
      });
    }

    const cred = loadCredential();
    if (cred) {
      document.getElementById("sign-ready")!.classList.remove("hidden");
      document.getElementById("sign-needs-register")!.classList.add("hidden");
    } else {
      document.getElementById("sign-needs-register")!.classList.remove("hidden");
      document.getElementById("sign-ready")!.classList.add("hidden");
    }

    // Register button in signing mode
    document.getElementById("sign-register-btn")!.addEventListener("click", async () => {
      clearError();
      const btn = document.getElementById("sign-register-btn") as HTMLButtonElement;
      const support = checkPasskeySupport();
      if (!support.ok) {
        showError(support.message!);
        return;
      }
      try {
        btn.disabled = true;
        await withPasskeySheet(() => registerPasskey(), {
          title: "Set up your passkey",
          sub: `Confirm with ${passkey.label} to create it.`,
        });
        document.getElementById("sign-needs-register")!.classList.add("hidden");
        document.getElementById("sign-ready")!.classList.remove("hidden");
      } catch (err: any) {
        if (err.name === "NotAllowedError") {
          showError(passkeyBlockedHint("registration"));
        } else {
          showError(`Couldn't set up your passkey: ${err.message}`);
        }
      } finally {
        btn.disabled = false;
      }
    });

    // Approve button
    document.getElementById("approve-btn")!.addEventListener("click", async () => {
      clearError();

      const btn = document.getElementById("approve-btn") as HTMLButtonElement;
      const support = checkPasskeySupport();
      if (!support.ok) {
        showError(support.message!);
        return;
      }
      try {
        btn.disabled = true;

        const result = await withPasskeySheet(
          () => signHash(signHashParam!),
          signingNameClaim
            ? {
                title: "Claim your name",
                sub: `Confirm with ${passkey.label} to register "${signingNameClaim}" for this Nido.`,
              }
            : {
                title: confirmLabel,
                sub: "Approving the request from the app.",
              },
        );

        const $result = document.getElementById("sign-mode-result")!;
        $result.style.display = "block";
        $result.textContent = "Approved — sending you back…";

        const cbUrl = new URL(callbackUrl!);
        cbUrl.searchParams.set("authenticatorData", result.authenticatorData);
        cbUrl.searchParams.set("clientDataJSON", result.clientDataJSON);
        cbUrl.searchParams.set("signature", result.signature);
        cbUrl.searchParams.set("publicKey", result.publicKey);

        setTimeout(() => {
          window.location.href = cbUrl.toString();
        }, 500);
      } catch (err: any) {
        if (err.name === "NotAllowedError") {
          showError(passkeyBlockedHint("signing"));
        } else {
          showError(`Couldn't confirm: ${err.message}`);
        }
        btn.disabled = false;
      }
    });

    // Deny button
    document.getElementById("deny-btn")!.addEventListener("click", () => {
      try {
        const cbUrl = new URL(callbackUrl!);
        cbUrl.searchParams.set("error", "denied");
        window.location.href = cbUrl.toString();
      } catch {
        window.history.back();
      }
    });
  }

  // =====================
  // HOME MODE
  // =====================

  function initHomeMode() {
    document.getElementById("home-mode")!.classList.remove("hidden");

    if (contractId) markUsed(contractId);

    const cred = loadCredential();
    const $registerSection = document.getElementById("register-section")!;
    const $registerBtn = document.getElementById("register-btn") as HTMLButtonElement;
    const $registerCopy = document.getElementById("register-copy");
    const $registerLabel = document.getElementById("register-label");

    if (!cred) {
      $registerSection.classList.remove("hidden");
      if (detectedName && $registerCopy) {
        $registerCopy.textContent =
          `Your Nido now opens at ${detectedName}. Browsers bind passkeys to each domain address, so register a passkey here before approving from this name.`;
        if ($registerLabel) $registerLabel.textContent = `Register passkey for ${detectedName}`;
      }
    } else if (shouldRegisterNamePasskey) {
      clearNamePasskeyParam();
    }

    // Receive panel toggle (display-only)
    const $receiveSection = document.getElementById("receive-section")!;
    // Both the mobile circular action and the desktop hero pill carry .js-receive.
    document.querySelectorAll(".js-receive").forEach((el) =>
      el.addEventListener("click", () => {
        const open = $receiveSection.classList.toggle("hidden");
        if (!open) {
          $receiveSection.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }
        // Update aria-expanded on all receive toggle buttons
        document.querySelectorAll('[aria-controls="receive-section"]').forEach(btn => {
          btn.setAttribute('aria-expanded', String(!open));
        });
      }),
    );
    // Receive copy button
    document.getElementById("receive-copy-btn")!.addEventListener("click", async () => {
      if (!contractId) return;
      try {
        await navigator.clipboard.writeText(contractId);
        toast({ msg: "Copied your address", icon: "check" });
      } catch {
        toast("Couldn't copy — try selecting it manually");
      }
    });

    // --- Send → dedicated /transfer/ view ---
    // The XLM-only inline panel was retired; "Send" now opens the multi-asset
    // transfer view. Navigate on the CONTRACT-ID subdomain so the passkey
    // ceremony there binds to the registered credential (a name subdomain would
    // change WebAuthn's rpId), mirroring the signing-mode redirect.
    {
      const rootHost = stripSubdomain(window.location.host);
      const transferHref = contractId
        ? `${window.location.protocol}${accountUrl(rootHost, contractId, "/transfer/")}`
        : "/transfer/";
      document.querySelectorAll(".js-send").forEach((el) =>
        el.addEventListener("click", () => {
          window.location.href = transferHref;
        }),
      );
    }

    // Register passkey (when none exists yet)
    async function runPasskeyRegistration(options?: { namePasskey?: boolean }) {
      clearError();
      const support = checkPasskeySupport();
      if (!support.ok) {
        if (options?.namePasskey) clearNamePasskeyParam();
        showError(support.message!);
        return;
      }
      try {
        $registerBtn.disabled = true;

        await withPasskeySheet(
          () => registerPasskey(),
          {
            title: options?.namePasskey ? "Register this name's passkey" : "Set up your passkey",
            sub: options?.namePasskey && detectedName
              ? `${detectedName} is a new domain address. Passkeys are locked to the domain shown, so confirm once to use this name.`
              : `Confirm with ${passkey.label} to create it.`,
          },
        );

        $registerSection.classList.add("hidden");
        if (options?.namePasskey) clearNamePasskeyParam();
        toast({ msg: options?.namePasskey ? "Passkey ready for this name" : "Passkey ready", icon: "check" });
      } catch (err: any) {
        if (options?.namePasskey) clearNamePasskeyParam();
        if (err.name === "NotAllowedError") {
          showError(passkeyBlockedHint("registration"));
        } else {
          showError(`Couldn't set up your passkey: ${err.message}`);
        }
      } finally {
        $registerBtn.disabled = false;
      }
    }

    $registerBtn.addEventListener("click", () => {
      void runPasskeyRegistration(shouldRegisterNamePasskey ? { namePasskey: true } : undefined);
    });

    // Arriving on the freshly-claimed name subdomain (?namepasskey=1): bring the
    // "Register passkey for <name>" button into view and let the user TAP it.
    // Do NOT auto-fire navigator.credentials.create() from a timer — WebAuthn
    // needs a transient user gesture to surface the passkey UI (1Password on
    // Firefox/Zen and iOS Safari enforce this; see attemptAutoPasskey in
    // new-account). A programmatic call just darkens our sheet with no provider
    // prompt and can trap the user behind the scrim. The button runs the same
    // registration, gesture-activated.
    if (!cred && shouldRegisterNamePasskey && detectedName && !isSigningMode) {
      $registerSection.scrollIntoView({ behavior: "smooth", block: "center" });
    }
  }

  // --- Init ---

  initAccountCard();

  // Home link is set unconditionally near the top of the script (before any
  // code that can throw), so it doesn't need setting here.

  if (isSigningMode) {
    initSigningMode();
  } else {
    if (contractId) saveAccount(contractId);
    initHomeMode();
  }

  // Show the real, full address in the Receive panel.
  document.getElementById("receive-address")!.textContent = contractId || "(unknown)";

  // Fetch balance in background — REAL XLM, no fabricated fiat figure.
  const $balance = document.getElementById("xlm-balance")!;
  if (contractId) {
    fetchXlmBalance(contractId).then((balance) => {
      // Friendly grouping via money.formatXlm; keep the XLM figure truthful
      // (no fabricated fiat "$" balance — that was the prototype's mock).
      const friendly = formatXlm(balance);
      $balance.innerHTML = `${friendly} <span class="mut" style="font-size:24px;">XLM</span>`;
    }).catch(() => {
      $balance.textContent = "unavailable";
    });
  } else {
    $balance.textContent = "—";
  }

  // --- Name section ---

  if (SHOW_NAME_SECTION && contractId && !isSigningMode) {
    const $nameSection = document.getElementById("name-section")!;
    const $nameDisplay = document.getElementById("name-display")!;
    const $claimBtn = document.getElementById("claim-name-btn") as HTMLButtonElement;
    const $nameInput = document.getElementById("name-input") as HTMLInputElement;

    // The name is known authoritatively when we arrived via a name subdomain
    // (detectedName already resolved to THIS account); otherwise fall back to a
    // locally-saved name. On a name subdomain, persist it so later contract-id
    // visits in this browser show the name too. Either way: show the name (with
    // the contract id in the account card above), never the claim card.
    const existingName = detectedName ?? loadAccountName(contractId);
    if (existingName) {
      if (detectedName) saveAccountName(contractId, detectedName);
      $nameSection.classList.remove("hidden");
      $nameDisplay.classList.remove("hidden");
      document.getElementById("account-name")!.textContent = existingName;
      // Reflect the claimed name in the top bar nickname + desktop greeting.
      document.getElementById("account-nickname")!.textContent = existingName;
      document
        .querySelectorAll(".js-account-name")
        .forEach((el) => (el.textContent = existingName));
      const rootHost = stripSubdomain(window.location.host);
      const nameLink = document.getElementById("name-url") as HTMLAnchorElement;
      nameLink.href = accountShareUrl(rootHost, existingName);
      nameLink.textContent = accountShareLabel(rootHost, existingName);
    } else {
      // Show the claim-a-name CTA (now a single coral button sitting above the
      // contract address in the hero).
      const topBtn = document.getElementById("claim-name-top-btn") as HTMLButtonElement | null;
      const inlineForm = document.getElementById("claim-name-inline") as HTMLElement | null;
      if (topBtn) topBtn.classList.remove("hidden");
      const openClaimForm = () => {
        inlineForm?.classList.remove("hidden");
        inlineForm?.scrollIntoView({ behavior: "smooth", block: "nearest" });
        $nameInput.focus();
      };
      topBtn?.addEventListener("click", openClaimForm);
    }


    // Claim name button — route through /sign/ (unified signing surface).
    $claimBtn.addEventListener("click", () => {
      const name = $nameInput.value.trim().toLowerCase();
      if (!name || !/^[a-z][a-z0-9]*$/.test(name) || name.length > 15) {
        showError("Name must be 1-15 characters, lowercase letters and digits only, starting with a letter.");
        return;
      }
      if (!contractId) {
        showError("Navigate to your account's subdomain to claim a name.");
        return;
      }
      const rootHost = stripSubdomain(window.location.host);
      const returnUrl = `${window.location.protocol}${accountUrl(rootHost, name, "/account/?namepasskey=1")}`;
      const req: SignRequest = {
        v: 1,
        kind: "name-claim",
        account: contractId,
        operation: { type: "register", name },
        title: `Claim ${name}`,
        submitMode: "relayer",
        returnTarget: { type: "route", url: returnUrl },
      };
      const id = stashSignRequest(req);
      window.location.href = `/sign/?req=${id}`;
    });

    // --- Auto-run on ?claim=<name> (account's own subdomain) ---
    // Build a SignRequest and hand off to /sign/ so the claim flows through
    // the unified signing surface. Return target: the name subdomain at /account/?namepasskey=1.
    const claimParam = params.get("claim");
    if (claimParam && contractId && !isSigningMode) {
      const name = claimParam.trim().toLowerCase();
      if (/^[a-z][a-z0-9]{0,14}$/.test(name)) {
        const rootHost = stripSubdomain(window.location.host);
        const returnUrl = `${window.location.protocol}${accountUrl(rootHost, name, "/account/?namepasskey=1")}`;
        const req: SignRequest = {
          v: 1,
          kind: "name-claim",
          account: contractId,
          operation: { type: "register", name },
          title: `Claim ${name}`,
          submitMode: "relayer",
          returnTarget: { type: "route", url: returnUrl },
        };
        const id = stashSignRequest(req);
        window.location.href = `/sign/?req=${id}`;
      }
    }

    // --- Auto-run on ?sm-sign=<xdr>&sm-return=<url> (status-message handoff) ---
    // status-message redirects here (on the account's subdomain) carrying the
    // assembled tx XDR and a return URL. We stash a SignRequest in sessionStorage
    // (now on the correct origin) and redirect to /sign/?req=<id>, exactly like
    // the ?claim= handoff above. The return URL already encodes the contract
    // address so the status-message page can repopulate its input on return.
    const smSignXdr = params.get("sm-sign");
    const smReturnUrl = params.get("sm-return");
    if (smSignXdr && smReturnUrl && contractId && !isSigningMode) {
      const req: SignRequest = {
        v: 1,
        kind: "generic",
        account: contractId,
        operation: { type: "raw-xdr", xdr: smSignXdr },
        title: "Set your note",
        subtitle: "Sign the on-chain status-message update.",
        submitMode: "relayer",
        returnTarget: { type: "route", url: smReturnUrl },
      };
      const id = stashSignRequest(req);
      window.location.href = `/sign/?req=${id}`;
