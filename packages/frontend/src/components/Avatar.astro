---
// Deterministic identicon avatar — a hash→hsl radial gradient circle.
// Pure presentation; the same `seed` always yields the same colors.
// Ported from `app/ui.jsx` `Avatar` (shares the FNV-1a `hashStr`).
//   <Avatar seed={address} size={34} />
interface Props {
  /** Seed string (e.g. an address). Same seed → same gradient. Default "nido". */
  seed?: string;
  /** Diameter in px. Default 34. */
  size?: number;
  /** Optional class on the wrapper. */
  class?: string;
}

const { seed = "nido", size = 34, class: className } = Astro.props;

// FNV-1a 32-bit hash (matches the prototype's hashStr).
function hashStr(s: string): number {
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}

const h = hashStr(seed);
// C-04: pull hues from a brand-adjacent set (coral / amber / honey / teal /
// indigo / plum) instead of the full wheel, so every avatar stays in the Nido
// palette. Unsigned shifts (>>>) avoid the signed-shift NaN: `h >> n` goes
// negative for large hashes, which indexed the anchor array out of bounds.
const anchors = [14, 28, 40, 186, 250, 332];
const j = ((h >>> 11) % 16) - 8;
const hue1 = (anchors[h % anchors.length] + j + 360) % 360;
const hue2 = (anchors[(h >>> 5) % anchors.length] - j + 360) % 360;
const style = [
  `width: ${size}px`,
  `height: ${size}px`,
  "border-radius: 50%",
  "flex: 0 0 auto",
  `background: radial-gradient(circle at 32% 28%, hsl(${hue1} 58% 60%), hsl(${hue2} 60% 42%))`,
  "box-shadow: inset 0 0 0 1.5px rgba(255,255,255,.35)",
].join("; ");
---

<div class={className} style={style}></div>
