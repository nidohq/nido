---
// packages/frontend/src/components/AssetsCard.astro
// The Living Ledger "balances band": the OTHER held assets (XLM stays the hero
// above) as compact balance chips, NOT a bordered card. It reads as a
// continuation of the balance hero — a band on --paper-2 closed by a single
// hairline below (added by the .ledger container in account/index.astro).
//
// Same client-side resolution as RecentActivityCard: the address comes from the
// hostname subdomain (name subdomains resolve via the registry), so no SSR
// address exists.
---
<section class="bal-band">
  <div class="bal-body">
    <div class="bal-skeleton">
      <span class="skeleton">&nbsp;</span><span class="skeleton">&nbsp;</span>
    </div>
    <!-- chips horizontal-scroll on mobile, wrap on desktop (see is:global below) -->
    <div class="bal-chips scroll-hide" hidden></div>
    <span class="bal-empty mut" hidden>Only XLM so far.</span>
    <a class="bal-explorer" target="_blank" rel="noopener noreferrer" hidden>On explorer →</a>
  </div>
</section>

<style is:global>
  /* is:global: chips are injected via innerHTML, so scoped styles wouldn't reach them. */
  .bal-band { padding: 14px 22px 16px; }
  .bal-body { display: flex; align-items: center; gap: 12px; min-width: 0; }
  /* :not([hidden]) so the `hidden` attribute can still hide it — a bare
     `display:flex` would out-specify the UA `[hidden]{display:none}` rule. */
  .bal-skeleton:not([hidden]) { display: flex; gap: 10px; flex: 1; }
  .bal-skeleton .skeleton { height: 34px; width: 108px; border-radius: var(--r-md); display: block; }

  /* the chip track: scrolls horizontally on mobile, wraps on desktop */
  .bal-chips:not([hidden]) { display: flex; gap: 8px; flex: 1; min-width: 0; overflow-x: auto; }
  @media (min-width: 800px) { .bal-chips:not([hidden]) { flex-wrap: wrap; overflow-x: visible; } }

  .bal-chip {
    display: inline-flex; align-items: center; gap: 8px; flex: 0 0 auto;
    padding: 5px 12px 5px 5px; border-radius: var(--r-md);
    background: var(--chip); color: var(--ink); text-decoration: none;
    font-size: 13.5px; font-weight: 600; white-space: nowrap; position: relative;
    transition: background .14s;
  }
  .bal-chip:hover { background: #e4ddcd; }
  .bal-chip .ricon.asset-initial {
    width: 28px; height: 28px; border-radius: var(--r-sm); flex: 0 0 auto;
    display: grid; place-items: center; background: var(--paper-2); color: var(--ink-soft);
    font-weight: 800; font-size: 12.5px; position: relative; overflow: hidden;
  }
  /* logo sits over the letter chip; removing it (load error) reveals the letter */
  .bal-chip .asset-icon { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; background: var(--paper-2); }
  .bal-chip .bal-code { color: var(--ink-soft); }
  .bal-chip .bal-amt { font-weight: 800; }
  /* unverified holding: a small warn dot in place of the (untrusted) domain */
  .bal-chip .bal-warn { width: 7px; height: 7px; border-radius: 50%; background: var(--warn); flex: 0 0 auto; }

  .bal-empty { font-size: 13px; font-weight: 600; flex: 1; }
  .bal-explorer { font-size: 12.5px; color: var(--acc-ink); font-weight: 700; text-decoration: none; white-space: nowrap; flex: 0 0 auto; margin-left: auto; }
  .bal-explorer:hover { text-decoration: underline; }
</style>

<script>
  import { loadAssets } from "../lib/assets/assets.js";
  import { balChipHtml } from "../lib/assets/rowHtml.js";
  import { resolveTomlIcon } from "../lib/assets/icons.js";
  import { EXPLORER_BASE } from "../lib/network.js";
  import { resolveAccountAddress } from "../lib/resolveAccount.js";
  import type { AssetHolding } from "../lib/assets/types.js";

  function onIconError(img: HTMLImageElement) {
    img.addEventListener("error", () => img.remove(), { once: true });
  }

  /**
   * Lazy second pass, off the render path: fill icons the curated lists
   * didn't have from each anchor's SEP-1 stellar.toml (cached per contract).
   * A holding without a list domain still qualifies — its issuer's on-chain
   * home_domain is looked up inside resolveTomlIcon.
   */
  function patchTomlIcons(track: HTMLElement, holdings: AssetHolding[]) {
    for (const h of holdings) {
      if (!h.verified || h.icon || (!h.domain && !h.issuer)) continue;
      resolveTomlIcon(h)
        .then((icon) => {
          if (!icon) return;
          // contract ids are bare base32 strkeys — safe inside a selector.
          const chip = track.querySelector<HTMLElement>(
            `a[data-contract="${h.contractId}"] .asset-initial`,
          );
          if (!chip || chip.querySelector("img")) return;
          const img = document.createElement("img");
          img.className = "asset-icon";
          img.alt = "";
          img.loading = "lazy";
          img.referrerPolicy = "no-referrer";
          onIconError(img);
          img.src = icon;
          chip.appendChild(img);
        })
        .catch(() => {});
    }
  }

  async function init() {
    const band = document.querySelector<HTMLElement>(".bal-band");
    if (!band) return;
    const skel = band.querySelector<HTMLElement>(".bal-skeleton")!;
    const chips = band.querySelector<HTMLElement>(".bal-chips")!;
    const empty = band.querySelector<HTMLElement>(".bal-empty")!;
    const explorer = band.querySelector<HTMLAnchorElement>(".bal-explorer")!;
    const address = await resolveAccountAddress();
    if (!address) { skel.hidden = true; empty.hidden = false; return; }
    // Stellar Expert's contract page lists every held asset (its balances API
    // is origin-gated for us, but the human-facing page isn't) — so the
    // explorer link doubles as the full, indexer-backed view.
    explorer.href = `${EXPLORER_BASE}/contract/${address}`;
    explorer.hidden = false;
    try {
      // XLM is the hero above; the band shows only the OTHER held assets.
      const holdings = (await loadAssets(address)).filter(
        (h) => h.code.toUpperCase() !== "XLM",
      );
      skel.hidden = true;
      if (holdings.length === 0) { empty.hidden = false; return; }
      chips.innerHTML = holdings.map(balChipHtml).join("");
      chips.hidden = false;
      chips.querySelectorAll<HTMLImageElement>("img.asset-icon").forEach(onIconError);
      patchTomlIcons(chips, holdings);
    } catch {
      // Keep the explorer link usable; just fall back to the quiet empty text.
      skel.hidden = true;
      empty.textContent = "Couldn’t load balances.";
      empty.hidden = false;
    }
  }
  init();
</script>
