---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
  </head>
  <body>
    <a id="preview-banner" style="display:none" target="_blank" rel="noopener"></a>
    <div id="webview-warning" style="display:none">
      <p>PASSKEYS NOT SUPPORTED IN IN-APP BROWSERS.</p>
      <p>Tap the menu (<strong>&middot;&middot;&middot;</strong>) and choose <strong>"Open in Safari"</strong> or <strong>"Open in Browser"</strong>.</p>
    </div>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  #preview-banner { position: fixed; top: 0; left: 0; right: 0; display: none; background: #ff0000; color: #ffffff; font-family: 'Space Mono', 'Courier New', monospace; font-size: 0.85rem; font-weight: 700; padding: 0.5rem 1rem; text-align: center; text-decoration: none; text-transform: uppercase; letter-spacing: 0.1em; z-index: 9999; border-bottom: 3px solid #000000; }
  #preview-banner:hover { background: #000000; color: #ffff00; }
  body:has(#preview-banner[style*="display: block"]) { padding-top: 2.5rem; }

  #webview-warning { background: #ffff00; border: 3px solid #000000; color: #000000; padding: 1rem; margin-bottom: 1.5rem; font-family: 'Space Mono', 'Courier New', monospace; font-size: 0.8rem; font-weight: 700; line-height: 1.6; text-transform: uppercase; }
  #webview-warning p { margin: 0.25rem 0; }
</style>

<script>
  // Preview banner
  const sub = window.location.hostname.split(".")[0];
  const match = sub.match(/(?:--)?pr-(\d+)$/);
  if (match) {
    const prNum = match[1];
    const banner = document.getElementById("preview-banner") as HTMLAnchorElement;
    banner.textContent = `Preview PR #${prNum}`;
    banner.href = `https://github.com/theahaco/g2c/pull/${prNum}`;
    banner.style.display = "block";
  }

  // In-app WebView detection
  const ua = navigator.userAgent;
  const isIOS = /iPhone|iPad|iPod/.test(ua);
  const isInAppBrowser = (isIOS && (!/Safari/.test(ua) || !/Version\//.test(ua)))
    || /Twitter|Instagram|FBAN|FBAV|Line\//.test(ua)
    || !window.PublicKeyCredential;

  if (isInAppBrowser) {
    document.getElementById("webview-warning")!.style.display = "block";
  }
</script>
