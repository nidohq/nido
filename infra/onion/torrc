# nido production onion service.
#
# Single onion service: nido's server location is public infrastructure —
# anonymity is for users (who keep their full 3-hop circuits), not the server.
# Cuts the service-side path from 3 hops to 1.
HiddenServiceNonAnonymousMode 1
HiddenServiceSingleHopMode 1
SocksPort 0

DataDirectory /var/lib/tor
Log notice stdout

HiddenServiceDir /var/lib/tor/onion
HiddenServicePort 80 127.0.0.1:8080
HiddenServicePort 443 127.0.0.1:8443

# DoS defenses for a public frontend: proof-of-work on the intro path
# (tor 0.4.8+, GPL build) plus introduction-point rate limiting.
HiddenServicePoWDefensesEnabled 1
HiddenServiceEnableIntroDoSDefense 1
