# Vhost routing for the nido onion service. Tor delivers the full hostname
# (including the subdomain label left of the onion address) in the Host
# header; everything below keys off it. {$ONION_ADDR} is the bare onion
# hostname, e.g. "nido…xyz.onion".
#
# Serves plain HTTP on :8080 always. When ONION_TLS_CERT/ONION_TLS_KEY point
# at a cert (the HARICA mixed-SAN cert in prod, or a local-CA wildcard leaf
# for local testing), the :8443 site is enabled too — WebAuthn on onion
# origins requires https in every proven browser path.

{
	auto_https off
	admin off
}

# Shared routing logic, imported by both the HTTP and HTTPS site blocks.
(routes) {
	# --- API backhauls (EOTK pattern): same fixed egress IP for every -----
	# --- Tor user, so Cloudflare-fronted upstreams never see exit IPs -----
	@relay host relay.{$ONION_ADDR}
	handle @relay {
		reverse_proxy https://relay.nido.fyi {
			header_up Host relay.nido.fyi
		}
	}

	@indexer host pool-indexer.{$ONION_ADDR}
	handle @indexer {
		reverse_proxy https://pool-indexer.nido.fyi {
			header_up Host pool-indexer.nido.fyi
		}
	}

	# Soroban RPC backhaul. Dead until the frontend's hardcoded testnet
	# RPC_URL is made env-driven and pointed here (phase 2) — the app calls
	# soroban-testnet.stellar.org directly today. RPC_UPSTREAM e.g.
	# https://soroban-testnet.stellar.org. (No Horizon vhost: the codebase
	# uses Soroban RPC + friendbot only, never Horizon.)
	@rpc host rpc.{$ONION_ADDR}
	handle @rpc {
		reverse_proxy {$RPC_UPSTREAM} {
			header_up Host {$RPC_UPSTREAM_HOST}
		}
	}

	# Relayer. Default is the public Fly hostname; switch RELAYER_UPSTREAM to
	# the 6PN internal address (http://nido.internal:<port>) once wired so the
	# hop never leaves Fly's private network.
	@relayer host relayer.{$ONION_ADDR}
	handle @relayer {
		reverse_proxy {$RELAYER_UPSTREAM} {
			header_up Host {$RELAYER_UPSTREAM_HOST}
		}
	}

	# --- Static frontend: apex + every account subdomain ------------------
	handle {
		root * /srv/dist
		try_files {path} {path}/index.html
		file_server
	}
}

http://:8080 {
	import routes
}

# The https://:8443 site is appended by entrypoint.sh at boot ONLY when a cert
# is mounted (ONION_TLS_CERT points at a readable file) — Caddy's `tls`
# directive errors on empty arguments, so it can't live here unconditionally.
